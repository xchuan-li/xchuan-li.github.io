---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  showProgress?: boolean;
  wide?: boolean;
  toc?: boolean;
  ogImage?: string;
  frontmatter?: {
    title?: string;
    description?: string;
    showProgress?: boolean;
    wide?: boolean;
    toc?: boolean;
    ogImage?: string;
  };
}

const frontmatter = Astro.props.frontmatter ?? {};
const title = Astro.props.title ?? frontmatter.title ?? "Xiaochuan Li";
const description =
  Astro.props.description ??
  frontmatter.description ??
  "Causal interpretability through linguistic structure — testing whether a model's behavior is licensed by the genuine structure of a sentence, or by a surface cue that merely correlates.";
const showProgress = Astro.props.showProgress ?? frontmatter.showProgress ?? false;
const wide = Astro.props.wide ?? frontmatter.wide ?? false;
const toc = Astro.props.toc ?? frontmatter.toc ?? false;
const ogImage = Astro.props.ogImage ?? frontmatter.ogImage ?? "/og.png";

const site = Astro.site ?? new URL("https://xchuan-li.github.io");
const canonical = new URL(Astro.url.pathname, site).href;
const ogImageUrl = new URL(ogImage, site).href;

const personLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Xiaochuan Li",
  url: site.href,
  image: ogImageUrl,
  jobTitle: "Master's student, Human and AI",
  affiliation: {
    "@type": "CollegeOrUniversity",
    name: "University of Technology Nuremberg (UTN)",
  },
  knowsAbout: [
    "Causal inference",
    "Interpretability",
    "Mechanistic interpretability",
    "Multilingual NLP",
    "Linguistic typology",
    "Machine learning",
  ],
  sameAs: [
    "https://github.com/xchuan-li",
    "https://www.linkedin.com/in/xiaochuan-li-0488533b5/",
  ],
};

const nav = [
  { href: "/research", label: "Research" },
  { href: "/writing", label: "Writing" },
  { href: "/cv", label: "CV" },
  { href: "/contact", label: "Contact" },
];

const path = Astro.url.pathname;

// Plain ⇄ rich view switch (sits next to the theme toggle). The rich, illustrated
// homepage is the default ("/"); a plain, content-first version lives at "/plain".
// On the plain page the switch points back to the rich homepage; everywhere else
// it points to the plain page.
const isPlain = path === "/plain" || path === "/plain/";
const viewToggleHref = isPlain ? "/" : "/plain";
const viewToggleLabel = isPlain ? "Switch to the full, illustrated homepage" : "Switch to the plain version";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#fafaf7" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Crimson+Pro:wght@400;500&family=JetBrains+Mono:wght@400;500&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Crimson+Pro:wght@400;500&family=JetBrains+Mono:wght@400;500&display=swap" />
    </noscript>
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="Xiaochuan Li — Writing" href="/rss.xml" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Xiaochuan Li" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Xiaochuan Li — causal interpretability through linguistic structure" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <script type="application/ld+json" set:html={JSON.stringify(personLd)} />
  </head>
  <body>
    {showProgress && <div id="reading-progress" class="reading-progress"></div>}

    <nav class="site-nav" aria-label="Primary">
      <div class="site-nav-inner">
        <a href="/" class="site-brand" aria-label="Home">
          <svg class="site-mark" viewBox="0 0 32 32" width="26" height="26" role="img" aria-label="Home">
            <path class="sm-surface" d="M6 12 L11 7 L16 2 L21 7 L26 12" />
            <path class="sm-surface-line" d="M6 12 H26" />
            <path class="sm-structure" d="M6 12 L11 19 L16 12 L21 19 L26 12" />
            <path class="sm-structure" d="M11 19 L16 25 L21 19" />
            <path class="sm-structure" d="M16 25 V29" />
            <path class="sm-structure" d="M11 29 H21" />
            <circle class="sm-node" cx="6" cy="12" r="2.2" />
            <circle class="sm-node" cx="11" cy="19" r="2.2" />
            <circle class="sm-node" cx="16" cy="12" r="2.2" />
            <circle class="sm-node" cx="21" cy="19" r="2.2" />
            <circle class="sm-node" cx="26" cy="12" r="2.2" />
            <circle class="sm-node" cx="16" cy="25" r="2.2" />
          </svg>
          <span class="wordmark">Xiaochuan Li</span>
        </a>

        <div class="nav-links">
          {
            nav.map((item) => {
              const active = path === item.href || (item.href !== "/" && path.startsWith(item.href));
              return (
                <a href={item.href} class={`nav-link ${active ? "active" : ""}`}>
                  {item.label}
                </a>
              );
            })
          }
        </div>

        <div class="nav-actions">
          <a
            class="theme-toggle view-toggle"
            href={viewToggleHref}
            aria-label={viewToggleLabel}
            title={viewToggleLabel}
          >
            {isPlain ? (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <rect x="4" y="4" width="6.5" height="6.5" rx="1.4"></rect>
                <rect x="13.5" y="4" width="6.5" height="6.5" rx="1.4"></rect>
                <rect x="4" y="13.5" width="6.5" height="6.5" rx="1.4"></rect>
                <rect x="13.5" y="13.5" width="6.5" height="6.5" rx="1.4"></rect>
              </svg>
            ) : (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="7" x2="19" y2="7"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <line x1="5" y1="17" x2="13" y2="17"></line>
              </svg>
            )}
          </a>
        </div>
      </div>
    </nav>

    <main class="page-main">
      {wide ? (
        <slot />
      ) : toc ? (
        <div class="doc-grid">
          <nav class="doc-toc" aria-label="On this page">
            <p class="doc-toc-label">On this page</p>
            <ul id="page-toc"></ul>
          </nav>
          <div class="doc-content"><slot /></div>
        </div>
      ) : (
        <div class="container-narrow"><slot /></div>
      )}
    </main>

    <footer class="site-footer">
      <span>Last updated {new Date().toLocaleDateString("en-US", { month: "long", year: "numeric" })}</span>
      <span> · Built with <a href="https://astro.build">Astro</a></span>
      <span> · <a href="https://github.com/xchuan-li/xchuan-li.github.io">source</a></span>
    </footer>

    <script is:inline>
      // Build the "On this page" rail from the section headings, with scroll-spy.
      (function () {
        var list = document.getElementById('page-toc');
        var prose = document.querySelector('.doc-content .prose');
        if (!list || !prose) return;
        var heads = prose.querySelectorAll(':scope > h2, :scope > h3');
        if (heads.length < 2) {
          var grid = document.querySelector('.doc-grid');
          var rail = document.querySelector('.doc-toc');
          if (grid) grid.classList.add('no-toc');
          if (rail) rail.style.display = 'none';
          return;
        }
        var links = [];
        heads.forEach(function (h, i) {
          if (!h.id) {
            h.id = (h.textContent || 'section').toLowerCase()
              .replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '') || 'section-' + i;
          }
          var li = document.createElement('li');
          li.className = h.tagName === 'H3' ? 'lvl-3' : 'lvl-2';
          var a = document.createElement('a');
          a.href = '#' + h.id;
          a.textContent = h.textContent;
          li.appendChild(a);
          list.appendChild(li);
          links.push(a);
        });
        // Scroll-spy: highlight the last heading scrolled past the top band.
        var ticking = false;
        function updateSpy() {
          ticking = false;
          var idx = 0;
          for (var i = 0; i < heads.length; i++) {
            if (heads[i].getBoundingClientRect().top <= 140) idx = i;
            else break;
          }
          links.forEach(function (a, i) { a.classList.toggle('active', i === idx); });
        }
        window.addEventListener('scroll', function () {
          if (!ticking) { ticking = true; requestAnimationFrame(updateSpy); }
        }, { passive: true });
        window.addEventListener('resize', updateSpy);
        updateSpy();
      })();

      // Reveal-on-scroll for .fade-in and .fade-in-up.
      (function () {
        var els = document.querySelectorAll('.fade-in, .fade-in-up');
        if (!els.length) return;
        if (!('IntersectionObserver' in window)) {
          els.forEach(function (el) { el.classList.add('visible'); });
          return;
        }
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              io.unobserve(entry.target);
            }
          });
        }, { rootMargin: '0px 0px -10% 0px', threshold: 0.1 });
        els.forEach(function (el) { io.observe(el); });
      })();
    </script>

    {showProgress && (
      <script is:inline>
        (function () {
          var bar = document.getElementById("reading-progress");
          if (!bar) return;
          function update() {
            var h = document.documentElement;
            var scrolled = h.scrollTop;
            var total = h.scrollHeight - h.clientHeight;
            var pct = total > 0 ? (scrolled / total) * 100 : 0;
            bar.style.width = pct + "%";
          }
          window.addEventListener("scroll", update, { passive: true });
          window.addEventListener("resize", update);
          update();
        })();
      </script>
    )}
  </body>
</html>
