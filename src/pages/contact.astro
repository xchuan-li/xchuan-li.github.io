---
import Base from "../layouts/Base.astro";
---

<Base title="Contact · Xiaochuan ___">
  <h1 class="text-2xl font-medium tracking-tight mb-8">Contact</h1>

  <div class="space-y-5 max-w-prose">
    <p class="leading-relaxed">
      The best way to reach me is email. I read everything but reply slowly — if it's about a paper
      draft or a research direction, expect a thoughtful response in a few days rather than an
      immediate one.
    </p>

    <div class="border-t border-[var(--color-border)] pt-5 space-y-3 text-sm">
      <div class="flex gap-3">
        <span class="text-[var(--color-text-dim)] w-20 shrink-0">Email</span>
        <a href="mailto:hello@xiaochuan.dev" class="text-[var(--color-accent)] hover:underline">hello@xiaochuan.dev</a>
      </div>
      <div class="flex gap-3">
        <span class="text-[var(--color-text-dim)] w-20 shrink-0">GitHub</span>
        <a href="https://github.com/__" class="text-[var(--color-accent)] hover:underline">github.com/___</a>
      </div>
      <div class="flex gap-3">
        <span class="text-[var(--color-text-dim)] w-20 shrink-0">Scholar</span>
        <a href="https://scholar.google.com/" class="text-[var(--color-accent)] hover:underline">Google Scholar</a>
      </div>
      <div class="flex gap-3">
        <span class="text-[var(--color-text-dim)] w-20 shrink-0">Location</span>
        <span>Nürnberg, Germany</span>
      </div>
    </div>

    <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-md p-4 mt-6">
      <p class="text-xs uppercase tracking-wider text-[var(--color-text-dim)] font-medium mb-1.5">
        Applying for PhDs
      </p>
      <p class="text-sm leading-relaxed">
        I'm applying for PhD positions starting fall 2027, working at the intersection of causal
        inference and interpretability. If your group works on related questions — causal
        foundations of mech interp, certification, world-model approaches — I'd be glad to hear from
        you, even if I haven't formally applied.
      </p>
    </div>
  </div>
</Base>
