---
import Base from "../layouts/Base.astro";
import HeroCausalMatrix from "../components/HeroCausalMatrix.astro";
import ResearchTimeline from "../components/ResearchTimeline.astro";
import { projects } from "../data/research";
import { posts as writingPosts } from "../data/writing";

// The research section as a narrative: Leibniz's question (origin) flows into the
// program, then into a reverse-chronological timeline of projects and notes
// (ResearchTimeline).
const spineLeadIn = "Leibniz dreamed of a characteristica universalis — a language whose very structure would make valid inference mechanical, so that reasoning and its expression never came apart. Three centuries later, large language models are the first artifacts that almost embody it: systems made entirely of language that nonetheless appear to reason. My program turns that old question back on them — does a model actually use the causal structure language encodes to license an inference, or only a surface correlate of it? Each project below is one way of pinning that down.";

const spineOrigin = {
  label: "From sufficient reason to a universal language",
  href: "/writing/from-leibniz",
  hook: "Nihil est sine ratione.",
};

// Homepage timeline (below the Leibniz lead-in), transformer-circuits style: a
// single reverse-chronological stream. Both project AND note display-dates are a
// homepage-only narrative, hand-spread so projects and notes interleave (never two
// notes in a row); the real note pubDates stay on /writing, and /research stays
// date-free. Only the personal core line appears here — pure-concept directions
// (Isotrace, Typological Grounding) and the collaborative extensions (Latent Control
// States, Cross-lingual ProtoBias) are left off the homepage. Stable Is Not Grounded
// anchors the top as the flagship; Arrowhead sits last, as a verification case.
const projectDate: Record<string, string> = {
  "/research/sc-certification": "2026-06-20",
  "/research/hangl": "2026-06-01",
  "/research/mini-causal-models": "2026-05-05",
  "/research/arrowhead": "2026-03-01",
};
// Homepage display-dates for the notes, chosen to interleave them among the
// projects (their real pubDates, several clustered in late May, remain on /writing).
const noteDate: Record<string, string> = {
  "inverted-observability": "2026-06-12",
  "meaning-beneath-language": "2026-05-28",
  "causal-residue": "2026-05-12",
  "inferential-productivity": "2026-04-25",
  "decidability-boundary": "2026-04-02",
  "from-leibniz": "2026-03-10",
};
// A 2–3 sentence introduction per project, condensed from each project's own
// description in data/research.ts (no new claims) — keyed by href.
const projectIntro: Record<string, string> = {
  "/research/sc-certification":
    "A model can answer a reasoning task correctly and stably and still not be using the structure that supposedly licenses the answer — it may be riding a surface cue that correlates. This builds a non-circular test for that gap: the stipulated structure counts as load-bearing only if the model's behaviour survives audits that sever the shortcuts. It is the entry point of the whole program.",
  "/research/isotrace":
    "Certification tells you whether the structure is used, not which part of it carried the inference. Isotrace upgrades that binary verdict into a hop-level diagnosis, using minimal pairs where distinct reasoning paths are forced to produce distinct output labels. It is currently in design, on the synthetic sandbox.",
  "/research/mini-causal-models":
    "A shared workbench that compiles small natural-language fragments into explicit causal graphs, so the structure a sentence encodes becomes observable. You can pose the model a question, intervene on the underlying graph, and check whether its answer tracks the structure or a surface accident. It is the bench the other projects run on.",
  "/research/arrowhead":
    "The certification work lives on a synthetic sandbox; Arrowhead asks whether it survives inside a real model. A completed pilot on Gemma-2-2B finds a causal-direction feature that is encoded, steerable, and genuinely causal under intervention — yet redundantly distributed across the network rather than localized. It is a case where a formal claim about the model is checked against its behaviour under intervention.",
  "/research/latent-control-states":
    "Prompt framing — urgency, authority, an epistemic stance — clearly changes what a model says; this asks whether it also shifts a causally relevant latent state, or only the surface. A controlled-data pipeline is built; probing and activation patching come next. A collaboration advised by a senior researcher at DFKI.",
  "/research/hangl":
    "Korean Sino-Korean words are a natural experiment in surface versus meaning: the Hangul spelling shares zero characters with its Hanja origin yet matches it in meaning. A wrong-Hanja intervention shows latent grounding scales with capability — a strong model neither needs the cue nor is misled by it, a weak one is both. A collaborative pilot, now scaling across more models.",
  "/research/cross-lingual-protobias":
    "The applied, multimodal stress test of the core question: across languages, does a vision-language model track meaning, or lean on language- and culture-specific prototype shortcuts? It pits the two against each other, extending a forthcoming paper from an established NLP group. The current report covers two models across seven languages.",
  "/research/typological-grounding":
    "The flagship application the program builds toward. Languages encode the same inference in different devices — morphology, word order, context — and this asks whether a model's grounding survives the re-encoding, or only learned the surface habits of particular languages. Currently exploratory.",
};
// One-sentence homepage descriptions for the notes (their fuller excerpts live on
// /writing) — keyed by slug.
const noteBlurb: Record<string, string> = {
  "earned-not-handed-to": "The grounding problem in language and the identifiability problem in world models are one question — when form licenses a causal inference, not just correlates.",
  "inverted-observability": "Why developmental psychology and interpretability are the same question seen from opposite sides of a mirror.",
  "meaning-beneath-language": "When one content is carried by German morphology, English word order, and Chinese context, does a model represent the meaning — or three surface habits?",
  "causal-residue": "Every training example is a falsifier; the structure a learner ends up with is the residue of cumulative cutting.",
  "from-leibniz": "What an undergraduate thesis on Leibniz's universal character became after a change of discipline.",
  "decidability-boundary": "Past a certain depth, much of what interpretability treats as a hard measurement is in fact an undefined quantity.",
  "inferential-productivity": "Given a system's behaviour, what is the smallest causal structure that has to be there for it to land?",
};

// Which real per-project figure to show on the right (by href). Projects without
// a clean static figure fall back to their glyph for now.
const projectFig: Record<string, string> = {
  "/research/arrowhead": "arrowhead",
  "/research/hangl": "hangl",
  "/research/cross-lingual-protobias": "protobias",
  "/research/latent-control-states": "latent",
  "/research/sc-certification": "sc",
  "/research/mini-causal-models": "mcm",
};

const MONTHS = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];
const monthLabel = (iso: string) => {
  const [y, m] = iso.split("-");
  return `${MONTHS[Number(m) - 1]} ${y}`;
};

const rawEntries = [
  ...projects
    .filter((p) => projectDate[p.href])
    .map((p) => ({
      type: "project" as const,
      date: projectDate[p.href],
      href: p.href,
      name: p.title.split(" · ")[0],
      blurb: p.blurb ?? p.short ?? p.desc,
      intro: projectIntro[p.href],
      color: p.color,
      category: p.category,
      progress: p.progress,
      kind: p.kind,
      demo: p.demo,
      glyph: p.glyph,
      fig: projectFig[p.href],
    })),
  ...writingPosts.map((p) => ({
    type: "writing" as const,
    date: noteDate[p.slug] ?? p.pubDate,
    href: `/writing/${p.slug}`,
    title: p.title,
    blurb: noteBlurb[p.slug] ?? p.excerpt,
    status: p.status,
  })),
].sort((a, b) => b.date.localeCompare(a.date));

let prevLabel = "";
const entries = rawEntries.map((e) => {
  const dateLabel = monthLabel(e.date);
  const showDate = dateLabel !== prevLabel;
  prevLabel = dateLabel;
  return { ...e, dateLabel, showDate };
});

---

<Base wide={true}>
  <!-- =========== HERO =========== -->
  <section class="hero">
    <div class="hero-inner hero-grid">
      <div class="hero-content">
        <p class="hero-tagline fade-in">Master's student · Human and AI · UTN Nürnberg</p>
        <h1 class="hero-heading fade-in-up">
          <span>Hi, I am</span>
          <span class="line-2">Xiaochuan Li.</span>
        </h1>
        <div class="hero-bio fade-in-up fade-delay-200">
          <p>
            I study when an AI model actually <strong>uses the structure that licenses an
            inference</strong> — what entails what, which event is the cause — rather than riding
            a surface correlate of it. My approach is <em>formal characterization plus
            controlled verification</em>: I specify the structure that should license an answer
            in advance — by grammar, by formal rule, or by construction — then test whether the
            model actually depends on it under intervention. This draws on formal language theory,
            formal semantics, and my background in philosophy and typology, rather than on
            large-scale circuit discovery.
            Language is where I test this most directly; the same question is beginning to
            extend to world models.
          </p>
          <p>
            After an undergraduate Philosophy thesis on Leibniz's <em>characteristica universalis</em>,
            I'm now in the M.Sc. in <strong>Human and AI</strong> at UTN. Philosophy left me caring
            about what actually makes an answer follow; reading across Chinese, German, and English —
            Japanese underway — left me attentive to how grammar makes an inference visible in one
            language and implicit in another.
          </p>
          <p>
            I'm preparing PhD applications for fall 2027 to take this further.
          </p>
        </div>
        <blockquote class="hero-pull fade-in-up fade-delay-300">
          Language gives reasoning its shape. Models tell us whether they learned the shape or only the shadow.
        </blockquote>
        <div class="hero-cta fade-in-up fade-delay-300">
          <a href="#research" class="btn btn-primary">
            View research
            <span class="btn-arrow">↓</span>
          </a>
          <a href="#contact" class="btn btn-secondary">Get in touch</a>
        </div>
        <div class="hero-social fade-in-up fade-delay-400">
          <span class="hero-social-label">Reach me</span>
          <a class="hero-social-link" href="mailto:xiaochuan.li@utn.de" aria-label="Email">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="5" width="18" height="14" rx="2"></rect>
              <path d="M3 7l9 6 9-6"></path>
            </svg>
          </a>
          <a class="hero-social-link" href="https://github.com/xchuan-li" aria-label="GitHub" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
            </svg>
          </a>
          <a class="hero-social-link" href="https://www.linkedin.com/in/xiaochuan-li-0488533b5/" aria-label="LinkedIn" rel="noopener" target="_blank">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z" />
            </svg>
          </a>
          <a class="hero-social-link" href="/cv.pdf" aria-label="Download CV (PDF)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
              <path d="M14 2v6h6" />
              <path d="M12 18v-6" />
              <path d="M9 15l3 3 3-3" />
            </svg>
          </a>
        </div>
      </div>

      <div class="hero-figure-col fade-in fade-delay-300" aria-hidden="false">
        <HeroCausalMatrix />
      </div>
    </div>

  </section>

  <!-- =========== RESEARCH =========== -->
  <section id="research" class="section">
    <div class="section-inner">
      <div class="divider-line"></div>
      <div class="section-head">
        <p class="section-label fade-in-up">Research</p>
        <h2 class="section-heading section-question fade-in-up fade-delay-100">
          Does a model use the causal structure that language encodes — or only its surface?
        </h2>
      </div>
      <div class="fade-in-up fade-delay-200">
        <ResearchTimeline
          origin={spineOrigin}
          leadIn={spineLeadIn}
          entries={entries}
        />
      </div>
    </div>
  </section>


  <!-- =========== CONTACT CTA =========== -->
  <section id="contact" class="section" style="padding-bottom: 7rem;">
    <div class="section-inner">
      <div class="divider-line"></div>
      <div class="contact-cta fade-in-up">
        <div>
          <h2 class="contact-cta-head">Let's talk.</h2>
          <p class="contact-cta-sub">
            Best by email — I read everything and reply slowly. If it's about a paper draft or a
            research direction, expect a thoughtful response in a few days rather than an immediate
            one.
          </p>
        </div>
        <div class="hero-cta" style="margin: 0;">
          <a class="btn btn-primary" href="mailto:xiaochuan.li@utn.de">
            Email me
            <span class="btn-arrow">↗</span>
          </a>
          <a class="btn btn-secondary" href="/contact">More ways</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  /* The research heading is now the core research question itself — keep it
     readable at a slightly smaller, tighter size than a normal section heading. */
  .section-question {
    max-width: 24ch;
    font-size: clamp(1.55rem, 1.1rem + 1.7vw, 2.4rem);
    line-height: 1.2;
  }
</style>
