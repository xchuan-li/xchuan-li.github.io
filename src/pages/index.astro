---
import Base from "../layouts/Base.astro";
import HeroModality from "../components/HeroModality.astro";
import ResearchTimeline from "../components/ResearchTimeline.astro";
import { projects } from "../data/research";
import { posts as writingPosts } from "../data/writing";

// The research section as a narrative: Leibniz's question (origin) flows into the
// program, then into a reverse-chronological timeline of projects and notes
// (ResearchTimeline).
const spineLeadIn = "Leibniz made modality structure: what is necessary holds in all possible worlds, what is possible in some. Kripke turned that into mathematics, Kratzer connected it to the modal words of natural language, and Leahy & Carey made possession-versus-performance an experimental question. That lineage gives a theory of what modal force is — and a theory of meaning, if true, has to leave an observable trace. So I derive one set of predictions from it and read them off in two systems at once: the human mind, where meaning is already real, and a language model, which I can open up and intervene on. Modality is where I build depth; the same method runs on to conditionals, counterfactuals, and quantifiers.";

const spineOrigin = {
  label: "From possible worlds to language models",
  href: "/motivation",
  hook: "Nihil est sine ratione.",
};

// Homepage timeline (below the Leibniz lead-in), transformer-circuits style: a
// single reverse-chronological stream. Both project AND note display-dates are a
// homepage-only narrative, hand-spread so projects and notes interleave (never two
// notes in a row); the real note pubDates stay on /writing, and /research stays
// date-free. The homepage timeline is modality-only: MODUS (the thesis — its
// language-model arm runs a pilot now) anchors the top, and the human arm is
// folded into the MODUS intro plus the milestone (no card without results). The
// earlier/methodological collaborations (Latent Control States, Cross-lingual
// ProtoBias) are kept on /research but left off the homepage timeline.
//
// Notes are filtered the same way: only the three squarely on the program's line
// appear here (from-leibniz = the stage-I origin; meaning-beneath-language = the
// Kratzer/typology stage in prose; inverted-observability = the Leahy & Carey
// verdict layer). Everything else lives on /writing only.
const mainlineNotes = new Set(["from-leibniz", "meaning-beneath-language", "inverted-observability"]);
const projectDate: Record<string, string> = {
  "/research/modus": "2026-07-08",
};
// Homepage display-dates for the notes, chosen to interleave them among the
// projects (their real pubDates, several clustered in late May, remain on /writing).
const noteDate: Record<string, string> = {
  "inverted-observability": "2026-06-12",
  "meaning-beneath-language": "2026-05-28",
  "from-leibniz": "2026-03-10",
};
// A 2–3 sentence introduction per project, condensed from each project's own
// description in data/research.ts (no new claims) — keyed by href.
const projectIntro: Record<string, string> = {
  "/research/modus":
    "My Master's thesis. Is modal force a quantification over a set of possible worlds (Kratzer), or a single degree of certainty (Lassiter)? Judgment data cannot separate the two; a system's representational format under intervention can. The thesis derives one set of predictions from that question and reads them in two systems: a language model I can open up and intervene on, and — through a shared behavioural paradigm now in planning — the human mind. The model arm's pilot already shows the force direction is load-bearing: ablate it on a might sentence and its certainty jumps toward must (+0.15), while a base-rate control does nothing. The format test, a graded epistemic-force dataset, and the human counterpart come next.",
};
// One-sentence homepage descriptions for the notes (their fuller excerpts live on
// /writing) — keyed by slug.
const noteBlurb: Record<string, string> = {
  "inverted-observability": "Why developmental psychology and interpretability are the same question seen from opposite sides of a mirror.",
  "meaning-beneath-language": "When one content is carried by German morphology, English word order, and Chinese context, does a model represent the meaning, or three surface habits?",
  "from-leibniz": "What an undergraduate thesis on Leibniz's universal character became after a change of discipline.",
};

// Which real per-project figure to show on the right (by href). Projects without
// a clean static figure fall back to their glyph for now.
const projectFig: Record<string, string> = {
  "/research/modus": "modus",
};

const MONTHS = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];
const monthLabel = (iso: string) => {
  const [y, m] = iso.split("-");
  return `${MONTHS[Number(m) - 1]} ${y}`;
};

// The thesis has no card (no results yet — program rule); it enters the stream as
// a milestone note, dated to the day the program statement went up.
const milestones = [
  {
    type: "milestone" as const,
    date: "2026-07-02",
    text: "The program settles on its spine: the experimental and computational semantics of modal reasoning. The Master's thesis at UTN, MODUS, takes shape as one modal theory tested in two systems — the language model (a pilot already running) and, through a shared paradigm now in planning, the human mind.",
  },
];

// Display names for the timeline: codename plus a plain-language phenomenon, so a
// title reads at a glance. Keyed by href; falls back to the bare title otherwise.
const caseGloss: Record<string, string> = {
  "/research/modus": "MODUS: Modal force",
};

const rawEntries = [
  ...milestones,
  ...projects
    .filter((p) => projectDate[p.href])
    .map((p) => ({
      type: "project" as const,
      date: projectDate[p.href],
      href: p.href,
      name: caseGloss[p.href] ?? p.title.split(" · ")[0],
      blurb: p.blurb ?? p.short ?? p.desc,
      intro: projectIntro[p.href],
      color: p.color,
      category: p.category,
      progress: p.progress,
      kind: p.kind,
      demo: p.demo,
      glyph: p.glyph,
      fig: projectFig[p.href],
    })),
  ...writingPosts.filter((p) => mainlineNotes.has(p.slug)).map((p) => ({
    type: "writing" as const,
    date: noteDate[p.slug] ?? p.pubDate,
    href: `/writing/${p.slug}`,
    title: p.title,
    blurb: noteBlurb[p.slug] ?? p.excerpt,
    status: p.status,
  })),
].sort((a, b) => b.date.localeCompare(a.date));

let prevLabel = "";
const entries = rawEntries.map((e) => {
  const dateLabel = monthLabel(e.date);
  const showDate = dateLabel !== prevLabel;
  prevLabel = dateLabel;
  return { ...e, dateLabel, showDate };
});

---

<Base wide={true}>
  <!-- =========== HERO =========== -->
  <section class="hero">
    <div class="hero-inner">
      <a class="hero-imprint fade-in" href="/motivation"><span class="hero-imprint-q">Is the logic of natural language the logic of the logicians?</span><span class="hero-imprint-arrow" aria-hidden="true"> →</span></a>
      <div class="hero-grid">
      <div class="hero-content">
        <p class="hero-tagline fade-in fade-delay-100">Master's student · Human and AI · UTN Nürnberg</p>
        <h1 class="hero-heading fade-in-up fade-delay-200">
          <span>Hi, I am</span>
          <span class="line-2">Xiaochuan Li.</span>
        </h1>
        <div class="hero-bio fade-in-up fade-delay-200">
          <p>
            That question sits underneath my work, and my way into it is one kind of word: the
            <strong>modal</strong>. I study <strong>how linguistic modality — may, must, might —
            structures the space of possibilities we reason over.</strong> Formal semantics gives a
            precise theory of what modal force is, and a theory of meaning, if it is true, has to
            leave an observable trace.
          </p>
          <p>
            So I derive one set of predictions from that theory and read them off in <strong>two
            systems at once</strong>: the <strong>human mind</strong>, where meaning is already real,
            and a <strong>language model</strong> I can open up and intervene on. Where they agree,
            and where the model departs from the mind, both constrain the theory. Modality is where I
            build depth; the same method runs on to conditionals, counterfactuals, and quantifiers.
          </p>
          <p>
            I'm applying for PhD positions for fall 2027.
          </p>
        </div>
        <div class="hero-cta fade-in-up fade-delay-300">
          <a href="#research" class="btn btn-primary">
            View research
            <span class="btn-arrow">↓</span>
          </a>
          <a href="#contact" class="btn btn-secondary">Get in touch</a>
        </div>
        <div class="hero-social fade-in-up fade-delay-400">
          <span class="hero-social-label">Reach me</span>
          <a class="hero-social-link" href="mailto:xiaochuan.li@utn.de" aria-label="Email">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="5" width="18" height="14" rx="2"></rect>
              <path d="M3 7l9 6 9-6"></path>
            </svg>
          </a>
          <a class="hero-social-link" href="https://github.com/xchuan-li" aria-label="GitHub" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
            </svg>
          </a>
          <a class="hero-social-link" href="https://www.linkedin.com/in/xiaochuan-li-0488533b5/" aria-label="LinkedIn" rel="noopener" target="_blank">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z" />
            </svg>
          </a>
          <a class="hero-social-link" href="/cv.pdf" aria-label="Download CV (PDF)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
              <path d="M14 2v6h6" />
              <path d="M12 18v-6" />
              <path d="M9 15l3 3 3-3" />
            </svg>
          </a>
        </div>
      </div>

      <div class="hero-figure-col fade-in fade-delay-300" aria-hidden="false">
        <HeroModality />
      </div>
      </div>
    </div>

  </section>

  <!-- =========== RESEARCH =========== -->
  <section id="research" class="section">
    <div class="section-inner">
      <div class="divider-line"></div>
      <div class="section-head">
        <p class="section-label fade-in-up">The research program</p>
        <h2 class="section-heading section-question fade-in-up fade-delay-100">
          One theory of modality, two systems that answer it.
        </h2>
      </div>
      <div class="fade-in-up fade-delay-200">
        <ResearchTimeline
          origin={spineOrigin}
          leadIn={spineLeadIn}
          entries={entries}
        />
      </div>
    </div>
  </section>


  <!-- =========== COLLABORATIONS =========== -->
  <section class="section">
    <div class="section-inner">
      <div class="divider-line"></div>
      <div class="section-head">
        <p class="section-label fade-in-up">Alongside</p>
        <h2 class="section-heading fade-in-up fade-delay-100">Earlier &amp; methodological work</h2>
      </div>
      <div class="hp-collab fade-in-up fade-delay-200">
        <p class="hp-collab-lead">
          The engineering the modality program runs on came from two collaborations — where I learned
          to build controlled evaluations, intervene inside a model, and analyse the results. They are
          my methodological training, not the identity.
        </p>
        <p>
          <strong>Latent Control States</strong><span class="hp-collab-org"> · DFKI</span><br />
          Mechanistic interpretation. Does prompt framing shift a causally relevant latent state, or
          only the output? My contribution: a utilitarian minimal-pair probe — dilemma × benefit-size ×
          framing — testing whether the choice tracks the real stakes or only surface pressure.
        </p>
        <p>
          <strong>Cross-lingual ProtoBias</strong><span class="hp-collab-org"> · an established NLP group</span><br />
          Multilingual model evaluation. Does a vision-language model track meaning, or culture-specific
          prototype shortcuts? My contribution: the cross-lingual evaluation across seven languages that
          extends the group's forthcoming paper.
        </p>
      </div>
    </div>
  </section>


  <!-- =========== CONTACT CTA =========== -->
  <section id="contact" class="section" style="padding-bottom: 7rem;">
    <div class="section-inner">
      <div class="divider-line"></div>
      <div class="contact-cta fade-in-up">
        <div>
          <h2 class="contact-cta-head">Let's talk.</h2>
          <p class="contact-cta-sub">
            Best by email. I read everything and reply slowly. If it's about a paper draft or a
            research direction, expect a thoughtful response in a few days rather than an immediate
            one.
          </p>
        </div>
        <div class="hero-cta" style="margin: 0;">
          <a class="btn btn-primary" href="mailto:xiaochuan.li@utn.de">
            Email me
            <span class="btn-arrow">↗</span>
          </a>
          <a class="btn btn-secondary" href="/contact">More ways</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  /* The research heading is now the core research question itself — keep it
     readable at a slightly smaller, tighter size than a normal section heading. */
  /* The site's imprint: the one question the whole program hangs from. It opens
     the page and links to the Motivation essay. */
  .hero-imprint {
    display: block;
    white-space: nowrap;
    font-family: var(--font-display, serif);
    font-size: clamp(1.1rem, 2.4vw, 1.7rem);
    line-height: 1.35;
    font-style: italic;
    color: var(--color-text);
    text-decoration: none;
    margin: 0 0 2.2rem;
    padding-left: 1rem;
    border-left: 2px solid var(--color-accent);
  }
  @media (max-width: 640px) {
    .hero-imprint { white-space: normal; font-size: 1.15rem; }
  }
  .hero-imprint-q { transition: color 0.2s ease; }
  .hero-imprint-arrow { font-style: normal; color: var(--color-text-dim); transition: color 0.2s ease; }
  .hero-imprint:hover .hero-imprint-q,
  .hero-imprint:hover .hero-imprint-arrow { color: var(--color-accent); }

  .section-question {
    max-width: 24ch;
    font-size: clamp(1.55rem, 1.1rem + 1.7vw, 2.4rem);
    line-height: 1.2;
  }

  /* Collaborations: plain two-line credits, no figures. */
  .hp-collab { max-width: 44rem; }
  .hp-collab > p {
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0 0 1.3rem;
  }
  .hp-collab > p:last-child { margin-bottom: 0; }
  .hp-collab > p strong { color: var(--color-text); font-weight: 600; }
  .hp-collab-lead { font-style: italic; margin-bottom: 1.8rem !important; }
  .hp-collab-org {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-text-dim);
  }
</style>
