---
import Base from "../layouts/Base.astro";
import ProjectCover from "../components/ProjectCover.astro";
import SCHierarchyFigure from "../components/SCHierarchyFigure.astro";
import ResearchSpine from "../components/TrajectoryTimeline.astro";

const researchSpine = [
  {
    kind: "idea",
    label: "Leibniz's question",
    href: "/writing/from-leibniz",
  },
  {
    // Single project node; the motivating idea sits stacked above it.
    kind: "paper",
    n: "01",
    title: "Stable Is Not Grounded",
    color: "var(--accent-coral)",
    href: "/research/sc-certification",
    ideas: [{ label: "Is stability enough?", href: "/writing/decidability-boundary" }],
  },
  {
    kind: "paper",
    n: "02",
    title: "Isotrace",
    color: "var(--accent-teal)",
    href: "/research/isotrace",
  },
  {
    // Sandbox on the main axis, with one inspiring idea above and one below.
    kind: "sandbox",
    n: "Sandbox",
    title: "Mini Causal Models",
    color: "var(--accent-slate)",
    href: "/research/mini-causal-models",
    ideas: [
      { label: "Minimum licensing structure", href: "/writing/inferential-productivity" },
    ],
    ideasBelow: [
      { label: "Causal residue", href: "/writing/causal-residue" },
    ],
  },
  {
    kind: "paper",
    n: "03",
    title: "Causal Inferential Yield",
    color: "var(--accent-purple)",
    href: "/research/ciy",
    capstone: true,
  },
];

// Two completed side studies that branch off before CIY and feed into the thesis.
// Latent branches from before 02 (Isotrace); Cross branches from after 02.
const researchExtensions = [
  {
    kicker: "Mechanistic bridge",
    title: "Latent Control States",
    desc: "Do behavioral control states correspond to activation-space states or directions?",
    href: "/research/latent-control-states",
    color: "var(--accent-amber)",
    anchor: 1.5, // before Isotrace (index 2)
  },
  {
    kicker: "Applied stress test",
    title: "Cross-lingual ProtoBias",
    desc: "Semantic content versus language- and culture-specific prototype shortcuts.",
    href: "/research/cross-lingual-protobias",
    color: "var(--accent-indigo)",
    anchor: 2.5, // after Isotrace (index 2), before sandbox (index 3)
  },
];

const projects = [
  {
    n: "01",
    title: "Stable Is Not Grounded",
    href: "/research/sc-certification",
    color: "var(--accent-coral)",
    tint: "rgba(240, 153, 123, 0.10)",
    glyph: "sc",
    tags: ["Paper 1", "Binary certification"],
    desc: "Tests whether the licensing structure is counterfactually load-bearing at all: stable-correct behavior is not counted as grounded unless the stipulated structure survives shortcut-severing audits.",
    group: "core",
  },
  {
    n: "02",
    title: "Isotrace",
    href: "/research/isotrace",
    color: "var(--accent-teal)",
    tint: "rgba(93, 202, 165, 0.10)",
    glyph: "isotrace",
    tags: ["Paper 2", "Path localization"],
    desc: "A behavioral path-tracing protocol that makes distinct hypothesized reasoning paths produce distinct observable labels, locating which hop was used, bypassed, or shortcut-replaced.",
    group: "core",
  },
  {
    n: "03",
    title: "Causal Inferential Yield",
    href: "/research/ciy",
    color: "var(--accent-purple)",
    tint: "rgba(175, 169, 236, 0.10)",
    glyph: "ciy",
    tags: ["Paper 3", "Quantification"],
    desc: "Grades how much causal structure the model reliably extracts, defined on certified or controlled items rather than arbitrary benchmark accuracy.",
    group: "core",
  },
  {
    n: "S",
    title: "Mini Causal Models",
    href: "/research/mini-causal-models",
    color: "var(--accent-slate)",
    tint: "rgba(116, 180, 206, 0.10)",
    glyph: "mcm",
    tags: ["Sandbox", "On the spine"],
    desc: "A controlled planted-ground-truth environment — inspired by the minimum-licensing and causal-residue notes — for testing causal-structure recovery, Isotrace-style localization, and CIY-style grading against a known target before the thesis trusts them.",
    group: "support",
  },
  {
    n: "E1",
    title: "Latent Control States",
    href: "/research/latent-control-states",
    color: "var(--accent-amber)",
    tint: "rgba(239, 159, 39, 0.10)",
    glyph: "latent",
    tags: ["Side study", "Mechanistic"],
    desc: "Asks whether behavioral causal control states have corresponding states or directions in activation space, without making mechanism the main thesis spine.",
    group: "extension",
  },
  {
    n: "E2",
    title: "Cross-lingual ProtoBias",
    href: "/research/cross-lingual-protobias",
    color: "var(--accent-indigo)",
    tint: "rgba(123, 155, 209, 0.10)",
    glyph: "protobias",
    tags: ["Side study", "Applied stress test"],
    desc: "Applies the same semantic-versus-shortcut ambiguity to multilingual and multimodal evaluation: semantic content or language- and culture-specific prototype shortcuts?",
    group: "extension",
  },
];

const programSections = [
  {
    label: "Core sequence",
    title: "Hierarchical Causal Evidence",
    desc: "The main spine moves from binary certification, to hop-level localization, to quantitative grading of causal structure use — converging on the thesis result, Causal Inferential Yield.",
    projects: projects.filter((p) => p.group === "core"),
  },
  {
    label: "On the spine",
    title: "Planted-structure sandbox",
    desc: "Mini Causal Models sit on the main spine between Isotrace and CIY: a known-target environment, inspired by the minimum-licensing and causal-residue notes, where recovery and grading are tested before the thesis trusts them.",
    projects: projects.filter((p) => p.group === "support"),
  },
  {
    label: "Side studies",
    title: "Feeding the thesis",
    desc: "Two studies that branch off before the thesis and feed into it — one a mechanistic bridge into activation space, the other an applied multilingual/multimodal stress test.",
    projects: projects.filter((p) => p.group === "extension"),
  },
];

const now = [
  {
    label: "Primary",
    text: "Writing Stable Is Not Grounded as a workshop-targeted paper on why stability is not sufficient for grounding.",
  },
  {
    label: "Next",
    text: "Designing Isotrace, a behavioral path-tracing method that upgrades binary grounding certification into hop-level diagnosis.",
  },
  {
    label: "Side studies",
    text: "Folding Latent Control States and Cross-lingual ProtoBias — a mechanistic bridge and an applied multilingual/multimodal stress test — back into the thesis as supporting evidence.",
  },
];

const posts = [
  {
    slug: "causal-residue",
    title: "Causal structure as residue — training as elimination",
    meta: "Note · May 2026",
  },
  {
    slug: "from-leibniz",
    title: "From Leibniz to do(class-3) — what philosophy gave me that ML didn't",
    meta: "Note · May 2026",
  },
  {
    slug: "decidability-boundary",
    title: "Why interpretability needs a decidability boundary",
    meta: "Draft · May 2026",
  },
  {
    slug: "inferential-productivity",
    title: "Reasoning is generative; grounding needs the other direction",
    meta: "Note · May 2026",
  },
];

const areas = [
  { label: "Binary certification", status: "Paper 1", color: "var(--accent-coral)" },
  { label: "Behavioral path tracing", status: "Paper 2", color: "var(--accent-teal)" },
  { label: "Causal structure grading", status: "Paper 3", color: "var(--accent-purple)" },
  { label: "Planted-structure sandbox", status: "On the spine", color: "var(--accent-slate)" },
  { label: "Mechanistic / applied tests", status: "Side studies", color: "var(--accent-amber)" },
  { label: "Philosophy of inference", status: "Background", color: "var(--accent-deep-purple)" },
];
---

<Base wide={true}>
  <!-- =========== HERO =========== -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <svg viewBox="0 0 1200 800" preserveAspectRatio="xMidYMid slice">
        <defs>
          <filter id="hb-glow" x="-50%" y="-50%" width="200%" height="200%">
            <feGaussianBlur stdDeviation="1.6" result="b" />
            <feMerge>
              <feMergeNode in="b" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>
        </defs>

        <g class="hb-edges" stroke="currentColor" stroke-opacity="0.10" fill="none" stroke-width="1">
          <path d="M 780 120 L 940 200" />
          <path d="M 940 200 L 1080 160" />
          <path d="M 940 200 L 1020 320" />
          <path d="M 780 120 L 700 280" />
          <path d="M 700 280 L 840 360" />
          <path d="M 840 360 L 1020 320" />
          <path d="M 1020 320 L 1100 460" />
          <path d="M 840 360 L 920 520" />
          <path d="M 920 520 L 1100 460" />
          <path d="M 700 280 L 620 460" />
          <path d="M 620 460 L 920 520" />
        </g>

        <!-- invisible multi-edge routes traced by the two drifting signals -->
        <path id="hb-route-a" d="M 780 120 L 940 200 L 1020 320 L 1100 460" fill="none" stroke="none" />
        <path id="hb-route-b" d="M 780 120 L 700 280 L 840 360 L 920 520" fill="none" stroke="none" />

        <g fill="currentColor" fill-opacity="0.20">
          <circle cx="780" cy="120" r="2.6" />
          <circle cx="940" cy="200" r="3.2" />
          <circle cx="1080" cy="160" r="2.4" />
          <circle cx="700" cy="280" r="2.6" />
          <circle cx="1020" cy="320" r="2.8" />
          <circle cx="840" cy="360" r="3.0" />
          <circle cx="1100" cy="460" r="2.4" />
          <circle cx="620" cy="460" r="2.6" />
          <circle cx="920" cy="520" r="2.8" />
        </g>
        <circle cx="940" cy="200" r="6.5" fill="var(--color-accent)" fill-opacity="0.55" />

        <g class="hb-particles" filter="url(#hb-glow)" fill="var(--color-accent)">
          <circle r="2" opacity="0">
            <animateMotion dur="9s" begin="0s" repeatCount="indefinite">
              <mpath href="#hb-route-a" />
            </animateMotion>
            <animate attributeName="opacity" dur="9s" begin="0s" repeatCount="indefinite"
                     values="0;1;1;0" keyTimes="0;0.12;0.85;1" />
          </circle>
          <circle r="2" opacity="0">
            <animateMotion dur="11s" begin="4.5s" repeatCount="indefinite">
              <mpath href="#hb-route-b" />
            </animateMotion>
            <animate attributeName="opacity" dur="11s" begin="4.5s" repeatCount="indefinite"
                     values="0;1;1;0" keyTimes="0;0.12;0.85;1" />
          </circle>
        </g>
      </svg>
    </div>

    <div class="hero-inner">
      <div class="hero-content">
        <p class="hero-tagline fade-in">Master's student · Human and AI · UTN Nürnberg</p>
        <h1 class="hero-heading fade-in-up">
          <span>Hi, I am</span>
          <span class="line-2">Xiaochuan Li.</span>
        </h1>
        <p class="hero-desc fade-in-up fade-delay-200">
          I study when a model's stable behavior is actually licensed by the causal structure we
          think it is using. My work asks when model behavior can be causally reduced to the minimum
          structure that licenses it.
        </p>
        <blockquote class="hero-pull fade-in-up fade-delay-300">
          Stability is necessary but not sufficient for grounding.
        </blockquote>
        <div class="hero-cta fade-in-up fade-delay-300">
          <a href="#research" class="btn btn-primary">
            View research
            <span class="btn-arrow">↓</span>
          </a>
          <a href="#contact" class="btn btn-secondary">Get in touch</a>
        </div>
        <div class="hero-social fade-in-up fade-delay-400">
          <span class="hero-social-label">Reach me</span>
          <a class="hero-social-link" href="mailto:xiaochuan.li@utn.de" aria-label="Email">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="5" width="18" height="14" rx="2"></rect>
              <path d="M3 7l9 6 9-6"></path>
            </svg>
          </a>
          <a class="hero-social-link" href="https://github.com/xchuan-li" aria-label="GitHub" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
            </svg>
          </a>
          <a class="hero-social-link" href="https://www.linkedin.com/in/xiaochuan-li-0488533b5/" aria-label="LinkedIn" rel="noopener" target="_blank">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z" />
            </svg>
          </a>
          <a class="hero-social-link" href="/cv.pdf" aria-label="Download CV (PDF)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
              <path d="M14 2v6h6" />
              <path d="M12 18v-6" />
              <path d="M9 15l3 3 3-3" />
            </svg>
          </a>
        </div>
      </div>
    </div>

    <a href="#about" class="scroll-indicator" aria-label="Scroll to about">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </a>
  </section>

  <!-- =========== ABOUT =========== -->
  <section id="about" class="section">
    <div class="section-inner">
      <div class="divider-line"></div>
      <div class="about-grid">
        <div class="about-fig fade-in-up">
          <SCHierarchyFigure />
        </div>

        <div>
          <p class="section-label fade-in-up">About</p>
          <h2 class="section-heading fade-in-up fade-delay-100">
            One question, traced backward.
          </h2>
          <div class="about-bio fade-in-up fade-delay-200">
            <p>
              I read undergraduate Philosophy at <strong>Shenzhen University</strong>, finishing a
              senior thesis on Leibniz's <em>characteristica universalis</em> — about which
              structures are minimally licensed by which behaviors. That question quietly survived
              the move into machine learning.
            </p>
            <p>
              I'm currently in the M.Sc. in <strong>Human and AI</strong> at the University of
              Technology Nuremberg (UTN), and I work on the same question with different tools:
              when a model's stable-correct behavior looks justified, was the minimum licensing
              structure actually load-bearing — or was something correlated with the answer doing
              the work?
            </p>
            <p>
              I'm preparing PhD applications for fall 2027 on causal foundations of interpretability.
            </p>
          </div>

          <div class="areas-card fade-in-up fade-delay-300">
            <h3 class="areas-card-title">Research focus</h3>
            {
              areas.map((a) => (
                <div class="areas-row">
                  <div class="areas-row-top">
                    <span class="areas-label">{a.label}</span>
                    <span class="areas-status">{a.status}</span>
                  </div>
                  <div class="areas-line" style={`--areas-color: ${a.color}`}></div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- =========== TRAJECTORY =========== -->
  <section id="trajectory" class="section">
    <div class="section-inner">
      <div class="divider-line"></div>
      <div class="section-head">
        <p class="section-label fade-in-up">Trajectory</p>
        <h2 class="section-heading fade-in-up fade-delay-100">From idea to experiment.</h2>
        <p class="section-sub fade-in-up fade-delay-200">
          One question — when is a model's behavior licensed by the structure we think it has? —
          traced from a first philosophical prompt, through ideas that each land as a paper and a
          planted-structure sandbox, with two completed side studies converging on the thesis result.
          Open marks are ideas; filled nodes are the projects that implement them.
        </p>
      </div>
      <div class="fade-in-up fade-delay-300">
        <ResearchSpine spine={researchSpine} extensions={researchExtensions} />
      </div>
    </div>
  </section>

  <!-- =========== CURRENTLY =========== -->
  <section id="currently" class="section">
    <div class="section-inner">
      <div class="divider-line"></div>
      <div class="section-head">
        <p class="section-label fade-in-up">Currently</p>
        <h2 class="section-heading fade-in-up fade-delay-100">What I'm working on now.</h2>
      </div>
      <ul class="now-list fade-in-up fade-delay-200">
        {
          now.map((item) => (
            <li>
              <strong>{item.label}:</strong> {item.text}
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- =========== RESEARCH GRID =========== -->
  <section id="research" class="section">
    <div class="section-inner">
      <div class="divider-line"></div>
      <div class="section-head">
        <p class="section-label fade-in-up">Research</p>
        <h2 class="section-heading fade-in-up fade-delay-100">One spine, converging on a thesis.</h2>
        <p class="section-sub fade-in-up fade-delay-200">
          When can a model's behavior be reduced to the minimum causal structure that should support
          it? The roadmap is a core sequence in hierarchical causal evidence — with a planted-structure
          sandbox on the spine and two side studies feeding in — all converging on the thesis result.
        </p>
      </div>

      <div class="space-y-14">
        {
          programSections.map((section, si) => (
            <div class={`fade-in-up fade-delay-${(si % 3) * 100 + 100}`}>
              <div class="mb-5 max-w-2xl">
                <p class="text-[11px] uppercase tracking-[0.22em] text-[var(--color-text-dim)] font-medium mb-2">
                  {section.label}
                </p>
                <h3 class="text-xl font-medium tracking-tight mb-2">{section.title}</h3>
                <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{section.desc}</p>
              </div>
              <div class="proj-grid">
                {
                  section.projects.map((p, i) => (
                    <a
                      href={p.href}
                      class={`proj-grid-card fade-in-up fade-delay-${(i % 3) * 100 + 100}`}
                      style={`--proj-color: ${p.color}; --proj-tint: ${p.tint};`}
                    >
                      <div class="proj-grid-visual">
                        <ProjectCover kind={p.glyph} color={p.color} />
                        <div class="proj-grid-overlay">
                          <span>View project →</span>
                        </div>
                      </div>
                      <div class="proj-grid-body">
                        <div class="proj-grid-tags">
                          <span>{p.n}</span>
                          <span class="sep">·</span>
                          {p.tags.map((t, ti) => (
                            <>
                              <span>{t}</span>
                              {ti < p.tags.length - 1 && <span class="sep">·</span>}
                            </>
                          ))}
                        </div>
                        <h3 class="proj-grid-title">{p.title}</h3>
                        <p class="proj-grid-desc">{p.desc}</p>
                      </div>
                    </a>
                  ))
                }
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- =========== WRITING =========== -->
  <section id="writing" class="section">
    <div class="section-inner">
      <div class="divider-line"></div>
      <div class="section-head">
        <p class="section-label fade-in-up">Writing</p>
        <h2 class="section-heading fade-in-up fade-delay-100">Notes &amp; essays.</h2>
        <p class="section-sub fade-in-up fade-delay-200">
          Short pieces that sit upstream of the experiments — what the right question is, why the
          standard fix is one level too shallow, what philosophy gave me that ML didn't.
        </p>
      </div>
      <div class="writing-list fade-in-up fade-delay-300">
        {
          posts.map((p) => (
            <a href={`/writing/${p.slug}`} class="writing-row">
              <span class="writing-title">{p.title}</span>
              <span class="writing-meta">{p.meta}</span>
            </a>
          ))
        }
      </div>
      <div class="fade-in-up fade-delay-400" style="margin-top: 1.75rem;">
        <a href="/writing" class="btn btn-secondary">All writing →</a>
      </div>
    </div>
  </section>

  <!-- =========== CONTACT CTA =========== -->
  <section id="contact" class="section" style="padding-bottom: 7rem;">
    <div class="section-inner">
      <div class="divider-line"></div>
      <div class="contact-cta fade-in-up">
        <div>
          <h2 class="contact-cta-head">Let's talk.</h2>
          <p class="contact-cta-sub">
            Best by email — I read everything and reply slowly. If it's about a paper draft or a
            research direction, expect a thoughtful response in a few days rather than an immediate
            one.
          </p>
        </div>
        <div class="hero-cta" style="margin: 0;">
          <a class="btn btn-primary" href="mailto:xiaochuan.li@utn.de">
            Email me
            <span class="btn-arrow">↗</span>
          </a>
          <a class="btn btn-secondary" href="/contact">More ways</a>
        </div>
      </div>
    </div>
  </section>
</Base>
