---
import Base from "../layouts/Base.astro";
import HeroCausalMatrix from "../components/HeroCausalMatrix.astro";
import MainlineScrolly from "../components/MainlineScrolly.astro";
import ProjectGlyph from "../components/ProjectGlyph.astro";
import { now } from "../data/research";

const posts = [
  {
    slug: "meaning-beneath-language",
    title: "Is there meaning beneath the language?",
    meta: "Note · June 2026",
  },
  {
    slug: "causal-residue",
    title: "Causal structure as residue — training as elimination",
    meta: "Note · May 2026",
  },
  {
    slug: "from-leibniz",
    title: "From a Sufficient Reason to a Universal Language — what philosophy gave me that ML didn't",
    meta: "Note · May 2026",
  },
  {
    slug: "decidability-boundary",
    title: "Why interpretability needs a decidability boundary",
    meta: "Draft · May 2026",
  },
  {
    slug: "inferential-productivity",
    title: "Reasoning is generative; grounding needs the other direction",
    meta: "Note · May 2026",
  },
];

---

<Base wide={true}>
  <!-- =========== HERO =========== -->
  <section class="hero">
    <div class="hero-inner hero-grid">
      <div class="hero-content">
        <p class="hero-tagline fade-in">Master's student · Human and AI · UTN Nürnberg</p>
        <h1 class="hero-heading fade-in-up">
          <span>Hi, I am</span>
          <span class="line-2">Xiaochuan Li.</span>
        </h1>
        <div class="hero-bio fade-in-up fade-delay-200">
          <p>
            I study <strong>how linguistic structure scaffolds reasoning in humans and AI</strong>.
            My current work turns that question into causal tests: whether a model's stable, correct
            answer is licensed by the structure of a sentence — the head that governs agreement, the
            dependency that carries an inference, the scope that changes what follows — or by a
            surface cue that only correlates with the answer.
          </p>
          <p>
            After an undergraduate Philosophy thesis on Leibniz's <em>characteristica universalis</em>,
            I'm now in the M.Sc. in <strong>Human and AI</strong> at the University of Technology
            Nuremberg (UTN). My philosophical background makes me care about reasons, causes, and
            what would make an answer genuinely follow; learning across Chinese, German, and English,
            with Japanese underway, has made me unusually sensitive to grammar — to the small
            structural choices by which languages make inference visible or leave it implicit.
          </p>
          <p>
            I'm preparing PhD applications for fall 2027 on language, reasoning, and AI:
            computational-linguistic questions about how grammar makes inference possible, tested
            with causal-interpretability tools on models that may track structure — or only its
            surface.
          </p>
        </div>
        <blockquote class="hero-pull fade-in-up fade-delay-300">
          Language gives reasoning its shape. Models tell us whether they learned the shape or only the shadow.
        </blockquote>
        <div class="hero-cta fade-in-up fade-delay-300">
          <a href="#research" class="btn btn-primary">
            View research
            <span class="btn-arrow">↓</span>
          </a>
          <a href="#contact" class="btn btn-secondary">Get in touch</a>
        </div>
        <div class="hero-social fade-in-up fade-delay-400">
          <span class="hero-social-label">Reach me</span>
          <a class="hero-social-link" href="mailto:xiaochuan.li@utn.de" aria-label="Email">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="5" width="18" height="14" rx="2"></rect>
              <path d="M3 7l9 6 9-6"></path>
            </svg>
          </a>
          <a class="hero-social-link" href="https://github.com/xchuan-li" aria-label="GitHub" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
            </svg>
          </a>
          <a class="hero-social-link" href="https://www.linkedin.com/in/xiaochuan-li-0488533b5/" aria-label="LinkedIn" rel="noopener" target="_blank">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z" />
            </svg>
          </a>
          <a class="hero-social-link" href="/cv.pdf" aria-label="Download CV (PDF)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
              <path d="M14 2v6h6" />
              <path d="M12 18v-6" />
              <path d="M9 15l3 3 3-3" />
            </svg>
          </a>
        </div>
      </div>

      <div class="hero-figure-col fade-in fade-delay-300" aria-hidden="false">
        <HeroCausalMatrix />
      </div>
    </div>

  </section>

  <!-- =========== RESEARCH MAINLINE (scroll narrative) =========== -->
  <section id="mainline" class="section">
    <div class="section-inner">
      <div class="divider-line"></div>
      <div class="section-head">
        <p class="section-label fade-in-up">The through-line</p>
        <h2 class="section-heading fade-in-up fade-delay-100">From Leibniz's question to the model.</h2>
        <p class="section-sub fade-in-up fade-delay-200">
          One line, bookended by Leibniz: his <em>sufficient reason</em> — what licenses a correct
          answer — put to a model. Scroll the question on the left as the figure splits that reason
          into a grounded route and a shortcut, traces which one holds, measures its yield, and asks
          whether the structure survives <em>beneath every language</em> — the
          <em>characteristica</em> he named.
        </p>
      </div>
    </div>
    <MainlineScrolly />
  </section>

  <style>
    /* the pinned animation already ends on near-empty space; don't add much more */
    #mainline { padding-bottom: 1.5rem; }
    #mainline .section-head { margin-bottom: 2rem; }
  </style>

  <!-- =========== RESEARCH =========== -->
  <section id="research" class="section">
    <div class="section-inner">
      <div class="divider-line"></div>
      <div class="section-head">
        <p class="section-label fade-in-up">Research</p>
        <p class="research-prose fade-in-up fade-delay-100">
          One question: how does linguistic structure license inference — and do models use that
          structure, or only its surface? I make it testable two ways: by turning grammar into causal
          variables, and by re-encoding the <em>same</em> inference across morphology, word order, and
          context, so a model that tracks structure and one that rides surface are forced apart. The
          line runs in three steps — <em>certify</em> whether the structure is used at all,
          <em>localize</em> where, <em>quantify</em> how much inference it yields — built on one shared
          workbench. Below is the step that's done; the rest is where it's going.
        </p>
      </div>

      <a href="/research/sc-certification" class="anchor-card fade-in-up fade-delay-200">
        <div class="anchor-card-body">
          <div class="anchor-card-top">
            <h3 class="anchor-card-title">Stable Is Not Grounded</h3>
            <span class="anchor-card-status">experiments complete, writing up</span>
          </div>
          <p class="anchor-card-q"><em>Certify</em> — is the structure that licenses an inference load-bearing for the model at all?</p>
          <p class="anchor-card-desc">
            A non-circular test: counterfactual interventions on the licensing structure, plus a
            pure-noise control to rule out "any edit breaks it," with a clear decidability boundary —
            grounding is identifiable only when the causal structure is stipulated and the training
            distribution auditable. A stable, correct answer counts as grounded only if the stipulated
            structure survives shortcut-severing audits.
          </p>
          <span class="anchor-card-more">Read the work <span aria-hidden="true">→</span></span>
        </div>
        <div class="anchor-card-glyph proj-glyph-cell" aria-hidden="true">
          <ProjectGlyph kind="sc" color="var(--accent-coral)" />
        </div>
      </a>

      <p class="research-aside fade-in-up fade-delay-300">
        <em>Isotrace (localize)</em> — in design: upgrading the binary grounding verdict into
        hop-level diagnosis.
      </p>
      <p class="research-aside fade-in-up fade-delay-300">
        Ongoing collaborative work, in progress with others — <em>Latent Control States</em>
        (a mechanistic bridge) and <em>Cross-lingual ProtoBias</em> (an applied stress test). Group
        efforts, so I don't claim the outcome as mine; this is where the methods get tested on real
        models.
      </p>
    </div>
  </section>

  <style>
    #research .research-prose {
      font-size: 1.0625rem;
      line-height: 1.7;
      color: var(--color-text);
      max-width: 44rem;
      margin: 0;
    }
    #research .research-prose em { font-style: italic; }
    .anchor-card {
      display: flex;
      gap: 1.5rem;
      align-items: flex-start;
      justify-content: space-between;
      max-width: 760px;
      margin-top: 2.5rem;
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-left: 3px solid var(--accent-coral);
      border-radius: 10px;
      padding: 1.6rem 1.75rem;
      text-decoration: none;
      color: inherit;
      transition: border-color 0.2s ease, background 0.2s ease;
    }
    .anchor-card:hover { border-color: var(--card-hover-border); border-left-color: var(--accent-coral); background: var(--card-hover-bg); }
    .anchor-card-body { min-width: 0; }
    .anchor-card-top { display: flex; align-items: baseline; gap: 0.85rem; flex-wrap: wrap; margin-bottom: 0.5rem; }
    .anchor-card-title { font-family: var(--font-display); font-size: 1.35rem; font-weight: 600; letter-spacing: -0.015em; color: var(--color-text); margin: 0; transition: color 0.2s ease; }
    .anchor-card:hover .anchor-card-title { color: var(--color-accent); }
    .anchor-card-status { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-accent); border: 1px solid color-mix(in srgb, var(--color-accent) 45%, transparent); border-radius: 999px; padding: 3px 9px; white-space: nowrap; }
    .anchor-card-q { font-family: var(--font-serif); font-style: italic; font-size: 1.0625rem; line-height: 1.5; color: var(--color-text); margin: 0 0 0.7rem; }
    .anchor-card-q em { font-style: normal; font-weight: 500; }
    .anchor-card-desc { font-size: 0.95rem; line-height: 1.65; color: var(--color-text-muted); margin: 0 0 0.9rem; max-width: 48ch; }
    .anchor-card-more { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-accent); }
    .anchor-card-more span { display: inline-block; transition: transform 0.2s ease; }
    .anchor-card:hover .anchor-card-more span { transform: translateX(3px); }
    .anchor-card-glyph { flex: 0 0 96px; }
    .research-aside { font-size: 0.95rem; line-height: 1.65; color: var(--color-text-muted); max-width: 42rem; margin: 1.5rem 0 0; }
    .research-aside em { font-style: italic; color: var(--color-text); }
    @media (max-width: 560px) {
      .anchor-card { flex-direction: column; }
      .anchor-card-glyph { display: none; }
    }
  </style>

  <!-- =========== CURRENTLY =========== -->
  <section id="currently" class="section">
    <div class="section-inner">
      <div class="divider-line"></div>
      <div class="section-head">
        <p class="section-label fade-in-up">Currently</p>
        <h2 class="section-heading fade-in-up fade-delay-100">What I'm working on now.</h2>
      </div>
      <ul class="now-list fade-in-up fade-delay-200">
        {
          now.map((item) => (
            <li>
              <strong>{item.label}:</strong> {item.text}
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- =========== WRITING =========== -->
  <section id="writing" class="section">
    <div class="section-inner">
      <div class="divider-line"></div>
      <div class="section-head">
        <p class="section-label fade-in-up">Writing</p>
        <h2 class="section-heading fade-in-up fade-delay-100">Notes &amp; essays.</h2>
        <p class="section-sub fade-in-up fade-delay-200">
          Short pieces that sit upstream of the experiments — what the right question is, why the
          standard fix is one level too shallow, what philosophy gave me that ML didn't.
        </p>
      </div>
      <div class="writing-list fade-in-up fade-delay-300">
        {
          posts.map((p) => (
            <a href={`/writing/${p.slug}`} class="writing-row">
              <span class="writing-title">{p.title}</span>
              <span class="writing-meta">{p.meta}</span>
            </a>
          ))
        }
      </div>
      <div class="fade-in-up fade-delay-400" style="margin-top: 1.75rem;">
        <a href="/writing" class="btn btn-secondary">All writing →</a>
      </div>
    </div>
  </section>

  <!-- =========== CONTACT CTA =========== -->
  <section id="contact" class="section" style="padding-bottom: 7rem;">
    <div class="section-inner">
      <div class="divider-line"></div>
      <div class="contact-cta fade-in-up">
        <div>
          <h2 class="contact-cta-head">Let's talk.</h2>
          <p class="contact-cta-sub">
            Best by email — I read everything and reply slowly. If it's about a paper draft or a
            research direction, expect a thoughtful response in a few days rather than an immediate
            one.
          </p>
        </div>
        <div class="hero-cta" style="margin: 0;">
          <a class="btn btn-primary" href="mailto:xiaochuan.li@utn.de">
            Email me
            <span class="btn-arrow">↗</span>
          </a>
          <a class="btn btn-secondary" href="/contact">More ways</a>
        </div>
      </div>
    </div>
  </section>
</Base>
