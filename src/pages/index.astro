---
import Base from "../layouts/Base.astro";
import HeroCausalMatrix from "../components/HeroCausalMatrix.astro";
import ResearchSpine from "../components/TrajectoryTimeline.astro";
import { now } from "../data/research";

// The research arc as a scroll narrative: Leibniz's question becomes one
// causal-interpretability mainline. Collaborative projects sit to the right.
const spineQuestion = "“Nothing is without a reason.” I put it to a model — is its right answer backed by a sufficient reason, or only a surface accident? — and aim at the horizon Leibniz named: a characteristica universalis, where structure and surface no longer come apart.";

const spineOrigin = {
  label: "From sufficient reason to a universal language",
  href: "/writing/from-leibniz",
  hook: "Nihil est sine ratione.",
};

// The three method contributions, sharpening the one question in three steps:
// whether structure is used at all, where it is used, how much it is relied on.
const spineStations = [
  {
    n: "01",
    method: "Certify",
    qword: "Whether",
    q: "is the model using the right structure at all?",
    title: "Stable Is Not Grounded",
    color: "var(--accent-coral)",
    href: "/research/sc-certification",
  },
  {
    n: "02",
    method: "Localize",
    qword: "Where",
    q: "in the model is that structure actually used?",
    title: "Isotrace",
    color: "var(--accent-teal)",
    href: "/research/isotrace",
  },
  {
    n: "03",
    method: "Quantify",
    qword: "How much",
    q: "of the inference it licenses does the model produce?",
    title: "Causal Inferential Yield",
    color: "var(--accent-purple)",
    href: "/research/ciy",
  },
];

const spineFrontier = {
  label: "Frontier",
  title: "Typological Grounding",
  href: "/research/typological-grounding",
};

// The workbench the three methods run on — and are validated against.
const spineWorkbench = {
  title: "MiniCausalLang",
  href: "/research/mini-causal-models",
  desc: "A planted-ground-truth sandbox for testing whether linguistic behavior is structurally grounded or surface-driven.",
};

// Off the spine: collaborative projects, in progress, not claimed as the main line.
const spineGroups = [
  {
    title: "Latent Control States",
    kind: "Mechanistic extension",
    href: "/research/latent-control-states",
    desc: "Do structural control features propagate into latent space as discrete, recoverable states?",
  },
  {
    title: "Cross-lingual ProtoBias",
    kind: "Applied extension",
    href: "/research/cross-lingual-protobias",
    desc: "Prototypicality bias in MLLM judges — does the prompt language change the verdict?",
  },
  {
    title: "HanGL",
    kind: "Application pilot",
    href: "/research/hangl",
    desc: "Surface Hangul vs latent Hanja — the structure-vs-surface question, run on real LLMs.",
  },
];

const posts = [
  {
    slug: "meaning-beneath-language",
    title: "Is there meaning beneath the language?",
    meta: "Note · June 2026",
  },
  {
    slug: "causal-residue",
    title: "Causal structure as residue — training as elimination",
    meta: "Note · May 2026",
  },
  {
    slug: "from-leibniz",
    title: "Three Threads from Leibniz — what philosophy gave me that ML didn't",
    meta: "Note · May 2026",
  },
  {
    slug: "decidability-boundary",
    title: "Why interpretability needs a decidability boundary",
    meta: "Draft · May 2026",
  },
  {
    slug: "inferential-productivity",
    title: "Reasoning is generative; grounding needs the other direction",
    meta: "Note · May 2026",
  },
];

---

<Base wide={true}>
  <!-- =========== HERO =========== -->
  <section class="hero">
    <div class="hero-inner hero-grid">
      <div class="hero-content">
        <p class="hero-tagline fade-in">Master's student · Human and AI · UTN Nürnberg</p>
        <h1 class="hero-heading fade-in-up">
          <span>Hi, I am</span>
          <span class="line-2">Xiaochuan Li.</span>
        </h1>
        <div class="hero-bio fade-in-up fade-delay-200">
          <p>
            I do <strong>causal interpretability through linguistic structure</strong> — testing
            whether a model's stable, correct answer is licensed by the genuine structure of a
            sentence (the head that governs agreement, the dependency that carries an inference) or
            by a surface cue that only correlates with the answer.
          </p>
          <p>
            After an undergraduate Philosophy thesis on Leibniz's <em>characteristica universalis</em>,
            I'm now in the M.Sc. in <strong>Human and AI</strong> at the University of Technology
            Nuremberg (UTN). It helps that I think across very different languages — Chinese, German,
            and English, with Japanese underway — which pack meaning into grammar in sharply
            different ways; moving between them trains an eye for structure a single language can hide.
          </p>
          <p>
            I'm preparing PhD applications for fall 2027 on causal interpretability through
            linguistic structure — using the way languages encode meaning (morphology, word order,
            context) as the ground on which to test whether a model tracks the structure or just its
            surface.
          </p>
        </div>
        <blockquote class="hero-pull fade-in-up fade-delay-300">
          Structure, or surface? Language is where you can tell.
        </blockquote>
        <div class="hero-cta fade-in-up fade-delay-300">
          <a href="#research" class="btn btn-primary">
            View research
            <span class="btn-arrow">↓</span>
          </a>
          <a href="#contact" class="btn btn-secondary">Get in touch</a>
        </div>
        <div class="hero-social fade-in-up fade-delay-400">
          <span class="hero-social-label">Reach me</span>
          <a class="hero-social-link" href="mailto:xiaochuan.li@utn.de" aria-label="Email">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="5" width="18" height="14" rx="2"></rect>
              <path d="M3 7l9 6 9-6"></path>
            </svg>
          </a>
          <a class="hero-social-link" href="https://github.com/xchuan-li" aria-label="GitHub" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
            </svg>
          </a>
          <a class="hero-social-link" href="https://www.linkedin.com/in/xiaochuan-li-0488533b5/" aria-label="LinkedIn" rel="noopener" target="_blank">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z" />
            </svg>
          </a>
          <a class="hero-social-link" href="/cv.pdf" aria-label="Download CV (PDF)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
              <path d="M14 2v6h6" />
              <path d="M12 18v-6" />
              <path d="M9 15l3 3 3-3" />
            </svg>
          </a>
        </div>
      </div>

      <div class="hero-figure-col fade-in fade-delay-300" aria-hidden="false">
        <HeroCausalMatrix />
      </div>
    </div>

  </section>

  <!-- =========== RESEARCH SPINE =========== -->
  <section id="research" class="section">
    <div class="section-inner">
      <div class="divider-line"></div>
      <div class="section-head">
        <p class="section-label fade-in-up">Research</p>
        <h2 class="section-heading fade-in-up fade-delay-100">One program, not a list of ideas.</h2>
        <p class="section-sub fade-in-up fade-delay-200">
          One question — Leibniz's principle of sufficient reason, put to a model: is its behavior
          licensed by the genuine structure, or by a surface correlate? — sharpened in three steps:
          <em>whether</em> structure is used at all (certify), <em>where</em> it is used (localize),
          and <em>how much</em> the model relies on it (quantify). The three are the main line, run on
          a shared workbench that turns linguistic structure into causal variables; the horizon is a
          <em>characteristica universalis</em>, a language where structure and surface coincide. A few
          collaborative projects sit off the spine.
        </p>
      </div>
      <div class="fade-in-up fade-delay-300">
        <ResearchSpine
          question={spineQuestion}
          origin={spineOrigin}
          stations={spineStations}
          frontier={spineFrontier}
          workbench={spineWorkbench}
          groups={spineGroups}
        />
      </div>
    </div>
  </section>

  <!-- =========== CURRENTLY =========== -->
  <section id="currently" class="section">
    <div class="section-inner">
      <div class="divider-line"></div>
      <div class="section-head">
        <p class="section-label fade-in-up">Currently</p>
        <h2 class="section-heading fade-in-up fade-delay-100">What I'm working on now.</h2>
      </div>
      <ul class="now-list fade-in-up fade-delay-200">
        {
          now.map((item) => (
            <li>
              <strong>{item.label}:</strong> {item.text}
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- =========== WRITING =========== -->
  <section id="writing" class="section">
    <div class="section-inner">
      <div class="divider-line"></div>
      <div class="section-head">
        <p class="section-label fade-in-up">Writing</p>
        <h2 class="section-heading fade-in-up fade-delay-100">Notes &amp; essays.</h2>
        <p class="section-sub fade-in-up fade-delay-200">
          Short pieces that sit upstream of the experiments — what the right question is, why the
          standard fix is one level too shallow, what philosophy gave me that ML didn't.
        </p>
      </div>
      <div class="writing-list fade-in-up fade-delay-300">
        {
          posts.map((p) => (
            <a href={`/writing/${p.slug}`} class="writing-row">
              <span class="writing-title">{p.title}</span>
              <span class="writing-meta">{p.meta}</span>
            </a>
          ))
        }
      </div>
      <div class="fade-in-up fade-delay-400" style="margin-top: 1.75rem;">
        <a href="/writing" class="btn btn-secondary">All writing →</a>
      </div>
    </div>
  </section>

  <!-- =========== CONTACT CTA =========== -->
  <section id="contact" class="section" style="padding-bottom: 7rem;">
    <div class="section-inner">
      <div class="divider-line"></div>
      <div class="contact-cta fade-in-up">
        <div>
          <h2 class="contact-cta-head">Let's talk.</h2>
          <p class="contact-cta-sub">
            Best by email — I read everything and reply slowly. If it's about a paper draft or a
            research direction, expect a thoughtful response in a few days rather than an immediate
            one.
          </p>
        </div>
        <div class="hero-cta" style="margin: 0;">
          <a class="btn btn-primary" href="mailto:xiaochuan.li@utn.de">
            Email me
            <span class="btn-arrow">↗</span>
          </a>
          <a class="btn btn-secondary" href="/contact">More ways</a>
        </div>
      </div>
    </div>
  </section>
</Base>
