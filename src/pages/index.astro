---
import Base from "../layouts/Base.astro";
import HeroSentence from "../components/HeroSentence.astro";
import ResearchTimeline from "../components/ResearchTimeline.astro";
import { projects } from "../data/research";
import { posts as writingPosts } from "../data/writing";

// The research section as a narrative: Leibniz's question (origin) flows into the
// program, then into a reverse-chronological timeline of projects and notes
// (ResearchTimeline).
const spineLeadIn = "Leibniz made modality structure: what is necessary holds in all possible worlds, what is possible in some. Kripke turned that into mathematics, Kratzer connected it to the modal words of natural language, and Leahy & Carey made possession-versus-performance an experimental question. Language models inherit it in its strangest form. They are built entirely from language, with no world, so do they still grow something functionally like a space of alternatives? Each entry below is one piece of the current case, modality. The same question runs on to conditionals, quantifiers, counterfactuals, and beyond: modality is the first case study, not the last.";

const spineOrigin = {
  label: "From possible worlds to language models",
  href: "/research-program",
  hook: "Nihil est sine ratione.",
};

// Homepage timeline (below the Leibniz lead-in), transformer-circuits style: a
// single reverse-chronological stream. Both project AND note display-dates are a
// homepage-only narrative, hand-spread so projects and notes interleave (never two
// notes in a row); the real note pubDates stay on /writing, and /research stays
// date-free. The homepage shows only the two projects squarely on the modality
// mainline — GRADUS (the modal-force pilot running now, anchoring the top) and
// CAST (the workbench it runs on). The collaborations (HanGL, Latent Control
// States, Cross-lingual ProtoBias) are kept on /research but left off the
// homepage; a milestone note marks the thesis turn to modal concepts.
//
// Notes are filtered the same way: only the three squarely on the program's line
// appear here (from-leibniz = the stage-I origin; meaning-beneath-language = the
// Kratzer/typology stage in prose; inverted-observability = the Leahy & Carey
// verdict layer). Everything else lives on /writing only.
const mainlineNotes = new Set(["from-leibniz", "meaning-beneath-language", "inverted-observability"]);
const projectDate: Record<string, string> = {
  "/research/modus": "2026-07-08",
  "/research/ordo": "2026-06-28",
  "/research/gradus": "2026-06-20",
  "/research/mini-causal-models": "2026-05-05",
};
// Homepage display-dates for the notes, chosen to interleave them among the
// projects (their real pubDates, several clustered in late May, remain on /writing).
const noteDate: Record<string, string> = {
  "inverted-observability": "2026-06-12",
  "meaning-beneath-language": "2026-05-28",
  "from-leibniz": "2026-03-10",
};
// A 2–3 sentence introduction per project, condensed from each project's own
// description in data/research.ts (no new claims) — keyed by href.
const projectIntro: Record<string, string> = {
  "/research/modus":
    "My Master's thesis: is modal force a quantification over a set of possible worlds (Kratzer), or a single degree of certainty (Lassiter)? Judgment data cannot separate the two; a model's representational format under intervention can, so the language model is the instrument, not the object. A pilot already shows the force direction is load-bearing (ablate it and a might sentence's certainty jumps toward must, +0.15). The format test (FORMA) is next; GRADUS is its graded ruler.",
  "/research/ordo":
    "Generics (birds fly, except penguins) and modals (you should repay, unless…) are both defaults that tolerate exceptions. Do they share one ordering-source mechanism, or two? A layered novelty-of-exception design: a memorized lookup table collapses on never-seen exceptions, a genuine ordering stays flat, and either outcome is a finding. In design, built on CAST.",
  "/research/gradus":
    "Does a language model represent epistemic modal force (the necessity in must, the possibility in might), or ride the surface modal word? A force direction is built from evidence alone, with no modal word present; ablate it on a might sentence and its certainty jumps toward must (+0.15), while a base-rate control does nothing. GRADUS extends the test into a graded epistemic-force dataset. That turns the binary probe into a calibration diagnostic, and gives MODUS (the modal-force thesis) a citable ruler to reuse. This is the one project I am actively running.",
  "/research/mini-causal-models":
    "Given a modal state (a set of possible worlds and a ◇/□ constraint), CAST projects it to controlled text in English, German, and Chinese, then grades whether the model's behaviour is isomorphic to the world-set it was compiled from. Because the logical content is fixed by construction, any difference across the three languages can only come from linguistic form, not the facts. It is the workbench the modal thesis runs on: a space of alternatives stipulated in advance, so the question stays decidable rather than guessed.",
  "/research/latent-control-states":
    "Prompt framing (urgency, authority, an epistemic stance) clearly changes what a model says. This asks whether it also shifts a causally relevant latent state, or only the surface. A controlled-data pipeline is built; probing and activation patching come next. A collaboration advised by a senior researcher at DFKI.",
  "/research/hangl":
    "Korean Sino-Korean words are a natural experiment in surface versus meaning: the Hangul spelling shares zero characters with its Hanja origin yet matches it in meaning. A wrong-Hanja intervention shows latent grounding scales with capability: a strong model neither needs the cue nor is misled by it, a weak one is both. A collaboration off the program's mainline (lexical grounding, not modality), but the clearest demonstration of the cross-lingual intervention method the modal-typology stage will reuse.",
  "/research/cross-lingual-protobias":
    "The applied, multimodal stress test of the core question: across languages, does a vision-language model track meaning, or lean on language- and culture-specific prototype shortcuts? It pits the two against each other, extending a forthcoming paper from an established NLP group. The current report covers two models across seven languages.",
  "/research/typological-grounding":
    "The flagship application the program builds toward, with modality as the case: English may/must, German können/müssen/dürfen, and Chinese 可能/必须/一定 carve the same modal space differently. Hold the modal base fixed, swap the language, and ask whether the model tracks the quantified world-set or each language's surface habits. Currently exploratory.",
};
// One-sentence homepage descriptions for the notes (their fuller excerpts live on
// /writing) — keyed by slug.
const noteBlurb: Record<string, string> = {
  "inverted-observability": "Why developmental psychology and interpretability are the same question seen from opposite sides of a mirror.",
  "meaning-beneath-language": "When one content is carried by German morphology, English word order, and Chinese context, does a model represent the meaning, or three surface habits?",
  "from-leibniz": "What an undergraduate thesis on Leibniz's universal character became after a change of discipline.",
};

// Which real per-project figure to show on the right (by href). Projects without
// a clean static figure fall back to their glyph for now.
const projectFig: Record<string, string> = {
  "/research/gradus": "gradus",
  "/research/hangl": "hangl",
  "/research/cross-lingual-protobias": "protobias",
  "/research/latent-control-states": "latent",
  "/research/mini-causal-models": "cast",
};

const MONTHS = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];
const monthLabel = (iso: string) => {
  const [y, m] = iso.split("-");
  return `${MONTHS[Number(m) - 1]} ${y}`;
};

// The thesis has no card (no results yet — program rule); it enters the stream as
// a milestone note, dated to the day the program statement went up.
const milestones = [
  {
    type: "milestone" as const,
    date: "2026-07-02",
    text: "The program's full statement goes up: the long arc from linguistic structure to language models. And the Master's thesis at UTN, MODUS (on the format of modal force), starts taking shape.",
  },
];

const rawEntries = [
  ...milestones,
  ...projects
    .filter((p) => projectDate[p.href])
    .map((p) => ({
      type: "project" as const,
      date: projectDate[p.href],
      href: p.href,
      name: p.title.split(" · ")[0],
      blurb: p.blurb ?? p.short ?? p.desc,
      intro: projectIntro[p.href],
      color: p.color,
      category: p.category,
      progress: p.progress,
      kind: p.kind,
      demo: p.demo,
      glyph: p.glyph,
      fig: projectFig[p.href],
    })),
  ...writingPosts.filter((p) => mainlineNotes.has(p.slug)).map((p) => ({
    type: "writing" as const,
    date: noteDate[p.slug] ?? p.pubDate,
    href: `/writing/${p.slug}`,
    title: p.title,
    blurb: noteBlurb[p.slug] ?? p.excerpt,
    status: p.status,
  })),
].sort((a, b) => b.date.localeCompare(a.date));

let prevLabel = "";
const entries = rawEntries.map((e) => {
  const dateLabel = monthLabel(e.date);
  const showDate = dateLabel !== prevLabel;
  prevLabel = dateLabel;
  return { ...e, dateLabel, showDate };
});

---

<Base wide={true}>
  <!-- =========== HERO =========== -->
  <section class="hero">
    <div class="hero-inner hero-grid">
      <div class="hero-content">
        <p class="hero-tagline fade-in">Master's student · Human and AI · UTN Nürnberg</p>
        <h1 class="hero-heading fade-in-up">
          <span>Hi, I am</span>
          <span class="line-2">Xiaochuan Li.</span>
        </h1>
        <div class="hero-bio fade-in-up fade-delay-200">
          <p>
            I study one question: <strong>how linguistic structure becomes representation, and how
            representation becomes reasoning.</strong> Concretely: how does a sentence come to mean?
            Words carry meaning, grammatical structure makes those meanings react into the meaning of
            the whole, and that whole becomes a step in reasoning.
          </p>
          <p>
            I put that question to two systems that answer it differently, a
            <strong>language model</strong> I can open up and intervene on, and the
            <strong>human mind</strong> where meaning is already real, and read the answer with the
            tools of interpretability. Modality is the first case I study it on.
          </p>
          <p>
            I'm applying for PhD positions for fall 2027.
          </p>
        </div>
        <blockquote class="hero-pull fade-in-up fade-delay-300">
          A sentence means more than its words. It means what structure makes them do.
        </blockquote>
        <div class="hero-cta fade-in-up fade-delay-300">
          <a href="#research" class="btn btn-primary">
            View research
            <span class="btn-arrow">↓</span>
          </a>
          <a href="#contact" class="btn btn-secondary">Get in touch</a>
        </div>
        <div class="hero-social fade-in-up fade-delay-400">
          <span class="hero-social-label">Reach me</span>
          <a class="hero-social-link" href="mailto:xiaochuan.li@utn.de" aria-label="Email">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="5" width="18" height="14" rx="2"></rect>
              <path d="M3 7l9 6 9-6"></path>
            </svg>
          </a>
          <a class="hero-social-link" href="https://github.com/xchuan-li" aria-label="GitHub" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
            </svg>
          </a>
          <a class="hero-social-link" href="https://www.linkedin.com/in/xiaochuan-li-0488533b5/" aria-label="LinkedIn" rel="noopener" target="_blank">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z" />
            </svg>
          </a>
          <a class="hero-social-link" href="/cv.pdf" aria-label="Download CV (PDF)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
              <path d="M14 2v6h6" />
              <path d="M12 18v-6" />
              <path d="M9 15l3 3 3-3" />
            </svg>
          </a>
        </div>
      </div>

      <div class="hero-figure-col fade-in fade-delay-300" aria-hidden="false">
        <HeroSentence />
      </div>
    </div>

  </section>

  <!-- =========== HOW I STUDY IT (the program's shape) =========== -->
  <section class="section">
    <div class="section-inner">
      <div class="divider-line"></div>
      <div class="section-head">
        <p class="section-label fade-in-up">How I study it</p>
        <h2 class="section-heading fade-in-up fade-delay-100">
          One question, not three directions.
        </h2>
      </div>
      <div class="program-lenses fade-in-up fade-delay-200">
        <p>
          A theory of meaning makes a claim about what a system must represent. I put that claim to
          two systems that answer it in different currencies, then read the verdict with the tools of
          interpretability. What can look like three interests are three ways of looking at one
          question.
        </p>
        <p>
          <strong>Theory — the claim.</strong> Formal semantics and logic state, precisely enough to
          be wrong, what structure a competent system would need: a modal base, an ordering source,
          the monotonicity of a quantifier. This is the source of every hypothesis I test.
        </p>
        <p>
          <strong>Language models — the testbed you can open.</strong> A system built from language
          alone, whose representations you can probe, ablate, and intervene on. It is the experiment
          you cannot run on a mind.
        </p>
        <p>
          <strong>Human minds — the testbed where meaning is real.</strong> How the same structure is
          acquired and used, and why behaviour alone never proves a representation. The reference the
          model is checked against.
        </p>
        <p class="program-lenses-foot">
          The instrument that reads the verdict today is mechanistic interpretation and causal
          intervention. The instrument will change. The question, and the method of turning a theory
          into a checkable prediction, will not.
        </p>
      </div>
    </div>
  </section>

  <!-- =========== RESEARCH =========== -->
  <section id="research" class="section">
    <div class="section-inner">
      <div class="divider-line"></div>
      <div class="section-head">
        <p class="section-label fade-in-up">The research program</p>
        <h2 class="section-heading section-question fade-in-up fade-delay-100">
          Modality is the first case study, not the boundary.
        </h2>
      </div>
      <div class="fade-in-up fade-delay-200">
        <ResearchTimeline
          origin={spineOrigin}
          leadIn={spineLeadIn}
          entries={entries}
        />
      </div>
    </div>
  </section>


  <!-- =========== CONTACT CTA =========== -->
  <section id="contact" class="section" style="padding-bottom: 7rem;">
    <div class="section-inner">
      <div class="divider-line"></div>
      <div class="contact-cta fade-in-up">
        <div>
          <h2 class="contact-cta-head">Let's talk.</h2>
          <p class="contact-cta-sub">
            Best by email. I read everything and reply slowly. If it's about a paper draft or a
            research direction, expect a thoughtful response in a few days rather than an immediate
            one.
          </p>
        </div>
        <div class="hero-cta" style="margin: 0;">
          <a class="btn btn-primary" href="mailto:xiaochuan.li@utn.de">
            Email me
            <span class="btn-arrow">↗</span>
          </a>
          <a class="btn btn-secondary" href="/contact">More ways</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  /* The research heading is now the core research question itself — keep it
     readable at a slightly smaller, tighter size than a normal section heading. */
  .section-question {
    max-width: 24ch;
    font-size: clamp(1.55rem, 1.1rem + 1.7vw, 2.4rem);
    line-height: 1.2;
  }

  /* "How I study it" — the program's three ways of looking at one question,
     as a simple prose block (theory / language models / human minds). */
  .program-lenses {
    max-width: 52ch;
  }
  .program-lenses > p {
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0 0 1.15rem;
  }
  .program-lenses > p:first-child {
    color: var(--color-text);
  }
  .program-lenses > p strong {
    color: var(--color-text);
    font-weight: 600;
  }
  .program-lenses-foot {
    margin-top: 1.6rem !important;
    padding-top: 1.15rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.95rem;
  }
</style>
