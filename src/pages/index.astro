---
import Base from "../layouts/Base.astro";
import SectionDivider from "../components/SectionDivider.astro";
import HeroFigure from "../components/HeroFigure.astro";

const projects = [
  {
    title: "Stable is not grounded",
    meta: "Paper · in progress · Aug 2026",
    desc: "An acyclic certification framework. A do(class-3) intervention severs a candidate shortcut and asks whether the licensing structure M was actually load-bearing for the model's output, or merely accuracy-correlated. Real-world demonstration on MNLI / HANS.",
    tags: ["causal inference", "certification"],
    href: "/research/sc-certification",
    color: "var(--accent-coral)",
    demo: true,
  },
  {
    title: "Isotrace — behavioral tracing of multi-hop reasoning",
    meta: "Paper · in progress",
    desc: "Fictional concept names with path-encoded naming conventions. Locates where shortcut substitution replaces compositional reasoning, hop by hop — without opening the model.",
    tags: ["behavioral probing", "reasoning"],
    href: "/research/isotrace",
    color: "var(--accent-teal)",
  },
  {
    title: "CIY — causal inferential yield",
    meta: "Paper · draft",
    desc: "A graded measure over the items SC-certification has already cleared as grounded. The falsifiability constraint: if two models matched on accuracy and grounding but opposing CIY cannot be constructed, CIY has collapsed into accuracy repackaging.",
    tags: ["measurement", "falsifiability"],
    href: "/research/ciy",
    color: "var(--accent-purple)",
  },
  {
    title: "LiT — latent control states under prompt framing",
    meta: "Team project · May–Dec 2026 · DFKI",
    desc: "Whether prompt-induced behavioral shifts correspond to causally relevant states in activation space. Five-person collaboration with DFKI Saarbrücken. I lead the experimental design and downstream causal analysis.",
    tags: ["mech interp"],
    href: "/research/lit",
    color: "var(--accent-amber)",
  },
];

const posts = [
  {
    slug: "from-leibniz",
    title: "From Leibniz to do(class-3) — what philosophy gave me that ML didn't",
    meta: "Note · May 2026",
  },
  {
    slug: "inferential-productivity",
    title: "Reasoning is generative; grounding needs the other direction",
    meta: "Note · May 2026",
  },
];

const now = [
  "Writing the SC-certification paper for an August target. The §6.5 demonstration on MNLI / HANS is the current bottleneck.",
  "Co-leading the LiT mech-interp project with DFKI Saarbrücken. My slice is experimental design and the downstream causal analysis.",
  "Preparing PhD applications for late 2026 — causal foundations of interpretability, ELLIS / MPI / DFKI-affiliated groups.",
];
---

<Base>
  <section class="mb-14">
    <div class="hero-accent mb-8">
      <h1 class="text-3xl font-medium tracking-tight mb-2">Xiaochuan Li</h1>
      <p class="text-base text-[var(--color-text-muted)]">
        Master's student, Human and AI — University of Technology Nuremberg
      </p>
    </div>

    <p class="leading-relaxed mb-5 text-[15.5px]">
      I work at the intersection of causal inference and interpretability. The question I keep
      coming back to is whether a model's stable-correct behavior is licensed by the structure
      we'd point to as the reason, or whether the structure is decorative and something else is
      doing the work.
    </p>

    <HeroFigure />

    <blockquote class="pull-quote">
      Stability is necessary but not sufficient for grounding.
    </blockquote>

    <p class="text-sm text-[var(--color-text-muted)] mt-6">
      Previously: B.A. Philosophy, Shenzhen University. Applying for PhD positions starting fall 2027.
    </p>
  </section>

  <SectionDivider mark="node" />

  <section class="mb-8">
    <div class="flex items-baseline justify-between mb-4">
      <h2 class="text-lg font-medium">Current research</h2>
      <a href="/research" class="text-xs text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">all projects →</a>
    </div>
    <div>
      {
        projects.map((p) => (
          <a
            href={p.href}
            class="proj-card block py-5 group hover:bg-[var(--color-surface)] -mx-3 pr-3 rounded-md transition-colors"
            style={`--proj-color: ${p.color}`}
          >
            <div class="flex justify-between items-baseline gap-3 mb-1.5">
              <span class="text-[15px] font-medium group-hover:text-[var(--color-accent)] transition-colors">
                {p.title}
              </span>
              <span class="text-xs text-[var(--color-text-dim)] whitespace-nowrap">{p.meta}</span>
            </div>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-2">{p.desc}</p>
            <div class="flex gap-1.5 flex-wrap">
              {p.demo && (
                <span class="inline-block text-[11px] px-2 py-0.5 rounded-full bg-[var(--accent-teal-tint)] text-[var(--accent-teal-deep)]">
                  interactive figure ↗
                </span>
              )}
              {p.tags.map((t) => (
                <span class="inline-block text-[11px] px-2 py-0.5 rounded-full bg-[var(--color-surface)] text-[var(--color-text-muted)] border border-[var(--color-border)]">
                  {t}
                </span>
              ))}
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <SectionDivider mark="arrow" />

  <section class="mb-8">
    <h2 class="text-lg font-medium mb-4">Currently</h2>
    <ul class="now-list">
      {now.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <SectionDivider mark="dots" />

  <section>
    <div class="flex items-baseline justify-between mb-4">
      <h2 class="text-lg font-medium">Writing</h2>
      <a href="/writing" class="text-xs text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">all posts →</a>
    </div>
    <div class="divide-y divide-[var(--color-border)]">
      {
        posts.map((p) => (
          <a href={`/writing/${p.slug}`} class="block py-3 group hover:bg-[var(--color-surface)] -mx-3 px-3 rounded-md transition-colors">
            <p class="text-sm font-medium mb-1 group-hover:text-[var(--color-accent)] transition-colors">{p.title}</p>
            <p class="text-xs text-[var(--color-text-dim)]">{p.meta}</p>
          </a>
        ))
      }
    </div>
  </section>
</Base>
