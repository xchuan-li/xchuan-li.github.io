---
import Base from "../layouts/Base.astro";
import SectionDivider from "../components/SectionDivider.astro";
import ProjectGlyph from "../components/ProjectGlyph.astro";

const timeline = [
  {
    type: "idea",
    note: "from-leibniz",
    text: "When can a system's behavior be reduced to the minimum structure that licenses it? I spent an undergraduate thesis asking this of Leibniz; I'm now asking it of models.",
  },
  {
    type: "idea",
    note: "decidability-boundary",
    text: "A model can be perfectly stable and perfectly accurate and still be reading the wrong feature — as long as that feature tracks the label on the slice you happen to test.",
  },
  {
    type: "project",
    n: "01",
    title: "Stable is not grounded",
    color: "var(--accent-coral)",
    glyph: "sc",
    href: "/research/sc-certification",
    code: "https://github.com/xchuan-li/Stable_is_not_grounded",
    text: "A do-intervention severs a candidate shortcut to test whether the licensing structure was load-bearing for the answer, or merely accuracy-correlated — with the controlled result running live as an interactive figure.",
  },
  {
    type: "project",
    n: "02",
    title: "Isotrace",
    color: "var(--accent-teal)",
    glyph: "isotrace",
    href: "/research/isotrace",
    text: "Once a shortcut is exposed, locate where compositional reasoning gives way to a surface pattern — hop by hop, without opening the model.",
  },
  {
    type: "idea",
    note: "inferential-productivity",
    text: "Producing conclusions is cheap; anything that composes has it for free. The expensive, almost-unmeasured direction is the reverse — given a behavior, what is the smallest causal structure that has to be there?",
  },
  {
    type: "project",
    n: "03",
    title: "Causal inferential yield",
    color: "var(--accent-purple)",
    glyph: "ciy",
    href: "/research/ciy",
    text: "A graded, falsifiable measure of how much of the licensing structure a model actually uses — built so it can't quietly collapse back into accuracy.",
  },
  {
    type: "project",
    n: "04",
    title: "Latent control states",
    color: "var(--accent-amber)",
    glyph: "latent",
    href: "/research/latent-control-states",
    text: "From behavioral evidence to mechanism: do prompt-framing effects correspond to causally relevant states in activation space, or to surface features that merely travel with the prompt?",
  },
  {
    type: "project",
    n: "05",
    title: "Cross-lingual ProtoBias",
    color: "var(--accent-indigo)",
    glyph: "protobias",
    href: "/research/cross-lingual-protobias",
    text: "The same semantic-versus-shortcut question, stress-tested across languages: does a multimodal evaluator track meaning, or culture-specific prototypes that shift with the prompt's language?",
  },
];

const posts = [
  {
    slug: "from-leibniz",
    title: "From Leibniz to do(class-3) — what philosophy gave me that ML didn't",
    meta: "Note · May 2026",
  },
  {
    slug: "inferential-productivity",
    title: "Reasoning is generative; grounding needs the other direction",
    meta: "Note · May 2026",
  },
];

const now = [
  "Writing the SC-certification paper for an August target. The §6.5 demonstration on MNLI / HANS is the current bottleneck.",
  "Developing the latent-control-states mech-interp project on prompt-framing effects and causally relevant activation-space states.",
  "Starting a cross-lingual ProtoBias project on prototypicality bias in multimodal AI evaluation.",
  "Preparing PhD applications for late 2026 — causal foundations of interpretability, ELLIS / MPI / DFKI-affiliated groups.",
];
---

<Base>
  <section class="mb-12">
    <div class="hero-accent mb-8">
      <h1 class="text-3xl font-medium tracking-tight mb-2">Xiaochuan Li</h1>
      <p class="text-base text-[var(--color-text-muted)]">
        Master's student, Human and AI — University of Technology Nuremberg
      </p>
    </div>

    <p class="leading-relaxed mb-5 text-[15.5px]">
      I work at the intersection of causal inference and interpretability. The question I keep
      coming back to is whether a model's stable-correct behavior is licensed by the structure
      we'd point to as the reason, or whether the structure is decorative and something else is
      doing the work.
    </p>

    <blockquote class="pull-quote">
      Stability is necessary but not sufficient for grounding.
    </blockquote>

    <p class="text-sm text-[var(--color-text-muted)] mt-6">
      Previously: B.A. Philosophy, Shenzhen University. Applying for PhD positions starting fall 2027.
    </p>
  </section>

  <SectionDivider mark="node" />

  <section class="mb-8">
    <div class="flex items-baseline justify-between mb-3">
      <h2 class="text-lg font-medium">From idea to experiment</h2>
      <a href="/research" class="text-xs text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">all projects →</a>
    </div>
    <p class="text-sm text-[var(--color-text-muted)] mb-8 max-w-prose">
      One question — when is a model's behavior licensed by the structure we think it has? — traced
      from where it started to the experiments testing it now. Open marks are ideas; the filled,
      numbered nodes are the projects that implement them.
    </p>

    <ol class="timeline">
      {
        timeline.map((item) =>
          item.type === "idea" ? (
            <li class="tl-item tl-idea">
              <span class="tl-marker"></span>
              <div class="tl-body">
                <div class="tl-kicker">idea</div>
                <p class="tl-idea-text">{item.text}</p>
                <a href={`/writing/${item.note}`} class="tl-link">read the note →</a>
              </div>
            </li>
          ) : (
            <li class="tl-item tl-project" style={`--c: ${item.color}`}>
              <span class="tl-marker"></span>
              <div class="tl-body tl-body-project">
                <div class="tl-main">
                  <div class="tl-head">
                    <span class="tl-num">{item.n}</span>
                    <h3 class="tl-title">{item.title}</h3>
                  </div>
                  <p class="tl-text">{item.text}</p>
                  <div class="tl-links">
                    <a href={item.href} class="tl-link">open project →</a>
                    {item.code && (
                      <a href={item.code} class="tl-code">experiments + code ↗</a>
                    )}
                  </div>
                </div>
                <div class="tl-glyph" aria-hidden="true">
                  <ProjectGlyph kind={item.glyph} color={item.color} />
                </div>
              </div>
            </li>
          )
        )
      }
    </ol>
  </section>

  <SectionDivider mark="arrow" />

  <section class="mb-8">
    <h2 class="text-lg font-medium mb-4">Currently</h2>
    <ul class="now-list">
      {now.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <SectionDivider mark="dots" />

  <section>
    <div class="flex items-baseline justify-between mb-4">
      <h2 class="text-lg font-medium">Writing</h2>
      <a href="/writing" class="text-xs text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">all posts →</a>
    </div>
    <div class="divide-y divide-[var(--color-border)]">
      {
        posts.map((p) => (
          <a href={`/writing/${p.slug}`} class="block py-3 group hover:bg-[var(--color-surface)] -mx-3 px-3 rounded-md transition-colors">
            <p class="text-sm font-medium mb-1 group-hover:text-[var(--color-accent)] transition-colors">{p.title}</p>
            <p class="text-xs text-[var(--color-text-dim)]">{p.meta}</p>
          </a>
        ))
      }
    </div>
  </section>
</Base>
