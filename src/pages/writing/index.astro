---
import Base from "../../layouts/Base.astro";
import { posts } from "../../data/writing";
---

<Base
  title="Writing · Xiaochuan Li"
  description="Longer-form notes and essays on causal-inferential rigor, research taste, and what philosophy training does to how one reads ML papers."
>
  <div class="flex items-baseline justify-between gap-3 mb-2">
    <h1 class="text-2xl font-medium tracking-tight">Writing</h1>
    <a href="/rss.xml" class="text-xs text-[var(--color-text-dim)] hover:text-[var(--color-accent)] transition-colors whitespace-nowrap">RSS</a>
  </div>
  <p class="text-[var(--color-text-muted)] mb-10 max-w-prose">
    Longer-form notes and essays. I write here when an idea is too messy for a paper but too
    specific for a tweet, usually about research taste, causal-inferential rigor, or what
    philosophy training does to how one reads ML papers. My work treats interpretability as an
    identification problem: which behavioral evidence licenses which causal claim?
  </p>

  <div class="divide-y divide-[var(--color-border)]">
    {
      posts.map((p) => (
        <a href={`/writing/${p.slug}`} class="block py-6 group hover:bg-[var(--color-surface)] -mx-3 px-3 rounded-md transition-colors">
          <div class="flex justify-between items-baseline gap-3 mb-2">
            <h2 class="text-base font-medium group-hover:text-[var(--color-accent)]">{p.title}</h2>
            <span class="text-xs text-[var(--color-text-dim)] whitespace-nowrap">{p.date}</span>
          </div>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-2">{p.excerpt}</p>
          <span class="inline-block text-[11px] px-2 py-0.5 rounded-full bg-[var(--color-surface)] text-[var(--color-text-muted)] border border-[var(--color-border)]">
            {p.status}
          </span>
        </a>
      ))
    }
  </div>
</Base>
