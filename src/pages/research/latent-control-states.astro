import Base from "../../layouts/Base.astro";
import ProgressTimeline from "../../components/ProgressTimeline.astro";

const roadmap = [
  {
    date: "Jun 2026",
    phase: "Report I · framing + data",
    title: "Three framing dimensions and a controlled-data pipeline",
    summary:
      "Prompt framing is operationalised into three dimensions — urgency, authority, epistemic positioning. A two-agent pipeline builds a controlled dataset: a helper extracts a framing-agnostic theme/action/goal from each scenario, then a generator re-renders it under each framing plus a neutral baseline, holding content fixed so framing is the single manipulated variable, with schema and faithfulness (RAGAS) validation.",
    status: "active" as const,
  },
  {
    date: "Planned",
    phase: "Next",
    title: "Probing and activation patching",
    summary:
      "With the controlled dataset in hand, test whether a framing's effect corresponds to a causally relevant direction in activation space — or to surface features that merely travel with the prompt.",
    status: "planned" as const,
  },
