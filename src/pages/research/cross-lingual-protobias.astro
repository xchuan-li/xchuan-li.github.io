import Base from "../../layouts/Base.astro";
import ProgressTimeline from "../../components/ProgressTimeline.astro";
import ProtoBiasDemo from "../../components/ProtoBiasDemo.tsx";

// Project milestones — each "done" node links to its own standalone report.
const progress = [
  {
    date: "8 Jun 2026",
    phase: "Experiment 1 · Report 1",
    title: "The bias follows the attribute, not the language",
    summary:
      "The first multilingual pipeline: 3,600 judgments from Qwen2.5-VL-7B across English, Chinese, Arabic, and Hindi, with full domain × language and attribute breakdowns, confidence intervals, and caveats.",
    href: "/research/cross-lingual-protobias/report-1",
    status: "done",
  },
  {
    date: "21 Jun 2026",
    phase: "Experiment 2 · Report 2",
    title: "It replicates across models — and language is not flat after all",
    summary:
      "Scaled to two model families (Qwen2.5-VL-7B and InternVL3-8B) and seven languages — about 12,500 judgments — adding Russian, Bengali, and Greek across resource levels and scripts. An item-clustered mixed-effects analysis confirms the attribute effect (Wealth, Power) in both families. The lower-resource, distinct-script prompts surface a language effect the first four languages missed: Bengali and Greek elicit measurably more bias than English, and a back-translation check rules out translation quality. The prototype trap is largely item-intrinsic (the same pairs fool both models, r = 0.68) and not a low-level visual artifact — pointing to a two-factor account.",
    status: "done",
  },
];
---

<Base
  title="Cross-lingual ProtoBias · Xiaochuan Li"
  description="An applied multilingual/multimodal stress test of semantic grounding versus language- and culture-specific prototype shortcuts."
  showProgress={true}
  toc={true}
>
  <article class="prose">
    <div class="text-xs uppercase tracking-wider text-[var(--color-text-dim)] font-medium mb-2">
      Extension · applied stress test
    </div>
    <h1>Cross-lingual ProtoBias</h1>
    <p class="text-[var(--color-text-muted)] italic !text-lg !mb-8">
      Semantic grounding versus prototype shortcuts under language variation.
    </p>

    <p>
      Cross-lingual ProtoBias carries the program's structure-versus-surface question — here meaning
      versus prototype shortcut — into multilingual, multimodal evaluation: does an MLLM judge track the
      meaning of an image–text pair, or lean on a language- and culture-specific prototype? Each prompt
      shows two images — one semantically correct but less prototypical, one more prototypical but wrong
      — so a judge that prefers the typical-but-wrong image is riding the shortcut, the same failure
      certified in Stable Is Not Grounded. The cross-lingual turn
      holds the image pairs fixed and translates only the prompt: if the verdict moves with the language,
      the judge is importing expectations a language-independent meaning would not. It is an applied
      stress test of the modality-centred program's core cut, not a separate thesis spine.
    </p>

    <h2>Roadmap</h2>
    <p>
      Each completed milestone opens its own standalone report.
    </p>
    <ProgressTimeline items={progress} accent="var(--accent-deep-purple)" />

    <h2>Latest progress</h2>
    <p>
      <strong>Report 2</strong> scaled the probe to two model families (Qwen2.5-VL-7B and InternVL3-8B)
      and seven languages, adding Russian, Bengali, and Greek to span resource levels and scripts. Two
      results <strong>replicate across both families</strong>: the bias is
      <strong>attribute-specific</strong> (concentrated on Wealth and social status, near chance for
      Morality and Intellect), and — once lower-resource, distinct-script prompts are added — a
      <strong>language effect the first four languages missed</strong> appears, with Bengali and Greek
      eliciting measurably more bias than English. A back-translation check rules out translation
      quality, and there is no attribute × language interaction: the attribute <em>pattern</em> is
      language-invariant while the overall <em>level</em> is not. Report 1's "language barely moves it"
      now reads as a four-language artifact. Code and figures:
      <a href="https://github.com/xchuan-li/cross_lingual_protobias">cross_lingual_protobias →</a>.
    </p>

    <p>
      Two deeper checks make the effect hard to dismiss. First, it is not a low-level visual artifact:
      the prototypical image always alters one feature — count, colour, size, layout — and
      <strong>colour, the obvious confound, is where the model is least fooled</strong>; the bias is
      strongest exactly when the discriminating cue is hard to perceive. Second, the two families fail on
      largely the <strong>same image pairs</strong> (per-item error correlation r = 0.68), so the
      prototype trap is an objective property of the pair, not a quirk of one model. Together these point
      to a <strong>two-factor account</strong>: the attribute decides whether a visual shortcut exists at
      all — a prototype for wealth and status, none for morality or intellect — and the weakness of the
      signal, whether a hard-to-perceive cue or an unfamiliar language, decides how strongly the model
      takes it.
    </p>

    <p>
      The interactive read below is the original <strong>four-language</strong> picture from Report 1 —
      bias swings sharply by attribute, only mildly by language until Report 2's lower-resource prompts
      are added:
    </p>

    <ProtoBiasDemo client:visible />

    <h2>Research questions</h2>
    <ul>
      <li>
        <strong>RQ1:</strong> Is prototypicality bias consistent across languages when the semantic
        content of the prompt is held fixed?
      </li>
      <li>
        <strong>RQ2:</strong> Are cross-lingual differences stronger in socially sensitive contexts
        such as wealth, intelligence, and profession than in neutral domains such as animals or
        objects?
      </li>
    </ul>

    <h2>AI relation</h2>
    <p>
      The project uses multimodal large language models as evaluators of image-text alignment. The
      object of study is not whether a model gets an item right, but what signal its decision rides on:
      semantic consistency, visual typicality, or a culturally specific prototype activated by the prompt
      language.
    </p>

    <h2>Data</h2>
    <p>
      The project uses the ProtoBias dataset, translating prompts into multiple languages while holding
      the image pairs fixed. The translation is thus an intervention on the linguistic presentation of
      the same semantic task.
    </p>

    <h2>Literature</h2>
    <p class="!text-sm text-[var(--color-text-dim)] !mb-3">Source benchmark and the closest related work.</p>
    <ol>
      <li>Roy, Bhatia &amp; Eger. <a href="https://arxiv.org/abs/2601.04946">ProtoBias</a> — the source benchmark this project extends.</li>
      <li>Hausladen, Knott, Camerer &amp; Perona. <a href="https://arxiv.org/abs/2408.14435">Social Perception of Faces in a Vision-Language Model</a> (FAccT 2025) — bias concentrates unevenly across social-trait dimensions, paralleling our attribute-specific result.</li>
      <li>Al Sahili, Patras &amp; Purver. <a href="https://arxiv.org/abs/2505.14160">Breaking Language Barriers or Reinforcing Bias?</a> (IJCNLP-AACL 2025) — multilingual VLMs show stronger bias than English, largest in low-resource languages; the closest mirror of our language effect.</li>
      <li>Neplenbroek, Bisazza &amp; Fernández. <a href="https://arxiv.org/abs/2406.07243">MBBQ</a> (CoLM 2024) — non-English stereotypes exceed English even after controlling for culture; the text-only precedent, with a control parallel to our back-translation check.</li>
      <li>Friedrich et&nbsp;al. <a href="https://aclanthology.org/2025.acl-long.966/">Multilingual T2I Generation Magnifies Gender Stereotypes</a> (ACL 2025) — cross-lingual bias variation in image generation; a contrasting modality.</li>
    </ol>
  </article>
</Base>
