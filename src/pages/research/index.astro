---
import Base from "../../layouts/Base.astro";
import ProjectGlyph from "../../components/ProjectGlyph.astro";

const coreProjects = [
  {
    title: "Stable Is Not Grounded",
    href: "/research/sc-certification",
    status: "Paper 1 · binary certification",
    color: "var(--accent-coral)",
    glyph: "sc",
    one_line: "Binary certification: is the licensing structure counterfactually load-bearing at all?",
    has_demo: true,
  },
  {
    title: "Isotrace",
    href: "/research/isotrace",
    status: "Paper 2 · path localization",
    color: "var(--accent-teal)",
    glyph: "isotrace",
    one_line: "Path localization — and, in language, which cue a model leans on: morphology, syntax, or context?",
  },
  {
    title: "Causal Inferential Yield",
    href: "/research/ciy",
    status: "Paper 3 · quantification",
    color: "var(--accent-purple)",
    glyph: "ciy",
    one_line: "Quantification: how much genuine linguistic structure does a model use, beyond surface cues?",
  },
];

const sandboxProjects = [
  {
    title: "Mini Causal Models",
    href: "/research/mini-causal-models",
    status: "supporting sandbox",
    color: "var(--accent-slate)",
    glyph: "mcm",
    one_line: "A planted-ground-truth environment where the target is linguistic — a known morpheme or rule — so the methods can be checked against an answer we know.",
  },
];

const extensionProjects = [
  {
    title: "Latent Control States",
    href: "/research/latent-control-states",
    status: "mechanistic extension",
    color: "var(--accent-amber)",
    glyph: "latent",
    one_line: "Mechanistic bridge: does a linguistic distinction (e.g. tense) have an activation-space direction, and is it the same one across forms?",
  },
  {
    title: "Cross-lingual ProtoBias",
    href: "/research/cross-lingual-protobias",
    status: "applied extension",
    color: "var(--accent-indigo)",
    glyph: "protobias",
    one_line: "Applied multilingual/multimodal stress test of semantic grounding versus language- and culture-specific prototype shortcuts.",
  },
];

const emergingProjects = [
  {
    title: "Typological Grounding",
    href: "/research/typological-grounding",
    status: "emerging direction",
    color: "var(--accent-deep-purple)",
    glyph: "xling",
    one_line: "The structure-versus-surface question across languages that encode meaning very differently — through morphology, word order, or context.",
  },
];

const sections = [
  {
    eyebrow: "Core Research Program",
    title: "Hierarchical Causal Evidence",
    description:
      "The core sequence moves from binary certification, to path-level localization, to quantitative grading of causal structure use.",
    projects: coreProjects,
  },
  {
    eyebrow: "Supporting Sandbox",
    title: "Mini Causal Models",
    description:
      "Mini Causal Models are infrastructure for the core program, not a fourth equal core paper.",
    projects: sandboxProjects,
  },
  {
    eyebrow: "Extensions",
    title: "Mechanistic and applied extensions",
    description:
      "These projects keep the same causal-licensing question visible while moving it into activation-space mechanism and multilingual/multimodal evaluation.",
    projects: extensionProjects,
  },
  {
    eyebrow: "Emerging direction",
    title: "Typological grounding",
    description:
      "An early direction taking shape. Languages differ in how much meaning they put into grammar versus leave to context — and that variation is a ready-made testbed for whether a model tracks structure or surface form.",
    projects: emergingProjects,
  },
];
---

<Base
  title="Research · Xiaochuan Li"
  description="One research spine on causal grounding, with mechanistic and applied extensions and an emerging line on language: when is a model's behavior licensed by the structure that should support it?"
>
  <h1 class="text-2xl font-medium tracking-tight mb-2">Research</h1>
  <p class="text-[var(--color-text-muted)] mb-10 max-w-prose">
    My work is organized around one question: <em>when is a model's behavior licensed by the
    minimum causal structure that should support it?</em> The roadmap is a core sequence, with a
    supporting sandbox, two extensions, and an emerging line that carries the same question into
    language.
  </p>

  <div class="space-y-12">
    {
      sections.map((section) => (
        <section>
          <div class="mb-5">
            <p class="text-[11px] uppercase tracking-wider text-[var(--color-text-dim)] font-medium mb-2">
              {section.eyebrow}
            </p>
            <h2 class="text-xl font-medium tracking-tight mb-2">{section.title}</h2>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed max-w-prose">
              {section.description}
            </p>
          </div>

          <div class="divide-y divide-[var(--color-border)]">
            {
              section.projects.map((p) => (
                <a href={p.href} class="block py-6 group hover:bg-[var(--color-surface)] -mx-3 px-3 rounded-md transition-colors">
                  <div class="flex items-center gap-5">
                    <div class="flex-1 min-w-0">
                      <div class="flex justify-between items-baseline gap-3 mb-2">
                        <h3 class="text-base font-medium group-hover:text-[var(--color-accent)]">{p.title}</h3>
                        <span class="text-xs text-[var(--color-text-dim)] whitespace-nowrap">{p.status}</span>
                      </div>
                      <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{p.one_line}</p>
                      {p.has_demo && (
                        <span class="inline-block mt-2 text-[11px] px-2 py-0.5 rounded-full bg-[#E1F5EE] text-[#0F6E56] dark:bg-[#085041]/40 dark:text-[#5DCAA5]">
                          interactive demo ↗
                        </span>
                      )}
                    </div>
                    <div class="proj-glyph-cell" aria-hidden="true">
                      <ProjectGlyph kind={p.glyph} color={p.color} />
                    </div>
                  </div>
                </a>
              ))
            }
          </div>
        </section>
      ))
    }
  </div>
</Base>
