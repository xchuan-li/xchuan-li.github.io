---
import Base from "../../layouts/Base.astro";
import ProjectGlyph from "../../components/ProjectGlyph.astro";
import { projects } from "../../data/research";

// The research page follows the program mainline stated on /research-program:
// what must a system's representations be like to genuinely grasp possibility and
// necessity, rather than merely behave as if it does? Three bodies — Certify (the
// verdict procedure, running in its first domain: causal structure), Toward
// modality (the flagship: the modal-concepts thesis, its typological application,
// and the completed format pilot), and Collaborations (off the mainline, kept
// honestly so). Isotrace is parked: its page stays up, but it is withdrawn from
// this index and from the now-list.
//
// Each card also carries its natural OUTPUT (a paper, a decision experiment, a
// shared workbench, a thesis chapter, a co-authored paper), pulled from the single
// source of truth in data/research.ts by href so positioning never drifts.
const outputByHref = new Map(projects.map((p) => [p.href, p.output]));

const mainlineProjects = [
  {
    title: "GRADUS",
    href: "/research/gradus",
    status: "modal force · pilot running",
    color: "var(--accent-deep-purple)",
    glyph: "xling",
    one_line: "Does a language model represent epistemic modal force — the necessity in must, the possibility in might — or ride the surface modal word? A force direction built from evidence alone: ablate it and might behaves like must, while a base-rate control does nothing. Now extended into a graded epistemic-force dataset. The one project running now, and the precursor the thesis reuses.",
  },
  {
    title: "CAST",
    href: "/research/mini-causal-models",
    status: "workbench · building",
    color: "var(--accent-slate)",
    glyph: "mcm",
    one_line: "Given a modal state — a set of possible worlds and a ◇/□ constraint — CAST projects it to controlled text in English, German, and Chinese, then grades whether the model tracks the surviving world-set or the words. Logical content is fixed by construction, so any cross-language difference is linguistic form alone. The workbench the modal work runs on.",
  },
];

// Collaborations & range — off the modality mainline, kept honestly so.
const collabProjects = [
  {
    title: "Cross-lingual ProtoBias",
    href: "/research/cross-lingual-protobias",
    status: "collaborative",
    color: "var(--accent-indigo)",
    glyph: "protobias",
    one_line: "Does a vision-language model track meaning, or language- and culture-specific prototype shortcuts? A collaborative project extending an established NLP group's paper.",
    has_demo: true,
  },
  {
    title: "HanGL · Surface Hangul, Latent Hanja",
    href: "/research/hangl",
    status: "collaborative · pilot",
    color: "var(--accent-teal-deep)",
    glyph: "hangl",
    one_line: "Do LLMs ground Korean words to their latent Hanja meaning, or stop at the surface script? A wrong-Hanja intervention shows grounding scales with capability: a weak model needs the cue and caves to a wrong one; a strong model does neither. Off the mainline — lexical grounding, not modality — but the clearest demonstration of the program's cross-lingual intervention method.",
    has_demo: true,
  },
  {
    title: "Latent Control States",
    href: "/research/latent-control-states",
    status: "collaborative",
    color: "var(--accent-amber)",
    glyph: "latent",
    one_line: "Does prompt framing shift a causally relevant latent state, or only the surface? A collaborative project, advised by a senior researcher at DFKI.",
  },
];

const sections = [
  {
    eyebrow: "The mainline · running now",
    title: "Modality — the first instance",
    description:
      "The structure-versus-surface question at its sharpest: does a language model represent modal force and a space of alternatives, or the surface modal words? GRADUS is the pilot and dataset running now; CAST is the workbench it runs on. The Master's thesis — modal-concept emergence during training — is the forward center, and gets no card until it has results.",
    projects: mainlineProjects,
  },
  {
    eyebrow: "Collaborations & range · off the mainline",
    title: "Collaborations & range",
    description:
      "Off the modality mainline, kept honestly so: collaborative projects that stress-test structure-versus-surface in other domains — writing systems, prompt framing, multimodal bias — and show the cross-lingual and mechanistic range the program draws on.",
    projects: collabProjects,
  },
];
---

<Base
  title="Research · Xiaochuan Li"
  description="One research program, from possible worlds to language models: certify whether a model's success is licensed by the stated structure, then carry the question to modal concepts and across languages."
>
  <h1 class="text-2xl font-medium tracking-tight mb-2">Research</h1>
  <p class="text-[var(--color-text-muted)] mb-4 max-w-prose">
    My work is one research program, not a list of ideas: <em>what must a system's representations
    be like for it to genuinely grasp possibility and necessity — rather than merely behave as if
    it does?</em> I ask it of language models, with a method inherited down one line — Leibniz's
    possible worlds, Kripke's frames, Kratzer's modal bases, Leahy &amp; Carey's
    possession-versus-performance tests. State the licensing structure formally, then test whether
    success actually depends on it, under intervention and on tasks engineered so that surface
    correlates must fail. The full lineage is on the
    <a href="/research-program" class="text-[var(--color-accent)] hover:opacity-75">program page</a>.
  </p>
  <p class="text-sm text-[var(--color-text-dim)] mb-10 max-w-prose leading-relaxed">
    Each project is tagged with its <em>natural output</em> — not everything aims at a paper. Some
    are papers; others are a <strong>decision experiment</strong> that earns a paper only if it
    passes a falsifiability test, a <strong>shared workbench</strong> other projects run on, a
    completed pilot that becomes a <strong>thesis chapter</strong>, or a defined contribution to a
    collaborator's paper.
  </p>

  <div class="space-y-12">
    {
      sections.map((section) => (
        <section>
          <div class="mb-5">
            <p class="text-[11px] uppercase tracking-wider text-[var(--color-text-dim)] font-medium mb-2">
              {section.eyebrow}
            </p>
            <h2 class="text-xl font-medium tracking-tight mb-2">{section.title}</h2>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed max-w-prose">
              {section.description}
            </p>
          </div>

          <div class="divide-y divide-[var(--color-border)]">
            {
              section.projects.map((p) => (
                <a href={p.href} class="block py-6 group hover:bg-[var(--color-surface)] -mx-3 px-3 rounded-md transition-colors">
                  <div class="flex items-center gap-5">
                    <div class="flex-1 min-w-0">
                      <div class="flex justify-between items-baseline gap-3 mb-2">
                        <h3 class="text-base font-medium group-hover:text-[var(--color-accent)]">{p.title}</h3>
                        {outputByHref.get(p.href) && (
                          <span class="proj-output" style={`--pc: ${p.color}`}>{outputByHref.get(p.href)}</span>
                        )}
                      </div>
                      <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{p.one_line}</p>
                      <div class="mt-2.5 flex items-center gap-3 flex-wrap">
                        <span class="proj-state">{p.status}</span>
                        {p.has_demo && (
                          <span class="inline-block text-[11px] font-medium px-2 py-0.5 rounded-full bg-[#c8ece0] text-[#07533e] dark:bg-[#0e4c3d] dark:text-[#74d6b4]">
                            interactive demo ↗
                          </span>
                        )}
                      </div>
                    </div>
                    <div class="proj-glyph-cell" aria-hidden="true">
                      <ProjectGlyph kind={p.glyph} color={p.color} />
                    </div>
                  </div>
                </a>
              ))
            }
          </div>
        </section>
      ))
    }
  </div>
</Base>

<style>
  /* Natural-output pill (positioning) + state line, per project. The pill is
     tinted with each project's accent so it reads with its glyph. */
  .proj-output {
    flex: none;
    font-family: var(--font-mono);
    font-size: 9.5px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    white-space: nowrap;
    padding: 2px 8px;
    border-radius: 999px;
    color: color-mix(in srgb, var(--pc) 72%, var(--color-text));
    border: 1px solid color-mix(in srgb, var(--pc) 38%, var(--color-border));
    background: color-mix(in srgb, var(--pc) 8%, transparent);
  }
  .proj-state {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }
</style>
