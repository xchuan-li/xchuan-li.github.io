---
import Base from "../../layouts/Base.astro";
import ProjectGlyph from "../../components/ProjectGlyph.astro";
import { projects } from "../../data/research";

// The research page follows the converged main line: computational linguistics,
// with causal-inference rigor as the method. Two forward bodies — Certify (does the
// model use the licensing structure at all) and Across languages (the typological
// application, where the differentiation is) — plus a demoted body of completed and
// collaborative work that shows range without being the center. Isotrace and a
// quantitative yield measure are named as horizon, not billed as running.
//
// Each card also carries its natural OUTPUT (a paper, a decision experiment, a
// shared workbench, a thesis chapter, a co-authored paper), pulled from the single
// source of truth in data/research.ts by href so positioning never drifts.
const outputByHref = new Map(projects.map((p) => [p.href, p.output]));

const certifyProjects = [
  {
    title: "Stable Is Not Grounded",
    href: "/research/sc-certification",
    status: "certify · in submission",
    color: "var(--accent-coral)",
    glyph: "sc",
    one_line: "Certify whether the structure that licenses an inference is load-bearing — stable-correct behavior isn't grounding unless it survives shortcut-severing audits.",
    has_demo: true,
  },
  {
    title: "MiniCausalLang",
    href: "/research/mini-causal-models",
    status: "workbench · building",
    color: "var(--accent-slate)",
    glyph: "mcm",
    one_line: "The foundation: a language-to-causal-graph workbench that makes grammatical structure, the inference it licenses, and interventions on it observable — so the certification cut is decidable by construction. Built next, after the paper.",
  },
  {
    title: "Isotrace",
    href: "/research/isotrace",
    status: "localize · design horizon",
    color: "var(--accent-teal)",
    glyph: "isotrace",
    one_line: "Localize which linguistic operation carries the inference — morphology, word order, or context — via path-encoded minimal pairs. A design-stage horizon, not yet running.",
  },
];

const crosslingualProjects = [
  {
    title: "HanGL · Surface Hangul, Latent Hanja",
    href: "/research/hangl",
    status: "collaborative · pilot",
    color: "var(--accent-teal-deep)",
    glyph: "hangl",
    one_line: "Do LLMs ground Korean words to their latent Hanja meaning, or stop at the surface script? A wrong-Hanja intervention shows grounding scales with capability — a weak model needs the cue and caves to a wrong one; a strong model does neither. The empirical second piece.",
    has_demo: true,
  },
  {
    title: "Typological Grounding",
    href: "/research/typological-grounding",
    status: "exploratory · horizon",
    color: "var(--accent-deep-purple)",
    glyph: "xling",
    one_line: "The flagship application: the same inference re-encoded by morphology, word order, or context — does grounding survive the re-encoding, or only the surface habits of each language?",
  },
];

const otherProjects = [
  {
    title: "Arrowhead",
    href: "/research/arrowhead",
    status: "MSc thesis · complete",
    color: "var(--accent-champagne)",
    glyph: "latent",
    one_line: "My completed MSc-thesis pilot on a real LLM: a causal-direction feature that is encoded, steerable, and genuinely causal — yet redundantly distributed across layers. Demonstrated mechanistic range, not the center of the forward program.",
    has_demo: true,
  },
  {
    title: "Latent Control States",
    href: "/research/latent-control-states",
    status: "collaborative",
    color: "var(--accent-amber)",
    glyph: "latent",
    one_line: "Does prompt framing shift a causally relevant latent state, or only the surface? A collaborative project, advised by a senior researcher at DFKI.",
  },
  {
    title: "Cross-lingual ProtoBias",
    href: "/research/cross-lingual-protobias",
    status: "collaborative",
    color: "var(--accent-indigo)",
    glyph: "protobias",
    one_line: "Does a vision-language model track meaning, or language- and culture-specific prototype shortcuts? A collaborative project extending an established NLP group's paper.",
    has_demo: true,
  },
];

const sections = [
  {
    eyebrow: "Behaviour · on a synthetic sandbox",
    title: "Certify",
    description:
      "Does the model use the linguistic structure that licenses an inference, or only a surface cue? Non-circular behavioral certification, with a workbench that turns grammar into causal variables and interventions to sever the shortcuts.",
    projects: certifyProjects,
  },
  {
    eyebrow: "Cross-lingual · typology",
    title: "Across languages",
    description:
      "Where the method meets linguistic typology — the same inference re-encoded by each language's grammar. This is the application the program builds toward, and where my multilingual background does the work.",
    projects: crosslingualProjects,
  },
  {
    eyebrow: "Completed & collaborative",
    title: "Other work",
    description:
      "A completed MSc-thesis pilot inside a real model, and collaborative projects that stress-test the same question across mechanism and modality — range and rigor, not the center of the forward program.",
    projects: otherProjects,
  },
];
---

<Base
  title="Research · Xiaochuan Li"
  description="Computational linguistics with causal-inference rigor: certify whether AI models use the linguistic structure that licenses an inference or only a surface correlate, and test whether it holds across languages."
>
  <h1 class="text-2xl font-medium tracking-tight mb-2">Research</h1>
  <p class="text-[var(--color-text-muted)] mb-4 max-w-prose">
    My work is one program in <strong>computational linguistics</strong>, not a list of ideas:
    <em>how does linguistic structure support reasoning, and do AI systems actually use that
    structure — or a surface correlate of it?</em> I test it with causal-inference rigor —
    controlled interventions and negative controls: first certifying whether the structure that
    licenses an inference is load-bearing, then carrying that test across languages, where each
    grammar re-encodes the same inference. Mechanistic tests inside real models are a complement,
    not the center. It is all part of a broader
    <a href="/research-program" class="text-[var(--color-accent)] hover:opacity-75">research program</a>,
    traced from Leibniz's possible worlds to concept attribution in language models.
  </p>
  <p class="text-sm text-[var(--color-text-dim)] mb-10 max-w-prose leading-relaxed">
    Each project is tagged with its <em>natural output</em> — not everything aims at a paper of its
    own. Some are papers; others are a <strong>decision experiment</strong> that earns a paper only
    if it passes a falsifiability test, a <strong>shared workbench</strong> other projects run on, a
    completed pilot that becomes a <strong>thesis chapter</strong>, or a defined contribution to a
    collaborator's paper.
  </p>

  <div class="space-y-12">
    {
      sections.map((section) => (
        <section>
          <div class="mb-5">
            <p class="text-[11px] uppercase tracking-wider text-[var(--color-text-dim)] font-medium mb-2">
              {section.eyebrow}
            </p>
            <h2 class="text-xl font-medium tracking-tight mb-2">{section.title}</h2>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed max-w-prose">
              {section.description}
            </p>
          </div>

          <div class="divide-y divide-[var(--color-border)]">
            {
              section.projects.map((p) => (
                <a href={p.href} class="block py-6 group hover:bg-[var(--color-surface)] -mx-3 px-3 rounded-md transition-colors">
                  <div class="flex items-center gap-5">
                    <div class="flex-1 min-w-0">
                      <div class="flex justify-between items-baseline gap-3 mb-2">
                        <h3 class="text-base font-medium group-hover:text-[var(--color-accent)]">{p.title}</h3>
                        {outputByHref.get(p.href) && (
                          <span class="proj-output" style={`--pc: ${p.color}`}>{outputByHref.get(p.href)}</span>
                        )}
                      </div>
                      <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{p.one_line}</p>
                      <div class="mt-2.5 flex items-center gap-3 flex-wrap">
                        <span class="proj-state">{p.status}</span>
                        {p.has_demo && (
                          <span class="inline-block text-[11px] font-medium px-2 py-0.5 rounded-full bg-[#c8ece0] text-[#07533e] dark:bg-[#0e4c3d] dark:text-[#74d6b4]">
                            interactive demo ↗
                          </span>
                        )}
                      </div>
                    </div>
                    <div class="proj-glyph-cell" aria-hidden="true">
                      <ProjectGlyph kind={p.glyph} color={p.color} />
                    </div>
                  </div>
                </a>
              ))
            }
          </div>
        </section>
      ))
    }
  </div>
</Base>

<style>
  /* Natural-output pill (positioning) + state line, per project. The pill is
     tinted with each project's accent so it reads with its glyph. */
  .proj-output {
    flex: none;
    font-family: var(--font-mono);
    font-size: 9.5px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    white-space: nowrap;
    padding: 2px 8px;
    border-radius: 999px;
    color: color-mix(in srgb, var(--pc) 72%, var(--color-text));
    border: 1px solid color-mix(in srgb, var(--pc) 38%, var(--color-border));
    background: color-mix(in srgb, var(--pc) 8%, transparent);
  }
  .proj-state {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }
</style>
