---
import Base from "../../layouts/Base.astro";
import ProjectGlyph from "../../components/ProjectGlyph.astro";

const coreProjects = [
  {
    title: "Stable Is Not Grounded",
    href: "/research/sc-certification",
    status: "Paper 1 · certification",
    color: "var(--accent-coral)",
    glyph: "sc",
    one_line: "Binary certification: is the licensing structure counterfactually load-bearing at all?",
    has_demo: true,
  },
  {
    title: "Isotrace",
    href: "/research/isotrace",
    status: "Paper 2 · localization",
    color: "var(--accent-teal)",
    glyph: "isotrace",
    one_line: "Path localization — and, in language, which cue a model leans on: morphology, syntax, or context?",
  },
  {
    title: "Causal Inferential Yield",
    href: "/research/ciy",
    status: "Paper 3 · quantification",
    color: "var(--accent-purple)",
    glyph: "ciy",
    one_line: "Quantification: how much genuine linguistic structure does a model use, beyond surface cues?",
  },
];

const frontierProjects = [
  {
    title: "Typological Grounding",
    href: "/research/typological-grounding",
    status: "application frontier",
    color: "var(--accent-deep-purple)",
    glyph: "xling",
    one_line: "Where the three methods meet linguistic typology: the same meaning re-encoded by morphology, word order, or context, and whether a model tracks the structure or the surface.",
  },
  {
    title: "HanGL · Surface Hangul, Latent Hanja",
    href: "/research/hangl",
    status: "application frontier · empirical pilot",
    color: "var(--accent-teal-deep)",
    glyph: "hangl",
    one_line: "The structure-versus-surface question run on real LLMs: do they ground Korean Sino-Korean words to latent Hanja meaning or surface script? A causal wrong-Hanja test shows latent grounding scales with model capability.",
  },
];

const supportProjects = [
  {
    title: "MiniCausalLang",
    href: "/research/mini-causal-models",
    status: "validation sandbox",
    color: "var(--accent-slate)",
    glyph: "mcm",
    one_line: "A planted-ground-truth sandbox for testing whether linguistic behavior is structurally grounded or surface-driven — the methods checked against an answer we know.",
  },
  {
    title: "Latent Control States",
    href: "/research/latent-control-states",
    status: "extension · mechanistic",
    color: "var(--accent-amber)",
    glyph: "latent",
    one_line: "Does a linguistic distinction such as tense have an activation-space direction, and is it the same one across forms?",
  },
  {
    title: "Cross-lingual ProtoBias",
    href: "/research/cross-lingual-protobias",
    status: "extension · applied",
    color: "var(--accent-indigo)",
    glyph: "protobias",
    one_line: "An applied multimodal stress test of semantic grounding versus language- and culture-specific prototype shortcuts.",
  },
];

const sections = [
  {
    eyebrow: "The thesis · three method contributions",
    title: "Certify · localize · quantify",
    description:
      "One program, not a list of ideas: certify whether behavior is licensed by genuine structure, localize where that structure is used, and quantify how much of it the model relies on — developed and tested through linguistic structure.",
    projects: coreProjects,
  },
  {
    eyebrow: "Application frontier",
    title: "Typological grounding",
    description:
      "Where the three methods converge on linguistic typology — the same meaning re-encoded by each language's grammar, a ready-made test of structure versus surface.",
    projects: frontierProjects,
  },
  {
    eyebrow: "Support",
    title: "Validation & extensions",
    description:
      "Infrastructure and side studies the program leans on — a validation sandbox and two extensions — not separate research directions.",
    projects: supportProjects,
  },
];
---

<Base
  title="Research · Xiaochuan Li"
  description="Causal interpretability through linguistic structure: three method contributions — certify, localize, quantify whether a model's behavior is licensed by genuine structure — with a validation sandbox and extensions in support."
>
  <h1 class="text-2xl font-medium tracking-tight mb-2">Research</h1>
  <p class="text-[var(--color-text-muted)] mb-10 max-w-prose">
    My work is one program, not a list of ideas: <em>is a model's behavior licensed by the genuine
    structure, or by a surface cue that merely correlates with it?</em> Three method contributions —
    certify, localize, quantify — developed through linguistic structure, with a validation sandbox
    and two extensions in support.
  </p>

  <div class="space-y-12">
    {
      sections.map((section) => (
        <section>
          <div class="mb-5">
            <p class="text-[11px] uppercase tracking-wider text-[var(--color-text-dim)] font-medium mb-2">
              {section.eyebrow}
            </p>
            <h2 class="text-xl font-medium tracking-tight mb-2">{section.title}</h2>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed max-w-prose">
              {section.description}
            </p>
          </div>

          <div class="divide-y divide-[var(--color-border)]">
            {
              section.projects.map((p) => (
                <a href={p.href} class="block py-6 group hover:bg-[var(--color-surface)] -mx-3 px-3 rounded-md transition-colors">
                  <div class="flex items-center gap-5">
                    <div class="flex-1 min-w-0">
                      <div class="flex justify-between items-baseline gap-3 mb-2">
                        <h3 class="text-base font-medium group-hover:text-[var(--color-accent)]">{p.title}</h3>
                        <span class="text-xs text-[var(--color-text-dim)] whitespace-nowrap">{p.status}</span>
                      </div>
                      <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{p.one_line}</p>
                      {p.has_demo && (
                        <span class="inline-block mt-2 text-[11px] font-medium px-2 py-0.5 rounded-full bg-[#c8ece0] text-[#07533e] dark:bg-[#0e4c3d] dark:text-[#74d6b4]">
                          interactive demo ↗
                        </span>
                      )}
                    </div>
                    <div class="proj-glyph-cell" aria-hidden="true">
                      <ProjectGlyph kind={p.glyph} color={p.color} />
                    </div>
                  </div>
                </a>
              ))
            }
          </div>
        </section>
      ))
    }
  </div>
</Base>
