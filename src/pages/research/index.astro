---
import Base from "../../layouts/Base.astro";
import ProjectGlyph from "../../components/ProjectGlyph.astro";
import { projects } from "../../data/research";

// The research page follows the program mainline stated on /research-program:
// does a language model represent the structure a theory of meaning assigns, or
// only its surface? The modality mainline is the spine — MODUS (the thesis: what
// modal force is made of) with GRADUS (its graded ruler), ORDO (one ordering
// source across generics and modals, or two?), and CAST (the workbench they run
// on). Then range & collaborations (off the mainline, kept honestly so).
//
// Each card also carries its natural OUTPUT (a paper, a decision experiment, a
// shared workbench, a thesis chapter, a co-authored paper), pulled from the single
// source of truth in data/research.ts by href so positioning never drifts.
const outputByHref = new Map(projects.map((p) => [p.href, p.output]));

// Cards render from these curated arrays (not research.ts directly), so the /research
// spine can be sequenced by hand. `href` omitted → the card is not a link yet
// (MODUS/ORDO have no dedicated page). `output` is the natural-deliverable pill.
// The three case studies are the core: one kind of word each, all places where
// the logic of natural language looks unlike the logic of the logic books.
const caseStudies = [
  {
    title: "MODUS: Modality",
    subtitle: "is <em>must</em> a set of worlds, or a degree of certainty?",
    href: "/research/modus",
    output: "Thesis",
    status: "modals · thesis · pilot run",
    color: "var(--accent-deep-purple)",
    glyph: "xling",
    one_line: "Modals, and the Master's thesis. Is modal force a quantification over a set of possible worlds (Kratzer) or a single degree of certainty (Lassiter)? Judgment data cannot separate the two; a model's representational format under intervention can. A pilot already reads a force direction built from evidence alone, with no modal word present: ablate it on a might sentence and its certainty jumps toward must, while a base-rate control does not.",
  },
  {
    title: "HanGL: Morphology",
    subtitle: "composed, or memorized?",
    href: "/research/hangl",
    output: "Paper",
    status: "compounds · Sino-Korean · pilot done",
    color: "var(--accent-teal-deep)",
    glyph: "hangl",
    has_demo: true,
    one_line: "Compounds. Is a Sino-Korean word's meaning composed from its morphemes (學 + 校 → school) or memorized whole? Hangul hides the morphemes; Hanja is the answer key the model never sees. The word-level cut of the question, with an existing human-psycholinguistics literature to mirror it against.",
  },
  {
    title: "ORDO: Genericity",
    subtitle: "do “birds fly” and “you should pay” run on one machine?",
    href: "/research/ordo",
    output: "Paper",
    status: "generics · in design",
    color: "var(--accent-coral)",
    glyph: "mcm",
    one_line: "Generics. “Birds fly” is not “all birds fly”: a penguin does not break it. That default-with-exceptions is an inference classical logic cannot state. Do generics and modals share one ordering-source mechanism for defaults, or two? A layered novelty-of-exception design where either outcome is a real finding.",
  },
];

// One collaboration, kept honestly separate from the three case studies.
const collabProjects = [
  {
    title: "Cross-lingual ProtoBias",
    subtitle: "meaning, or cultural prototype?",
    href: "/research/cross-lingual-protobias",
    output: "Co-authored paper",
    status: "collaborative",
    color: "var(--accent-indigo)",
    glyph: "protobias",
    has_demo: true,
    one_line: "Does a vision-language model track meaning, or language- and culture-specific prototype shortcuts? A collaborative project extending an established NLP group's paper.",
  },
];

const sections = [
  {
    eyebrow: "The core · three kinds of word",
    title: "Three case studies, one question",
    description:
      "Each case study is a kind of word where the logic of natural language looks unlike the logic of the logic books: modals (necessity and possibility), compounds (meaning built from parts), and generics (defaults that tolerate exceptions). Same question, same method, three incisions. MODUS is the Master's thesis; the question runs on to conditionals and quantifiers beyond these three.",
    projects: caseStudies,
  },
  {
    eyebrow: "Alongside · collaboration",
    title: "Collaboration",
    description:
      "One collaborative project in another domain, kept honestly separate from the three case studies: multimodal prototype bias, extending an established NLP group's work.",
    projects: collabProjects,
  },
];
---

<Base
  title="Research · Xiaochuan Li"
  description="One research program on where the logic of natural language departs from the logic of the logic books, studied through three kinds of word: modals (the thesis, MODUS), compounds (HanGL), and generics (ORDO)."
>
  <h1 class="text-2xl font-medium tracking-tight mb-2">Research</h1>
  <p class="text-[var(--color-text-muted)] mb-4 max-w-prose">
    My work is one research program, not a list of ideas. The question the whole site hangs from:
    <em>is the logic of natural language the logic of the logicians?</em> The method is constant: take
    a theory of linguistic meaning and ask what observable trace it would have to leave
    <em>if it were true</em>, then let evidence, not argument, decide. I test it through three case
    studies, one per kind of word where natural language's logic looks unlike the textbook's:
    <strong>modals</strong> (the thesis), <strong>compounds</strong>, and <strong>generics</strong>.
    The criterion comes down one line: Leibniz's possible worlds, Kripke's frames, Kratzer's modal
    bases, Leahy &amp; Carey's possession-versus-performance tests. State the licensing structure
    formally, then read whether success actually depends on it, under intervention and on tasks
    engineered so that surface correlates must fail. The question runs on to conditionals, quantifiers,
    and beyond. The full lineage is on the
    <a href="/motivation" class="text-[var(--color-accent)] hover:opacity-75">motivation page</a>.
  </p>
  <p class="text-sm text-[var(--color-text-dim)] mb-10 max-w-prose leading-relaxed">
    Each project is tagged with its <em>natural output</em>, and not everything aims at a paper. Some
    are papers; others are a <strong>decision experiment</strong> that earns a paper only if it
    passes a falsifiability test, a <strong>shared workbench</strong> other projects run on, a
    completed pilot that becomes a <strong>thesis chapter</strong>, or a defined contribution to a
    collaborator's paper.
  </p>

  <div class="space-y-12">
    {
      sections.map((section) => (
        <section>
          <div class="mb-5">
            <p class="text-[11px] uppercase tracking-wider text-[var(--color-text-dim)] font-medium mb-2">
              {section.eyebrow}
            </p>
            <h2 class="text-xl font-medium tracking-tight mb-2">{section.title}</h2>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed max-w-prose">
              {section.description}
            </p>
          </div>

          <div class="divide-y divide-[var(--color-border)]">
            {
              section.projects.map((p) => {
                const Tag = p.href ? "a" : "div";
                const output = p.output ?? outputByHref.get(p.href);
                return (
                  <Tag href={p.href} class="block py-6 group hover:bg-[var(--color-surface)] -mx-3 px-3 rounded-md transition-colors">
                    <div class="flex items-center gap-5">
                      <div class="flex-1 min-w-0">
                        <div class="flex justify-between items-baseline gap-3 mb-1">
                          <h3 class="text-base font-medium group-hover:text-[var(--color-accent)]">
                            {p.title}
                            {!p.href && <span class="proj-soon">page soon</span>}
                          </h3>
                          {output && (
                            <span class="proj-output" style={`--pc: ${p.color}`}>{output}</span>
                          )}
                        </div>
                        {p.subtitle && <p class="proj-subtitle" set:html={p.subtitle} />}
                        <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mt-1.5">{p.one_line}</p>
                        <div class="mt-2.5 flex items-center gap-3 flex-wrap">
                          <span class="proj-state">{p.status}</span>
                          {p.has_demo && (
                            <span class="inline-block text-[11px] font-medium px-2 py-0.5 rounded-full bg-[#c8ece0] text-[#07533e] dark:bg-[#0e4c3d] dark:text-[#74d6b4]">
                              interactive demo ↗
                            </span>
                          )}
                        </div>
                      </div>
                      <div class="proj-glyph-cell" aria-hidden="true">
                        <ProjectGlyph kind={p.glyph} color={p.color} />
                      </div>
                    </div>
                  </Tag>
                );
              })
            }
          </div>
        </section>
      ))
    }
  </div>
</Base>

<style>
  /* Natural-output pill (positioning) + state line, per project. The pill is
     tinted with each project's accent so it reads with its glyph. */
  .proj-output {
    flex: none;
    font-family: var(--font-mono);
    font-size: 9.5px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    white-space: nowrap;
    padding: 2px 8px;
    border-radius: 999px;
    color: color-mix(in srgb, var(--pc) 72%, var(--color-text));
    border: 1px solid color-mix(in srgb, var(--pc) 38%, var(--color-border));
    background: color-mix(in srgb, var(--pc) 8%, transparent);
  }
  .proj-state {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }
  /* The plain-language subtitle under each codename — tells MODUS from ORDO at a glance. */
  .proj-subtitle {
    font-size: 13.5px;
    font-style: italic;
    color: var(--color-text);
    opacity: 0.82;
    line-height: 1.4;
  }
  .proj-subtitle em { font-style: normal; }
  /* Marks a card whose dedicated page is not written yet (MODUS/ORDO). */
  .proj-soon {
    margin-left: 0.5rem;
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 1px 6px;
    vertical-align: middle;
    white-space: nowrap;
  }
</style>
