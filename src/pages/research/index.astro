---
import Base from "../../layouts/Base.astro";
import ProjectGlyph from "../../components/ProjectGlyph.astro";
import CaseFigure from "../../components/CaseFigure.astro";
import { projects } from "../../data/research";

// The research page states the modality program: how linguistic modality
// structures the space of possibilities for inference. The spine is the thesis in
// two arms — MODUS (the language-model arm: what modal force is made of, read
// under intervention) and the human arm (the same theory, adjudicated in the mind
// through a shared paradigm). Then earlier & methodological collaborations (off
// the mainline, kept honestly so).
//
// Each card also carries its natural OUTPUT (a paper, a decision experiment, a
// shared workbench, a thesis chapter, a co-authored paper), pulled from the single
// source of truth in data/research.ts by href so positioning never drifts.
const outputByHref = new Map(projects.map((p) => [p.href, p.output]));

// Cards render from these curated arrays (not research.ts directly), so the /research
// spine can be sequenced by hand. `href` omitted → the card is not a link yet
// (the human arm has no dedicated page). `output` is the natural-deliverable pill.
// The thesis is the core: one theory of modal force, one set of predictions,
// adjudicated in two systems — a language model and the human mind.
const arms = [
  {
    title: "MODUS: the language-model arm",
    subtitle: "is <em>must</em> a set of worlds, or a degree of certainty?",
    href: "/research/modus",
    output: "Thesis",
    status: "modal force · LM arm · pilot run",
    color: "var(--accent-deep-purple)",
    glyph: "xling",
    fig: "modus",
    one_line: "The Master's thesis, on a system I can open up. Is modal force a quantification over a set of possible worlds (Kratzer) or a single degree of certainty (Lassiter)? Judgment data cannot separate the two; a model's representational format under intervention can. A pilot already reads a force direction built from evidence alone, with no modal word present: ablate it on a might sentence and its certainty jumps toward must, while a base-rate control does not.",
  },
  {
    title: "The human arm",
    subtitle: "the same modal contrast, put to people",
    output: "Thesis",
    status: "human arm · shared paradigm · in planning",
    color: "var(--accent-slate)",
    glyph: "latent",
    one_line: "The same theory, adjudicated in the mind. The very modal contrast the model turns on — evidence-driven force, worlds versus degree — put to people through a shared behavioural paradigm, drawing on the developmental literature on modal cognition (Leahy & Carey). Where the two systems agree, and where the model departs from the mind, both constrain the theory. In planning, co-designed from the cognitive-developmental side.",
  },
];

// Collaborations: contributions to others' projects, kept separate from the
// the thesis. Two sentences each, emphasising what I did. No figures,
// no dedicated pages.
const collaborations = [
  {
    name: "Latent Control States",
    org: "DFKI",
    text: "Does prompt framing shift a causally relevant latent state, or only the output? My contribution: a utilitarian minimal-pair probe — dilemma × benefit-size × framing — testing whether the choice tracks the real stakes or only surface pressure.",
  },
  {
    name: "Cross-lingual ProtoBias",
    org: "an established NLP group",
    text: "Does a vision-language model track meaning, or language- and culture-specific prototype shortcuts? My contribution: the cross-lingual evaluation across seven languages that extends the group's forthcoming paper.",
    href: "https://github.com/xchuan-li/cross_lingual_protobias",
    hrefLabel: "GitHub ↗",
  },
];

const sections = [
  {
    eyebrow: "The thesis · two arms",
    title: "One theory of modality, two systems",
    description:
      "The Master's thesis takes one question about modal force — a set of possible worlds, or a degree of certainty? — and derives a single set of predictions from it, then adjudicates them in two systems at once: a language model, opened up under intervention, and the human mind, through a shared behavioural paradigm. Neither settles it alone; together they constrain the theory. Modality is where I build depth — the same method runs on to conditionals, counterfactuals, and quantifiers.",
    projects: arms,
  },
];
---

<Base
  title="Research · Xiaochuan Li"
  description="The experimental and computational semantics of modal reasoning: how linguistic modality structures the space of possibilities for inference, with one set of predictions from formal semantics tested in both the human mind and language models."
>
  <h1 class="text-2xl font-medium tracking-tight mb-2">Research</h1>
  <p class="text-[var(--color-text-muted)] mb-4 max-w-prose">
    My work is one research program, not a list of ideas: the <strong>experimental and computational
    semantics of modal reasoning</strong> — how linguistic modality (<em>may</em>, <em>must</em>,
    <em>might</em>) structures the space of possibilities we reason over. The method is constant: take
    a theory of modal meaning and ask what observable trace it would have to leave <em>if it were
    true</em>, then let evidence, not argument, decide. The criterion comes down one line: Leibniz's
    possible worlds, Kripke's frames, Kratzer's modal bases, Leahy &amp; Carey's
    possession-versus-performance tests. State the licensing structure formally, then read whether
    success actually depends on it — in <strong>two systems at once</strong>, a language model under
    intervention and the human mind through a shared paradigm. Modality is where I build depth; the
    same method runs on to conditionals, counterfactuals, and quantifiers. The full lineage is on the
    <a href="/motivation" class="text-[var(--color-accent)] hover:opacity-75">motivation page</a>.
  </p>
  <p class="text-sm text-[var(--color-text-dim)] mb-10 max-w-prose leading-relaxed">
    Each project is tagged with its <em>natural output</em>, and not everything aims at a paper. Some
    are papers; others are a <strong>decision experiment</strong> that earns a paper only if it
    passes a falsifiability test, a <strong>shared workbench</strong> other projects run on, a
    completed pilot that becomes a <strong>thesis chapter</strong>, or a defined contribution to a
    collaborator's paper.
  </p>

  <div class="space-y-12">
    {
      sections.map((section) => (
        <section>
          <div class="mb-5">
            <p class="text-[11px] uppercase tracking-wider text-[var(--color-text-dim)] font-medium mb-2">
              {section.eyebrow}
            </p>
            <h2 class="text-xl font-medium tracking-tight mb-2">{section.title}</h2>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed max-w-prose">
              {section.description}
            </p>
          </div>

          <div class="divide-y divide-[var(--color-border)]">
            {
              section.projects.map((p) => {
                const Tag = p.href ? "a" : "div";
                const output = p.output ?? outputByHref.get(p.href);
                return (
                  <Tag href={p.href} class="block py-6 group hover:bg-[var(--color-surface)] -mx-3 px-3 rounded-md transition-colors">
                    <div class="flex items-center gap-5">
                      <div class="flex-1 min-w-0">
                        <div class="flex justify-between items-baseline gap-3 mb-1">
                          <h3 class="text-base font-medium group-hover:text-[var(--color-accent)]">
                            {p.title}
                            {!p.href && <span class="proj-soon">page soon</span>}
                          </h3>
                          {output && (
                            <span class="proj-output" style={`--pc: ${p.color}`}>{output}</span>
                          )}
                        </div>
                        {p.subtitle && <p class="proj-subtitle" set:html={p.subtitle} />}
                        <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mt-1.5">{p.one_line}</p>
                        <div class="mt-2.5 flex items-center gap-3 flex-wrap">
                          <span class="proj-state">{p.status}</span>
                          {p.has_demo && (
                            <span class="inline-block text-[11px] font-medium px-2 py-0.5 rounded-full bg-[#c8ece0] text-[#07533e] dark:bg-[#0e4c3d] dark:text-[#74d6b4]">
                              interactive demo ↗
                            </span>
                          )}
                        </div>
                      </div>
                      <div class="proj-glyph-cell" aria-hidden="true">
                        {p.fig ? <CaseFigure kind={p.fig} color={p.color} /> : <ProjectGlyph kind={p.glyph} color={p.color} />}
                      </div>
                    </div>
                  </Tag>
                );
              })
            }
          </div>
        </section>
      ))
    }
  </div>

  <section class="mt-14">
    <div class="mb-5">
      <p class="text-[11px] uppercase tracking-wider text-[var(--color-text-dim)] font-medium mb-2">
        Alongside · methodological training
      </p>
      <h2 class="text-xl font-medium tracking-tight mb-2">Earlier &amp; methodological work</h2>
      <p class="text-sm text-[var(--color-text-muted)] leading-relaxed max-w-prose">
        Two collaborations that gave me the engineering the modality program runs on — controlled
        evaluation, intervention inside a model, and the analysis to read the result. Methodological
        training, not the identity. What I did, in two lines.
      </p>
    </div>
    <ul class="list-none p-0 m-0 space-y-5">
      {
        collaborations.map((c) => (
          <li>
            <p class="text-[15px] font-medium text-[var(--color-text)]">
              {c.name}<span class="font-normal text-[var(--color-text-dim)]"> · {c.org}</span>
            </p>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed max-w-prose mt-1">{c.text}</p>
            {c.href && (
              <p class="text-xs mt-1.5">
                <a href={c.href} class="text-[var(--color-accent)] hover:underline">{c.hrefLabel}</a>
              </p>
            )}
          </li>
        ))
      }
    </ul>
  </section>
</Base>

<style>
  /* Natural-output pill (positioning) + state line, per project. The pill is
     tinted with each project's accent so it reads with its glyph. */
  .proj-output {
    flex: none;
    font-family: var(--font-mono);
    font-size: 9.5px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    white-space: nowrap;
    padding: 2px 8px;
    border-radius: 999px;
    color: color-mix(in srgb, var(--pc) 72%, var(--color-text));
    border: 1px solid color-mix(in srgb, var(--pc) 38%, var(--color-border));
    background: color-mix(in srgb, var(--pc) 8%, transparent);
  }
  .proj-state {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }
  /* The plain-language subtitle under each codename — tells the arms apart at a glance. */
  .proj-subtitle {
    font-size: 13.5px;
    font-style: italic;
    color: var(--color-text);
    opacity: 0.82;
    line-height: 1.4;
  }
  .proj-subtitle em { font-style: normal; }
  /* Marks a card whose dedicated page is not written yet (the human arm). */
  .proj-soon {
    margin-left: 0.5rem;
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 1px 6px;
    vertical-align: middle;
    white-space: nowrap;
  }
</style>
