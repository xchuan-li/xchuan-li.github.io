---
// HeroSentence — the homepage hero emblem: how a sentence comes to mean, in
// three layers, revealed once (calm, not a slot machine).
//
// One sentence — "Every dog barked" — read at three strata:
//   1 WORD        each word carries an atomic meaning (∀ · dog · bark)
//   2 STRUCTURE   grammar makes those meanings react into one proposition
//   3 INFERENCE   that proposition becomes a step in reasoning (⊨)
//
// The animation reveals the strata in sequence with a single "reaction" pulse
// on the composition node, holds, then quietly replays. Progressive
// enhancement: with no JS the full figure is shown; prefers-reduced-motion
// shows it static too. Modality-free by design — the emblem is the program's
// durable question (structure ↔ meaning), of which modality is one instance.
---

<figure
  class="hero-sentence"
  aria-label="How a sentence comes to mean, in three layers. In the sentence “Every dog barked,” each word carries a meaning; grammatical structure composes them into the proposition that for every x, if x is a dog then x barked; and that proposition licenses the inference that if Rex is a dog, Rex barked."
>
  <svg viewBox="0 0 660 470" role="img" shape-rendering="geometricPrecision" preserveAspectRatio="xMidYMid meet">
    <defs>
      <marker id="hs-ar" viewBox="0 0 8 8" refX="6" refY="4" markerWidth="6.5" markerHeight="6.5" orient="auto">
        <path class="hs-arrhead" d="M0 1 L6.5 4 L0 7" />
      </marker>
    </defs>

    <!-- left rail: the three strata -->
    <g class="hs-rail">
      <text class="hs-num" x="22" y="104">1</text>
      <text class="hs-lab" x="38" y="104">WORD</text>
      <text class="hs-sub" x="22" y="120">carries meaning</text>

      <text class="hs-num" x="22" y="236">2</text>
      <text class="hs-lab" x="38" y="236">STRUCTURE</text>
      <text class="hs-sub" x="22" y="252">composes meaning</text>

      <text class="hs-num" x="22" y="368">3</text>
      <text class="hs-lab" x="38" y="368">INFERENCE</text>
      <text class="hs-sub" x="22" y="384">meaning reasons</text>
    </g>

    <line class="hs-divider" x1="150" y1="40" x2="150" y2="430" />

    <!-- the one sentence (always present) -->
    <text class="hs-word" x="252" y="66" text-anchor="middle">Every</text>
    <text class="hs-word" x="380" y="66" text-anchor="middle">dog</text>
    <text class="hs-word" x="502" y="66" text-anchor="middle">barked</text>

    <!-- 1 · atomic meanings under each word -->
    <g class="rev c1">
      <rect class="hs-chip" x="204" y="86" width="96" height="26" rx="5" />
      <text class="hs-chiptx" x="252" y="103" text-anchor="middle">&#8704;&#8201; quantifier</text>
    </g>
    <g class="rev c2">
      <rect class="hs-chip" x="332" y="86" width="96" height="26" rx="5" />
      <text class="hs-chiptx" x="380" y="103" text-anchor="middle">dog( &#183; )</text>
    </g>
    <g class="rev c3">
      <rect class="hs-chip" x="454" y="86" width="96" height="26" rx="5" />
      <text class="hs-chiptx" x="502" y="103" text-anchor="middle">bark( &#183; )</text>
    </g>

    <!-- 2 · they react into one meaning -->
    <g class="rev jc">
      <path class="hs-join" d="M252 112 C 252 150, 380 150, 380 184" marker-end="url(#hs-ar)" />
      <path class="hs-join" d="M380 112 V 184" marker-end="url(#hs-ar)" />
      <path class="hs-join" d="M502 112 C 502 150, 380 150, 380 184" marker-end="url(#hs-ar)" />
      <text class="hs-note" x="576" y="150" text-anchor="middle">grammar makes</text>
      <text class="hs-note" x="576" y="164" text-anchor="middle">them react</text>
    </g>
    <g class="rev cc">
      <rect class="hs-halo react-halo" x="238" y="188" width="284" height="42" rx="8" />
      <rect class="hs-node" x="238" y="188" width="284" height="42" rx="7" />
      <text class="hs-nodetx" x="380" y="214" text-anchor="middle">&#8704;x.&#8201; dog(x) &#8594; bark(x)</text>
    </g>

    <!-- 3 · the meaning becomes a premise -->
    <g class="rev ii">
      <path class="hs-drop" d="M380 230 V 320" marker-end="url(#hs-ar)" />
      <text class="hs-note" x="474" y="278" text-anchor="middle">one meaning,</text>
      <text class="hs-note" x="474" y="292" text-anchor="middle">now a premise</text>
      <rect class="hs-node" x="228" y="322" width="304" height="42" rx="7" />
      <text class="hs-inftx" x="380" y="348" text-anchor="middle"><tspan class="hs-turn">&#8872;&#8201; </tspan>if Rex is a dog, Rex barked</text>
    </g>

    <!-- the standing question -->
    <line class="hs-divider" x1="22" y1="404" x2="638" y2="404" />
    <text class="hs-q" x="22" y="432">Has a system really built all three layers —</text>
    <text class="hs-q" x="22" y="450">or only their surface?</text>
  </svg>

  <figcaption class="hero-sentence-cap">
    Three layers of one sentence — <span class="cap-k">word</span>,
    <span class="cap-k">composition</span>, <span class="cap-k">inference</span>. My work asks
    whether a system has really built them, or only their surface.
  </figcaption>
</figure>

<script>
  (function () {
    const fig = document.querySelector(".hero-sentence");
    if (!fig) return;
    const STEPS = ["lit-1", "lit-2", "lit-3", "lit-c", "lit-i"];
    const IN = [0, 650, 1300, 2200, 3150]; // reveal offsets (ms)
    const HOLD = 3800; // dwell after the last reveal
    const GAP = 650; // dark beat before replay
    let timers = [];
    const clearTimers = () => { timers.forEach(clearTimeout); timers = []; };
    const reset = () => STEPS.forEach((c) => fig.classList.remove(c));

    // reduced motion / accessibility: show the finished figure, no motion
    if (matchMedia("(prefers-reduced-motion: reduce)").matches) {
      STEPS.forEach((c) => fig.classList.add(c));
      return;
    }

    fig.classList.add("anim"); // gate the reveal only once JS is running
    const cycle = () => {
      reset();
      STEPS.forEach((c, i) => timers.push(setTimeout(() => fig.classList.add(c), IN[i] + 60)));
      const end = IN[IN.length - 1] + HOLD;
      timers.push(setTimeout(() => { reset(); timers.push(setTimeout(cycle, GAP)); }, end));
    };

    let running = false;
    new IntersectionObserver((es) => {
      for (const e of es) {
        if (e.isIntersecting && !running) { running = true; cycle(); }
        else if (!e.isIntersecting && running) { running = false; clearTimers(); reset(); }
      }
    }).observe(fig);
  })();
</script>

<style>
  .hero-sentence { margin: 0; padding: 0; }
  .hero-sentence svg {
    width: 100%;
    max-width: 660px;
    height: auto;
    display: block;
    font-family: var(--font-mono);
    overflow: visible;
    --hs-ok: var(--accent-teal, #12a594);
  }

  .hs-divider { stroke: var(--color-text); stroke-opacity: 0.1; }
  .hs-num { font-size: 12px; font-weight: 700; fill: var(--hs-ok); }
  .hs-lab { font-size: 11px; font-weight: 650; letter-spacing: 0.08em; fill: var(--color-text-muted); }
  .hs-sub { font-size: 9px; letter-spacing: 0.04em; fill: var(--color-text-dim); }

  .hs-word { font-size: 24px; font-weight: 600; fill: var(--color-text); }

  .hs-chip { fill: none; stroke: var(--color-border-strong); stroke-opacity: 0.7; }
  .hs-chiptx { font-size: 11px; fill: var(--color-text-muted); }

  .hs-join { fill: none; stroke: var(--hs-ok); stroke-opacity: 0.45; }
  .hs-arrhead { fill: none; stroke: var(--hs-ok); stroke-opacity: 0.6; stroke-width: 1.3; stroke-linecap: round; stroke-linejoin: round; }
  .hs-drop { fill: none; stroke: var(--color-text-dim); stroke-opacity: 0.6; }
  .hs-note { font-size: 10px; fill: var(--color-text-dim); }

  .hs-node { fill: none; stroke: var(--hs-ok); stroke-opacity: 0.55; }
  .hs-nodetx { font-size: 15px; font-weight: 600; fill: var(--color-text); }
  .hs-halo { fill: var(--hs-ok); fill-opacity: 0.14; stroke: none; }
  .hs-inftx { font-size: 14px; fill: var(--color-text); }
  .hs-turn { fill: var(--hs-ok); font-weight: 700; }

  .hs-q { font-size: 11px; fill: var(--color-text-muted); opacity: 0.75; }

  /* progressive reveal — only once JS adds .anim; otherwise fully visible */
  .rev { transition: opacity 0.55s ease; }
  .hero-sentence.anim .rev { opacity: 0; }
  .hero-sentence.anim.lit-1 .c1 { opacity: 1; }
  .hero-sentence.anim.lit-2 .c2 { opacity: 1; }
  .hero-sentence.anim.lit-3 .c3 { opacity: 1; }
  .hero-sentence.anim.lit-c .jc,
  .hero-sentence.anim.lit-c .cc { opacity: 1; }
  .hero-sentence.anim.lit-i .ii { opacity: 1; }

  /* the "reaction": one gentle pulse on the composition node's halo */
  .react-halo { transform-box: fill-box; transform-origin: center; }
  .hero-sentence.anim.lit-c .react-halo { animation: hs-react 1.2s ease-out both; }
  @keyframes hs-react {
    0%   { opacity: 0; transform: scale(0.82); }
    45%  { opacity: 0.55; }
    100% { opacity: 0.16; transform: scale(1); }
  }

  .hero-sentence-cap {
    margin-top: 1.1rem;
    font-size: 11.5px;
    line-height: 1.6;
    font-style: italic;
    color: var(--color-text-dim);
    max-width: 40rem;
  }
  .hero-sentence-cap .cap-k { font-style: normal; font-family: var(--font-mono); font-size: 11px; color: var(--accent-teal, #12a594); }
</style>
