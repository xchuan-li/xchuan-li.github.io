---
// DirectionsFigure — two opposing forces on a single object.
// Outward (productivity): conclusions fan out without bound, cheap, muted.
// Inward (minimum licensing structure): the expensive constraint pressing back,
// accent. Where the two balance is the only place true causal reasoning sits.
const cx = 320;
const cy = 164;
const ring = 60;
const rad = (d: number) => (d * Math.PI) / 180;
const pt = (ang: number, r: number) => [
  +(cx + r * Math.cos(rad(ang))).toFixed(1),
  +(cy + r * Math.sin(rad(ang))).toFixed(1),
];

// Outward productivity rays — many, thin, fading; some longer to read as unbounded.
const outRays = Array.from({ length: 12 }, (_, i) => {
  const ang = 15 + 30 * i;
  const end = i % 2 === 0 ? 116 : 96;
  const [x1, y1] = pt(ang, ring + 6);
  const [x2, y2] = pt(ang, end);
  return { x1, y1, x2, y2, tip: i % 3 === 0 ? pt(ang, end) : null };
});

// Inward licensing arrows — few, bold, deliberate; press in toward the ring.
const inArrows = Array.from({ length: 6 }, (_, i) => {
  const ang = 60 * i;
  const [x1, y1] = pt(ang, 122);
  const [x2, y2] = pt(ang, ring + 9);
  return { x1, y1, x2, y2 };
});
---
<figure class="essay-fig">
  <svg viewBox="0 0 640 330" role="img" aria-label="Two opposing forces on one object: productivity expands conclusions outward and cheaply; the minimum licensing structure presses inward and expensively; their balance is true causal reasoning">
    <defs>
      <marker id="df-out" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto">
        <path d="M 0 1 L 9 5 L 0 9" class="head-out" />
      </marker>
      <marker id="df-in" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto">
        <path d="M 0 1 L 9 5 L 0 9" class="head-in" />
      </marker>
    </defs>

    <!-- force labels: dim = expansion, accent = constraint -->
    <text class="lbl lbl-dim" x="20" y="22">productivity · conclusions expand · cheap</text>
    <text class="lbl lbl-acc" x="20" y="316">minimum licensing · smallest structure · expensive</text>

    <!-- outward force (productivity) -->
    {outRays.map((r) => (
      <line class="ray" x1={r.x1} y1={r.y1} x2={r.x2} y2={r.y2} marker-end="url(#df-out)" />
    ))}
    {outRays.map((r) => r.tip && <circle class="ray-tip" cx={r.tip[0]} cy={r.tip[1]} r="2.4" />)}

    <!-- equilibrium boundary: where the two forces balance -->
    <circle class="ring" cx={cx} cy={cy} r={ring} />

    <!-- inward force (minimum licensing structure) -->
    {inArrows.map((a) => (
      <line class="press" x1={a.x1} y1={a.y1} x2={a.x2} y2={a.y2} marker-end="url(#df-in)" />
    ))}

    <!-- the object held in tension -->
    <circle class="core" cx={cx} cy={cy} r="14" />
    <text class="core-tag" x={cx} y={cy + 36} text-anchor="middle">grounding</text>
  </svg>
  <figcaption>
    Two forces act on one object. Productivity pushes <em>outward</em> — anything that composes
    fans conclusions out for free, without bound. The minimum licensing structure presses the
    other way, <em>inward</em> — the expensive question of which smallest causal structure
    <em>must</em> be there. True causal reasoning is the equilibrium: the behavior that survives
    being squeezed down to exactly the structure that licenses it.
  </figcaption>
</figure>

<style>
  .essay-fig svg { color: var(--color-text-muted); max-height: 320px; }
  .ray { stroke: var(--color-text-dim); stroke-width: 0.9; opacity: 0.6; fill: none; stroke-linecap: round; }
  .ray-tip { fill: var(--color-text-dim); opacity: 0.6; }
  .head-out { fill: none; stroke: var(--color-text-dim); stroke-width: 1.4; stroke-linecap: round; stroke-linejoin: round; opacity: 0.7; }
  .press { stroke: var(--color-accent); stroke-width: 1.5; fill: none; stroke-linecap: round; }
  .head-in { fill: none; stroke: var(--color-accent); stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; }
  .ring { fill: none; stroke: var(--color-accent); stroke-width: 1; stroke-dasharray: 4 4; opacity: 0.55; }
  .core { fill: var(--color-bg); stroke: var(--color-text); stroke-width: 1.5; }
  .core-tag { font-family: var(--font-mono); font-size: 11px; fill: var(--color-text-muted); }
  .lbl { font-family: var(--font-mono); font-size: 11px; }
  .lbl-dim { fill: var(--color-text-muted); }
  .lbl-acc { fill: var(--color-accent); }
</style>
