---
// ResearchTimeline — the homepage's combined stream, in the spirit of
// transformer-circuits.pub. Below the Leibniz lead-in: a reverse-chronological
// timeline with the date on the left and, on the right, large project entries
// ("Name: one-line"), smaller writing entries interspersed, and small milestone
// notes. Entries are precomputed (dated, sorted, month-labelled) in index.astro.
import ProjectGlyph from "./ProjectGlyph.astro";
import HanGLFigure from "./HanGLFigure.astro";
import TLFig from "./TLFig.astro";

interface Origin { label: string; href: string; hook?: string; }
interface Entry {
  type: "project" | "writing" | "milestone";
  date: string;
  dateLabel: string;
  showDate: boolean;
  href?: string;
  name?: string;
  blurb?: string;
  intro?: string;
  glyph?: string;
  fig?: string;
  color?: string;
  category?: string;
  progress?: string;
  kind?: string;
  demo?: boolean;
  title?: string;
  status?: string;
  text?: string;
}
interface Props { origin: Origin; leadIn: string; entries: Entry[]; }
const { origin, leadIn, entries } = Astro.props;
const portraitSrc = "/images/leibniz-portrait.png";
const kindLabel: Record<string, string> = { tool: "Tool", paper: "Paper", project: "Project" };
---

<div class="tl-wrap">
  <!-- Leibniz lead-in -->
  <div class="tl-lead">
    <a class="tl-portrait" href={origin.href} aria-label={origin.label}>
      <img src={portraitSrc} alt="Portrait of Gottfried Wilhelm Leibniz" loading="lazy" decoding="async" />
    </a>
    <div class="tl-lead-text">
      <span class="tl-kicker">{origin.label}</span>
      <p class="tl-latin">{origin.hook ?? "Nihil est sine ratione."}</p>
      <p class="tl-lead-body">{leadIn}</p>
      <a class="tl-lead-cta" href={origin.href}>Read the philosophical bridge <span aria-hidden="true">→</span></a>
    </div>
  </div>

  <!-- timeline stream -->
  <ol class="tl">
    {
      entries.map((e) => (
        <li class={`tl-row tl-row-${e.type}`}>
          <div class="tl-date">{e.showDate ? e.dateLabel : ""}</div>
          <div class="tl-entry">
            {e.type === "project" && (
              <a class="tl-proj" href={e.href} style={`--c: ${e.color ?? "var(--color-accent)"}`}>
                <span class="tl-proj-main">
                  <span class="tl-proj-title">
                    <span class="tl-proj-name">{e.name}</span>
                  </span>
                  {e.intro && <span class="tl-proj-intro">{e.intro}</span>}
                  <span class="tl-proj-meta">
                    <span>{e.category === "collaborative" ? "Collaboration" : "Solo"}</span>
                    {e.kind && <span class="tl-dot">·</span>}
                    {e.kind && <span>{kindLabel[e.kind] ?? e.kind}</span>}
                    {e.progress && <span class="tl-dot">·</span>}
                    {e.progress && <span>{e.progress}</span>}
                    {e.demo && <span class="tl-demo">interactive demo ↗</span>}
                  </span>
                </span>
                {(e.fig || e.glyph) && (
                  <span class={`tl-proj-fig ${e.fig ? "tl-proj-fig-real" : ""}`} aria-hidden="true">
                    {e.fig === "hangl" ? <HanGLFigure />
                      : e.fig ? <TLFig kind={e.fig} color={e.color} />
                      : <ProjectGlyph kind={e.glyph as any} color={e.color} />}
                  </span>
                )}
              </a>
            )}
            {e.type === "writing" && (
              <a class="tl-writing" href={e.href}>
                <span class="tl-writing-tag">{e.status === "draft" ? "Draft" : "Note"}</span>
                <span class="tl-writing-title">{e.title}</span>
                {e.blurb && <span class="tl-writing-desc">{e.blurb}</span>}
              </a>
            )}
            {e.type === "milestone" && <span class="tl-milestone">{e.text}</span>}
          </div>
        </li>
      ))
    }
  </ol>
</div>

<style>
  .tl-wrap { margin: 2.5rem 0 0; }

  /* ---- Leibniz lead-in ---- */
  .tl-lead {
    display: grid; grid-template-columns: 72px 1fr; column-gap: 1.5rem;
    align-items: start; max-width: 52rem; margin-bottom: 2.8rem;
  }
  .tl-portrait { display: block; text-decoration: none; }
  .tl-portrait img {
    width: 72px; height: 88px; object-fit: cover; object-position: 50% 14%;
    border-radius: 10px; filter: contrast(1.04);
    -webkit-mask-image: radial-gradient(130% 100% at 50% 30%, #000 62%, transparent 97%);
            mask-image: radial-gradient(130% 100% at 50% 30%, #000 62%, transparent 97%);
  }
  .tl-kicker {
    font-family: var(--font-mono); font-size: 10px; font-weight: 500;
    letter-spacing: 0.13em; text-transform: uppercase; color: var(--accent-deep-purple);
  }
  .tl-latin {
    margin: 0.3rem 0 0; font-family: var(--font-display); font-style: italic;
    font-size: 1.55rem; font-weight: 500; line-height: 1.15; color: var(--color-text);
  }
  .tl-lead-body {
    margin: 0.7rem 0 0; font-size: 0.95rem; line-height: 1.65;
    color: var(--color-text-muted); max-width: 46rem;
  }
  .tl-lead-cta {
    display: inline-flex; align-items: center; gap: 0.4rem; margin-top: 0.9rem;
    font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.02em;
    color: var(--btn-primary-text); background: var(--accent-deep-purple);
    padding: 5px 13px; border-radius: 999px; text-decoration: none; transition: opacity 0.2s ease;
  }
  .tl-lead-cta:hover { opacity: 0.88; }

  /* ---- timeline ---- */
  .tl { list-style: none; margin: 0; padding: 0; border-top: 1px solid var(--color-border); }
  .tl-row {
    display: grid; grid-template-columns: 112px 1fr; gap: 1.5rem; align-items: start;
  }
  .tl-row-project { padding: 1.2rem 0; border-bottom: 1px solid var(--color-border); }
  .tl-row-writing { padding: 0.75rem 0; border-bottom: 1px solid color-mix(in srgb, var(--color-border) 55%, transparent); }
  .tl-row-milestone { padding: 0.55rem 0; }
  .tl-date {
    font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--color-text-dim); text-align: left; white-space: nowrap; padding-top: 0.5rem;
  }
  .tl-entry { min-width: 0; }

  /* project entry — the large type */
  .tl-proj {
    display: flex; gap: 1.75rem; align-items: flex-start; justify-content: space-between;
    text-decoration: none; border-radius: 8px;
    margin: -0.5rem -0.75rem; padding: 0.5rem 0.75rem; transition: background 0.18s ease;
  }
  .tl-proj:hover { background: var(--color-surface); }
  .tl-proj-main { flex: 1 1 auto; min-width: 0; display: block; }
  .tl-proj-fig {
    flex: 0 0 200px; align-self: center;
    border: 1px solid var(--color-border); border-radius: 12px;
    background: #fffdf9;
    box-shadow: 0 1px 12px color-mix(in srgb, var(--color-text) 5%, transparent);
    padding: 1.15rem 1.3rem;
    display: flex; align-items: center; justify-content: center;
  }
  .tl-proj-fig-real { flex-basis: 320px; padding: 0.9rem 1rem; }
  .tl-proj-fig :global(.proj-glyph) { max-width: 150px; }
  .tl-proj-title {
    display: block; font-family: var(--font-display); font-weight: 600;
    font-size: 1.72rem; line-height: 1.18; letter-spacing: -0.01em; color: var(--color-text);
  }
  .tl-proj-name { color: color-mix(in srgb, var(--c) 68%, var(--color-text)); transition: color 0.18s ease; }
  .tl-proj:hover .tl-proj-name { color: color-mix(in srgb, var(--c) 90%, var(--color-text)); }
  .tl-proj-intro {
    display: block; margin-top: 0.55rem; max-width: 42rem;
    font-family: "Newsreader", "Iowan Old Style", Georgia, serif;
    font-size: 1.05rem; font-weight: 400; line-height: 1.55;
    color: var(--color-text-muted); letter-spacing: 0;
  }
  .tl-proj-meta {
    display: flex; flex-wrap: wrap; align-items: center; gap: 0.45rem; margin-top: 0.55rem;
    font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.05em;
    text-transform: uppercase; color: var(--color-text-dim);
  }
  .tl-dot { opacity: 0.5; }
  .tl-demo {
    text-transform: none; letter-spacing: 0.04em;
    color: #07533e; background: #c8ece0; padding: 1px 7px; border-radius: 999px;
  }

  /* writing entry — the small type, interspersed */
  .tl-writing { display: block; text-decoration: none; }
  .tl-writing-tag {
    font-family: var(--font-mono); font-size: 8.5px; font-weight: 500;
    letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-text-dim);
    border: 1px solid var(--color-border); border-radius: 999px; padding: 1.5px 7px;
    margin-right: 0.55rem; position: relative; top: -1px; white-space: nowrap;
  }
  .tl-writing-title {
    display: inline; font-family: var(--font-display); font-weight: 600; font-size: 1rem; line-height: 1.5;
    color: var(--color-text); transition: color 0.18s ease;
  }
  .tl-writing:hover .tl-writing-title { color: var(--color-accent); }
  .tl-writing-desc {
    display: block; margin-top: 0.25rem;
    font-family: "Newsreader", "Iowan Old Style", Georgia, serif;
    font-size: 0.98rem; line-height: 1.45; color: var(--color-text-muted);
  }
  .tl-draft {
    font-family: var(--font-mono); font-size: 8.5px; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--color-text-dim); border: 1px solid var(--color-border); border-radius: 999px; padding: 1px 6px;
  }

  /* milestone — the smallest, connective notes */
  .tl-milestone {
    display: block; font-size: 0.85rem; font-style: italic; line-height: 1.5;
    color: var(--color-text-dim); max-width: 42rem;
  }
  .tl-milestone::before { content: "— "; font-style: normal; opacity: 0.7; }

  @media (max-width: 640px) {
    .tl-lead { grid-template-columns: 1fr; row-gap: 1rem; }
    .tl-portrait img { width: 60px; height: 74px; }
    .tl-row { grid-template-columns: 1fr; gap: 0.3rem; }
    .tl-date { text-align: left; padding-top: 0; }
    .tl-proj-title { font-size: 1.22rem; }
    .tl-proj { gap: 1rem; }
    .tl-proj-fig { display: none; }
  }
</style>
