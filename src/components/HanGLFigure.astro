---
// HanGLFigure — headline result for the HanGL pilot. Two surface-Hanja effects,
// measured across four models from weak to strong, both collapsing toward zero as
// capability rises:
//   purple = Hanja Gain      — how much a *correct* Hanja gloss helps (model needs it)
//   coral  = Wrong-Hanja Cost — how much a *wrong* Hanja gloss misleads (model led by it)
// A strong model has internalized the latent Hanja structure: it neither needs the
// correct cue nor is misled by a wrong one. Theme-aware, no card chrome.
//
// Data (acc differences): Gain [.52, .00, .02, .00], Cost [.55, .21, .11, .09]
// over Qwen2.5-1.5B, DeepSeek-chat, Gemini 2.5 Flash, Claude Opus 4.8.
const xs = [80, 192, 304, 416];
const yOf = (v: number) => 240 - (v / 0.6) * 180; // plot: y=240 is 0, y=60 is 0.6
const gain = [0.52, 0.0, 0.02, 0.0];
const cost = [0.55, 0.21, 0.11, 0.09];
const models = ["1.5B", "DeepSeek", "Gemini", "Claude"];
const gainPts = xs.map((x, i) => `${x},${yOf(gain[i])}`).join(" ");
const costPts = xs.map((x, i) => `${x},${yOf(cost[i])}`).join(" ");
---

<figure class="hg-fig" aria-label="Two line series across four models ordered weak to strong. Hanja Gain (does a correct Hanja help) falls from 0.52 at Qwen2.5-1.5B to about zero for DeepSeek, Gemini and Claude. Wrong-Hanja Cost (does a wrong Hanja mislead) falls from 0.55 to 0.09. Both surface-Hanja effects collapse as model capability rises.">
  <svg viewBox="0 0 470 300" shape-rendering="geometricPrecision" preserveAspectRatio="xMidYMid meet">
    <!-- legend -->
    <line class="hg-e-gain" x1="70" y1="26" x2="90" y2="26" />
    <text class="hg-leg hg-gain" x="96" y="29.5">Hanja Gain · needs correct Hanja</text>
    <line class="hg-e-cost" x1="280" y1="26" x2="300" y2="26" />
    <text class="hg-leg hg-cost" x="306" y="29.5">Wrong-Hanja Cost · misled by wrong</text>

    <!-- y axis ticks -->
    <line class="hg-axis" x1="70" y1="60" x2="70" y2="240" />
    <text class="hg-tick" x="62" y="63" text-anchor="end">0.6</text>
    <text class="hg-tick" x="62" y="153" text-anchor="end">0.3</text>
    <text class="hg-tick" x="62" y="243" text-anchor="end">0</text>
    <line class="hg-base" x1="70" y1="240" x2="430" y2="240" />

    <!-- series -->
    <polyline class="hg-e-cost" points={costPts} />
    <polyline class="hg-e-gain" points={gainPts} />
    {xs.map((x, i) => (<circle class="hg-dot-cost" cx={x} cy={yOf(cost[i])} r="3.4" />))}
    {xs.map((x, i) => (<circle class="hg-dot-gain" cx={x} cy={yOf(gain[i])} r="3.4" />))}

    <!-- value labels for the extremes -->
    <text class="hg-val hg-gain" x="80" y={yOf(gain[0]) - 8} text-anchor="middle">+.52</text>
    <text class="hg-val hg-cost" x="80" y={yOf(cost[0]) - 18} text-anchor="middle">+.55</text>
    <text class="hg-val hg-cost" x="416" y={yOf(cost[3]) - 9} text-anchor="middle">+.09</text>
    <text class="hg-val hg-gain" x="416" y={yOf(gain[3]) + 16} text-anchor="middle">≈0</text>

    <!-- x labels -->
    {models.map((m, i) => (<text class="hg-xlbl" x={xs[i]} y="256" text-anchor="middle">{m}</text>))}
    <text class="hg-axislbl" x="250" y="278" text-anchor="middle">weaker  →  stronger</text>

    <!-- caption -->
    <text class="hg-cap" x="250" y="296" text-anchor="middle">strong models neither need the correct Hanja nor follow a wrong one</text>
  </svg>
</figure>

<style>
  .hg-fig { margin: 0; padding: 0; }
  .hg-fig svg { width: 100%; max-width: 480px; height: auto; display: block; margin: 0 auto; font-family: var(--font-mono); }

  .hg-gain { fill: var(--accent-purple); }
  .hg-cost { fill: var(--accent-coral); }
  .hg-leg { font-size: 9.5px; letter-spacing: 0.01em; }
  .hg-tick { font-size: 9px; fill: var(--color-text-dim); }
  .hg-xlbl { font-size: 10px; font-weight: 600; fill: var(--color-text-muted); }
  .hg-axislbl { font-size: 9px; letter-spacing: 0.04em; fill: var(--color-text-dim); }
  .hg-val { font-size: 9.5px; font-weight: 600; }
  .hg-cap { font-size: 9.5px; font-style: italic; fill: var(--color-text-dim); letter-spacing: 0.01em; }

  .hg-axis { stroke: var(--color-border-strong); stroke-width: 0.5; }
  .hg-base { stroke: var(--color-border-strong); stroke-width: 0.5; }

  .hg-e-gain { stroke: var(--accent-purple); stroke-width: 1.6; fill: none; }
  .hg-e-cost { stroke: var(--accent-coral); stroke-width: 1.6; fill: none; }
  .hg-dot-gain { fill: var(--accent-purple); }
  .hg-dot-cost { fill: var(--accent-coral); }
</style>
