---
// MiniCausalFigure — a synthetic sandbox with a known answer.
// We PLANT a small causal model whose structure we fully control, simulate data
// and train a model on it, then RECOVER the minimal structure from behavior alone.
// Because the structure is planted, the recovery can be scored: the recovered
// skeleton matches the planted one, and an inessential candidate edge (X1 → Y) is
// tested and pruned — removable without behavioral cost. Left→right is the cheap
// forward direction (simulate · train, dim); right is the expensive recovery (slate).
type N = {
  x: number; y: number; r: number;
  label: string; lx: number; ly: number;
  anchor: "start" | "middle" | "end"; fill?: boolean;
};

const trim = (a: N, b: N, padB = 9) => {
  const dx = b.x - a.x, dy = b.y - a.y;
  const L = Math.hypot(dx, dy);
  const ux = dx / L, uy = dy / L;
  return {
    x1: +(a.x + a.r * ux).toFixed(1),
    y1: +(a.y + a.r * uy).toFixed(1),
    x2: +(b.x - (b.r + padB) * ux).toFixed(1),
    y2: +(b.y - (b.r + padB) * uy).toFixed(1),
  };
};

// one node layout, instantiated twice — planted (left) and recovered (right)
const layout = (ox: number): Record<"x1" | "x2" | "m" | "y", N> => ({
  x1: { x: ox + 8,  y: 84,  r: 6, label: "X1", lx: ox - 3,   ly: 88,  anchor: "end" },
  x2: { x: ox + 8,  y: 168, r: 6, label: "X2", lx: ox - 3,   ly: 172, anchor: "end" },
  m:  { x: ox + 86, y: 126, r: 6, label: "M",  lx: ox + 86,  ly: 109, anchor: "middle" },
  y:  { x: ox + 96, y: 210, r: 7, label: "Y",  lx: ox + 112, ly: 214, anchor: "start", fill: true },
});

const planted = layout(52);
const recovered = layout(496);

const skeleton = (n: ReturnType<typeof layout>) => [
  trim(n.x1, n.m), trim(n.x2, n.m), trim(n.m, n.y),
];
const plantedEdges = skeleton(planted);
const recoveredEdges = skeleton(recovered);
const pruned = trim(recovered.x1, recovered.y, 7);
const cut = { x: (recovered.x1.x + recovered.y.x) / 2, y: (recovered.x1.y + recovered.y.y) / 2 };

const nodes = (n: ReturnType<typeof layout>) => Object.values(n);

// faint output bars inside the black box — its behavior, not its structure
const bars = [18, 30, 13, 26, 21].map((h, i) => ({ x: 270 + i * 12, h }));
const barBase = 206;
---
<figure class="essay-fig mcm-fig">
  <svg viewBox="0 0 720 300" role="img" aria-label="A small causal model is planted as ground truth, data is simulated and a model trained on it; the minimal structure is then recovered from behavior alone — and because the structure was planted, the recovery is scored: it returns the planted skeleton and prunes an inessential candidate edge">
    <defs>
      <marker id="mcm-arr-acc" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto">
        <path d="M 0 1 L 9 5 L 0 9" class="mcm-head-acc" />
      </marker>
      <marker id="mcm-arr-dim" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto">
        <path d="M 0 1 L 9 5 L 0 9" class="mcm-head-dim" />
      </marker>
    </defs>

    <!-- LEFT — the planted ground truth -->
    <text class="mcm-lbl mcm-lbl-acc" x="100" y="44" text-anchor="middle">planted ground truth</text>
    <text class="mcm-lbl mcm-lbl-dim" x="100" y="58" text-anchor="middle">structure we control</text>
    {plantedEdges.map((e) => (
      <line class="mcm-edge" x1={e.x1} y1={e.y1} x2={e.x2} y2={e.y2} marker-end="url(#mcm-arr-acc)" />
    ))}
    {nodes(planted).map((p) => (
      <g>
        <circle class={p.fill ? "mcm-node-f" : "mcm-node"} cx={p.x} cy={p.y} r={p.r} />
        <text class="mcm-nlbl" x={p.lx} y={p.ly} text-anchor={p.anchor}>{p.label}</text>
      </g>
    ))}

    <!-- forward direction (cheap): simulate data, train a model -->
    <line class="mcm-fwd" x1="166" y1="150" x2="244" y2="150" marker-end="url(#mcm-arr-dim)" />
    <text class="mcm-lbl mcm-lbl-dim" x="205" y="142" text-anchor="middle">simulate · train</text>

    <!-- CENTER — the trained model, opaque; we see behavior, not structure -->
    <rect class="mcm-box" x="250" y="96" width="120" height="120" rx="9" />
    <text class="mcm-box-lbl" x="262" y="116">model · black box</text>
    {bars.map((b) => (
      <line class="mcm-bar" x1={b.x} y1={barBase} x2={b.x} y2={barBase - b.h} />
    ))}
    <text class="mcm-box-sub" x="310" y="222" text-anchor="middle">behavior</text>

    <!-- expensive direction: recover the minimal structure from behavior alone -->
    <line class="mcm-rec" x1="376" y1="150" x2="486" y2="150" marker-end="url(#mcm-arr-acc)" />
    <text class="mcm-lbl mcm-lbl-acc" x="431" y="142" text-anchor="middle">recover structure</text>
    <text class="mcm-lbl mcm-lbl-dim" x="431" y="166" text-anchor="middle">from behavior</text>

    <!-- RIGHT — the recovered structure, scored against the planted truth -->
    <text class="mcm-lbl mcm-lbl-acc" x="592" y="44" text-anchor="middle">recovered</text>
    <!-- a candidate direct edge X1 → Y, tested and pruned (removable) -->
    <line class="mcm-pruned" x1={pruned.x1} y1={pruned.y1} x2={pruned.x2} y2={pruned.y2} />
    <line class="mcm-cut" x1={cut.x - 4} y1={cut.y - 4} x2={cut.x + 4} y2={cut.y + 4} />
    <line class="mcm-cut" x1={cut.x + 4} y1={cut.y - 4} x2={cut.x - 4} y2={cut.y + 4} />
    {recoveredEdges.map((e) => (
      <line class="mcm-edge" x1={e.x1} y1={e.y1} x2={e.x2} y2={e.y2} marker-end="url(#mcm-arr-acc)" />
    ))}
    {nodes(recovered).map((p) => (
      <g>
        <circle class={p.fill ? "mcm-node-f" : "mcm-node"} cx={p.x} cy={p.y} r={p.r} />
        <text class="mcm-nlbl" x={p.lx} y={p.ly} text-anchor={p.anchor}>{p.label}</text>
      </g>
    ))}
    <text class="mcm-verdict" x="592" y="262" text-anchor="middle">matches planted · X1→Y pruned</text>
  </svg>
  <figcaption>
    Plant a structure we control, simulate data, train on it — then recover the minimal structure from behavior alone. Because the truth is <em>planted</em>, the recovery can be scored: here it returns the planted skeleton and prunes the inessential <code>X1→Y</code> edge.
  </figcaption>
</figure>

<style>
  .essay-fig.mcm-fig svg { max-height: 320px; }

  .mcm-lbl { font-family: var(--font-mono); font-size: 11px; }
  .mcm-lbl-acc { fill: var(--accent-slate); }
  .mcm-lbl-dim { fill: var(--color-text-dim); }

  .mcm-edge { stroke: var(--accent-slate); stroke-width: 1.6; fill: none; stroke-linecap: round; }
  .mcm-head-acc { fill: none; stroke: var(--accent-slate); stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; }
  .mcm-head-dim { fill: none; stroke: var(--color-text-dim); stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; }

  .mcm-node { fill: var(--color-bg); stroke: var(--accent-slate); stroke-width: 1.5; }
  .mcm-node-f { fill: var(--accent-slate); stroke: none; }
  .mcm-nlbl { font-family: var(--font-mono); font-size: 11px; fill: var(--color-text-muted); }

  .mcm-fwd { stroke: var(--color-text-dim); stroke-width: 1.3; fill: none; stroke-linecap: round; }
  .mcm-rec { stroke: var(--accent-slate); stroke-width: 1.8; fill: none; stroke-linecap: round; }

  .mcm-pruned { stroke: var(--color-text-dim); stroke-width: 1.2; fill: none; stroke-dasharray: 4 3; opacity: 0.7; }
  .mcm-cut { stroke: var(--accent-slate); stroke-width: 1.5; stroke-linecap: round; }

  .mcm-verdict { font-family: var(--font-mono); font-size: 10px; fill: var(--color-text-muted); }

  /* the opaque model — light-on-dark in both themes, matching Isotrace */
  .mcm-box { fill: #15151b; stroke: rgba(255, 255, 255, 0.16); stroke-width: 1; }
  .mcm-box-lbl { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.03em; fill: rgba(255, 255, 255, 0.4); }
  .mcm-box-sub { font-family: var(--font-mono); font-size: 9.5px; fill: rgba(255, 255, 255, 0.5); }
  .mcm-bar { stroke: rgba(255, 255, 255, 0.32); stroke-width: 3; stroke-linecap: round; }
</style>
