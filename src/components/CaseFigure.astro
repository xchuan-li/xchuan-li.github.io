---
// CaseFigure — a tiny figure for each case study that shows the experiment's
// core setup through a sentence instance, rather than an abstract glyph.
//   modus — the force test: ablate the certainty direction on a "might" sentence
//           and it behaves like "must".
//   hangl — the decomposition test: is 학교 built from 學 + 校, or stored whole?
//   ordo  — the defeasibility test: "birds fly" survives a sparrow, meets
//           exceptions of rising novelty (penguin, then a bird set in concrete).
interface Props {
  kind: "modus" | "hangl" | "ordo";
  color?: string;
}
const { kind, color = "var(--color-accent)" } = Astro.props;
---

<div class="cf" style={`--cf: ${color}`}>
  {kind === "modus" && (
    <>
      <div class="cf-s">“…<b>might</b> be red.”</div>
      <div class="cf-op">ablate force →</div>
      <div class="cf-s cf-hi">acts like <b>must</b></div>
    </>
  )}
  {kind === "hangl" && (
    <>
      <div class="cf-s cf-big">학교</div>
      <div class="cf-op">= 學 + 校 ?</div>
      <div class="cf-sub">composed, or stored</div>
    </>
  )}
  {kind === "ordo" && (
    <>
      <div class="cf-s">Birds fly.</div>
      <div class="cf-row"><span>a sparrow</span><span class="ok">✓</span></div>
      <div class="cf-row"><span>a penguin</span><span class="no">✗</span></div>
      <div class="cf-row"><span>in concrete</span><span class="no">✗</span></div>
    </>
  )}
</div>

<style>
  .cf {
    font-family: var(--font-mono);
    font-size: 10px;
    line-height: 1.5;
    color: var(--color-text-muted);
    text-align: left;
  }
  .cf-s {
    font-family: var(--font-display, serif);
    font-size: 13px;
    color: var(--color-text);
    margin-bottom: 2px;
  }
  .cf-s b { color: var(--cf); font-weight: 600; }
  .cf-big { font-size: 21px; letter-spacing: 0.02em; }
  .cf-hi b { color: var(--cf); }
  .cf-op {
    color: var(--cf);
    font-size: 9px;
    letter-spacing: 0.03em;
    margin: 3px 0;
  }
  .cf-sub { font-size: 9.5px; }
  .cf-row {
    display: flex;
    justify-content: space-between;
    gap: 8px;
    max-width: 96px;
  }
  .cf-row .ok { color: var(--cf); font-weight: 600; }
  .cf-row .no { color: var(--color-text-dim); }
</style>
