---
// ProjectGlyph — a small, concept-driven diagram for each research project.
// One glyph per project, drawn in the project's accent color (passed via `color`).
// Each has a deliberately distinct silhouette so the project families read apart at a glance:
//   sc        — two causes converge on a target; the spurious one is severed by do()
//   isotrace  — a numbered hop-chain (¹²³) with a bypass arc that drops the middle hop
//   mcm       — a dense web of candidate edges with one bold minimal skeleton kept
//   ciy       — a ticked yield gauge beside a column of realized / unrealized slots
//   latent    — an activation cloud on a manifold, two causal states linked by a steer
//   protobias — a meaning fans to language tokens; one branch drifts to a prototype
interface Props {
  kind: "sc" | "isotrace" | "mcm" | "ciy" | "latent" | "protobias";
  color?: string;
}
const { kind, color = "var(--color-accent)" } = Astro.props;
const labels: Record<Props["kind"], string> = {
  sc: "two causes converge on a target; the spurious one is severed",
  isotrace: "a numbered hop-chain with a bypass arc that drops a hop",
  mcm: "a dense candidate web with one minimal skeleton kept",
  ciy: "a graded yield gauge beside realized and unrealized slots",
  latent: "two causal states linked on an activation manifold",
  protobias: "meaning fans to language tokens; one drifts to a prototype",
};
---

<svg
  class="proj-glyph"
  viewBox="0 0 96 60"
  role="img"
  aria-label={labels[kind]}
  style={`color:${color}`}
>
  {
    kind === "sc" && (
      <g>
        <marker id="g-sc-a" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto">
          <path d="M 0 1 L 9 5 L 0 9" class="gl-arrhead" />
        </marker>
        <marker id="g-sc-d" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto">
          <path d="M 0 1 L 9 5 L 0 9" class="gl-arrhead-dim" />
        </marker>
        <circle class="gl-acc-soft" cx="78" cy="30" r="11" />
        <circle class="gl-acc-f" cx="78" cy="30" r="6.5" />
        <circle class="gl-acc" cx="16" cy="15" r="5" />
        <circle class="gl-dim" cx="16" cy="47" r="4.5" />
        <line class="gl-acc gl-w" x1="20.9" y1="16.2" x2="69" y2="27.6" marker-end="url(#g-sc-a)" />
        <line class="gl-acc" x1="20.3" y1="45.8" x2="37" y2="41" />
        <line class="gl-dim gl-dash" x1="43" y1="39.6" x2="69" y2="33" marker-end="url(#g-sc-d)" />
        <line class="gl-cut" x1="37" y1="37" x2="43" y2="44" />
        <line class="gl-cut" x1="43" y1="37" x2="37" y2="44" />
      </g>
    )
  }
  {
    kind === "isotrace" && (
      <g>
        <marker id="g-iso-a" viewBox="0 0 10 10" refX="7" refY="5" markerWidth="5" markerHeight="5" orient="auto">
          <path d="M 0 1 L 9 5 L 0 9" class="gl-arrhead" />
        </marker>
        <marker id="g-iso-d" viewBox="0 0 10 10" refX="7" refY="5" markerWidth="5" markerHeight="5" orient="auto">
          <path d="M 0 1 L 9 5 L 0 9" class="gl-arrhead-dim" />
        </marker>
        <path class="gl-dim gl-dash" d="M 18 38 C 34 12, 60 12, 76 38" marker-end="url(#g-iso-d)" />
        <line class="gl-acc gl-w" x1="24" y1="42" x2="38" y2="42" marker-end="url(#g-iso-a)" />
        <line class="gl-acc gl-w" x1="52" y1="42" x2="65" y2="42" marker-end="url(#g-iso-a)" />
        <circle class="gl-acc" cx="18" cy="42" r="5" />
        <circle class="gl-dim gl-dash" cx="45" cy="42" r="4.5" />
        <circle class="gl-acc-f" cx="72" cy="42" r="5.5" />
        <text class="gl-num" x="18" y="57" text-anchor="middle">1</text>
        <text class="gl-num gl-num-dim" x="45" y="57" text-anchor="middle">2</text>
        <text class="gl-num" x="72" y="57" text-anchor="middle">3</text>
      </g>
    )
  }
  {
    kind === "mcm" && (
      <g>
        <marker id="g-mcm-a" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto">
          <path d="M 0 1 L 9 5 L 0 9" class="gl-arrhead" />
        </marker>
        <line class="gl-faint" x1="15" y1="22" x2="15" y2="40" />
        <line class="gl-faint gl-dash" x1="20" y1="18" x2="74" y2="29" />
        <line class="gl-faint gl-dash" x1="20" y1="44" x2="74" y2="33" />
        <line class="gl-faint" x1="46" y1="26" x2="53" y2="13" />
        <line class="gl-faint" x1="48" y1="33" x2="62" y2="48" />
        <line class="gl-acc gl-w" x1="19.5" y1="19.1" x2="37" y2="27.3" marker-end="url(#g-mcm-a)" />
        <line class="gl-acc gl-w" x1="19.5" y1="42.9" x2="37" y2="34.7" marker-end="url(#g-mcm-a)" />
        <line class="gl-acc gl-w" x1="50" y1="31" x2="71" y2="31" marker-end="url(#g-mcm-a)" />
        <circle class="gl-acc" cx="15" cy="17" r="5" />
        <circle class="gl-acc" cx="15" cy="45" r="5" />
        <circle class="gl-acc" cx="45" cy="31" r="5" />
        <circle class="gl-acc-f" cx="80" cy="31" r="6.5" />
      </g>
    )
  }
  {
    kind === "ciy" && (
      <g>
        <path class="gl-dim gl-w" d="M 10 46 A 22 22 0 0 1 54 46" />
        <line class="gl-tick" x1="10" y1="46" x2="14.5" y2="46" />
        <line class="gl-tick" x1="16.4" y1="30.4" x2="19.3" y2="33.3" />
        <line class="gl-tick" x1="32" y1="24" x2="32" y2="28.5" />
        <line class="gl-tick" x1="47.6" y1="30.4" x2="44.7" y2="33.3" />
        <line class="gl-tick" x1="54" y1="46" x2="49.5" y2="46" />
        <line class="gl-acc gl-w" x1="32" y1="46" x2="24.8" y2="30.6" />
        <circle class="gl-acc-f" cx="32" cy="46" r="2.6" />
        <circle class="gl-acc-f" cx="80" cy="15" r="3.2" />
        <circle class="gl-acc-f" cx="80" cy="27" r="3.2" />
        <circle class="gl-dim" cx="80" cy="39" r="3.2" />
        <circle class="gl-dim" cx="80" cy="51" r="3.2" />
      </g>
    )
  }
  {
    kind === "latent" && (
      <g>
        <marker id="g-lat-a" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto">
          <path d="M 0 1 L 9 5 L 0 9" class="gl-arrhead" />
        </marker>
        <path class="gl-manifold" d="M 8 40 C 28 13, 58 51, 90 18" />
        <circle class="gl-dim-f" cx="14" cy="22" r="1.6" />
        <circle class="gl-dim-f" cx="24" cy="45" r="1.6" />
        <circle class="gl-dim-f" cx="21" cy="53" r="1.6" />
        <circle class="gl-dim-f" cx="42" cy="52" r="1.6" />
        <circle class="gl-dim-f" cx="56" cy="47" r="1.6" />
        <circle class="gl-dim-f" cx="70" cy="40" r="1.6" />
        <circle class="gl-dim-f" cx="85" cy="27" r="1.6" />
        <circle class="gl-dim-f" cx="88" cy="44" r="1.6" />
        <circle class="gl-dim-f" cx="51" cy="17" r="1.6" />
        <line class="gl-acc gl-w" x1="38" y1="28" x2="58" y2="33" marker-end="url(#g-lat-a)" />
        <circle class="gl-acc" cx="34" cy="27" r="4.5" />
        <circle class="gl-acc-f" cx="62" cy="34" r="5" />
      </g>
    )
  }
  {
    kind === "protobias" && (
      <g>
        <marker id="g-pb-a" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto">
          <path d="M 0 1 L 9 5 L 0 9" class="gl-arrhead" />
        </marker>
        <marker id="g-pb-d" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto">
          <path d="M 0 1 L 9 5 L 0 9" class="gl-arrhead-dim" />
        </marker>
        <line class="gl-acc" x1="20" y1="27" x2="70" y2="16" marker-end="url(#g-pb-a)" />
        <line class="gl-acc" x1="20" y1="31" x2="70" y2="31" marker-end="url(#g-pb-a)" />
        <path class="gl-acc gl-dash" d="M 19 34 C 34 51, 50 52, 62 52" marker-end="url(#g-pb-d)" />
        <circle class="gl-acc" cx="15" cy="30" r="5" />
        <rect class="gl-dim" x="72" y="11" width="9" height="9" rx="1.5" />
        <rect class="gl-acc" x="72" y="26" width="9" height="9" rx="1.5" />
        <polygon class="gl-dim" points="71,46 78,52 71,58 64,52" />
      </g>
    )
  }
</svg>

<style>
  .proj-glyph { display: block; width: 100%; height: auto; overflow: visible; }
  .gl-acc { stroke: currentColor; fill: none; stroke-width: 1.3; }
  .gl-acc-soft { stroke: currentColor; fill: none; stroke-width: 1; opacity: 0.32; }
  .gl-dim { stroke: var(--color-text-dim); fill: none; stroke-width: 1; }
  .gl-faint { stroke: var(--color-text-dim); fill: none; stroke-width: 0.8; opacity: 0.5; }
  .gl-manifold { stroke: var(--color-text-dim); fill: none; stroke-width: 1; opacity: 0.6; stroke-dasharray: 2 3; }
  .gl-tick { stroke: var(--color-text-dim); stroke-width: 1; opacity: 0.75; stroke-linecap: round; }
  .gl-w { stroke-width: 1.5; }
  .gl-dash { stroke-dasharray: 3 2.5; }
  .gl-acc-f { fill: currentColor; stroke: none; }
  .gl-dim-f { fill: var(--color-text-dim); stroke: none; }
  .gl-cut { stroke: currentColor; stroke-width: 1.5; stroke-linecap: round; }
  .gl-arrhead { fill: none; stroke: currentColor; stroke-width: 1.4; stroke-linecap: round; stroke-linejoin: round; }
  .gl-arrhead-dim { fill: none; stroke: var(--color-text-dim); stroke-width: 1.4; stroke-linecap: round; stroke-linejoin: round; }
  .gl-num { font-family: var(--font-mono); font-size: 8px; fill: currentColor; }
  .gl-num-dim { fill: var(--color-text-dim); }
  .proj-glyph path { fill: none; }
  .proj-glyph line { stroke-linecap: round; }
</style>
