---
// IsotraceFigure — behavioral tracing as isotope labeling.
// A coined word is "isotope-labeled" (path-encoded superscript) and injected into
// the black-box model. We never open the box; we follow the label. If the labeled
// chain ¹Zorb → ²Veln → ³Quasp comes out intact, the model composed. If the middle
// label is missing, a shortcut substituted for the hop — and we've localized it.
const cyHop = 158;
const r = 27;
const hex = (cx: number, cy: number, rr: number) =>
  Array.from({ length: 6 }, (_, k) => {
    const a = (60 * k) * Math.PI / 180;
    return `${+(cx + rr * Math.cos(a)).toFixed(1)},${+(cy + rr * Math.sin(a)).toFixed(1)}`;
  }).join(" ");

const hops = [
  { idx: "1", name: "Zorb", cx: 240 },
  { idx: "2", name: "Veln", cx: 352 },
  { idx: "3", name: "Quasp", cx: 464 },
];
const box = { x: 178, y: 64, w: 348, h: 176 };
---
<figure class="essay-fig isotrace-fig">
  <svg viewBox="0 0 744 300" role="img" aria-label="A coined word is isotope-labeled and injected into a black-box model; following the label reveals whether the model composed through every hop or substituted a shortcut for one">
    <defs>
      <marker id="iso-teal" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto">
        <path d="M 0 1 L 9 5 L 0 9" class="iso-head-teal" />
      </marker>
      <marker id="iso-gray" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto">
        <path d="M 0 1 L 9 5 L 0 9" class="iso-head-gray" />
      </marker>
      <marker id="iso-tealb" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto">
        <path d="M 0 1 L 9 5 L 0 9" class="iso-head-tealb" />
      </marker>
    </defs>

    <!-- LEFT — the isotope-labeled tracer -->
    <polygon class="iso-tracer" points={hex(78, cyHop, 31)} />
    <text class="iso-sup iso-sup-teal" x="61" y="150">1</text>
    <text class="iso-token iso-token-teal" x="82" y="163" text-anchor="middle">Zorb</text>
    <line class="iso-inject" x1="112" y1="158" x2="172" y2="158" marker-end="url(#iso-teal)" />

    <!-- CENTER — the opaque model -->
    <rect class="iso-box" x={box.x} y={box.y} width={box.w} height={box.h} rx="10" />
    <text class="iso-box-lbl" x={box.x + 14} y={box.y + 22}>model · black box</text>

    <!-- inferred multi-hop structure (we never open the box; the hops are reconstructed) -->
    {hops.map((h) => (
      <g>
        <polygon class="iso-ghost" points={hex(h.cx, cyHop, r)} />
        <text class="iso-sup-in" x={h.cx - 19} y={cyHop - 6}>{h.idx}</text>
        <text class="iso-token-in" x={h.cx + 3} y={cyHop + 4} text-anchor="middle">{h.name}</text>
      </g>
    ))}

    <!-- the labeled chain, threaded hop by hop (composition: label retained) -->
    <line class="iso-trace" x1={box.x} y1={cyHop} x2={hops[0].cx - r} y2={cyHop} marker-end="url(#iso-tealb)" />
    <line class="iso-trace" x1={hops[0].cx + r} y1={cyHop} x2={hops[1].cx - r} y2={cyHop} marker-end="url(#iso-tealb)" />
    <line class="iso-trace" x1={hops[1].cx + r} y1={cyHop} x2={hops[2].cx - r} y2={cyHop} marker-end="url(#iso-tealb)" />

    <!-- the shortcut: jumps the middle hop, dropping its label (substitution) -->
    <path class="iso-shortcut" d={`M ${hops[0].cx} ${cyHop - r} C ${hops[0].cx + 50} ${box.y + 6}, ${hops[2].cx - 50} ${box.y + 6}, ${hops[2].cx} ${cyHop - r}`} marker-end="url(#iso-gray)" />
    <text class="iso-drop" x={hops[1].cx} y={box.y + 48} text-anchor="middle">²Veln dropped</text>

    <!-- RIGHT — the detector reads which label sequence emerged -->
    <line class="iso-out" x1={box.x + box.w} y1={cyHop} x2={box.x + box.w + 44} y2={cyHop} marker-end="url(#iso-teal)" />
    <line class="iso-detface" x1="592" y1="120" x2="592" y2="196" />
    <circle class="iso-dot-teal" cx="606" cy="138" r="4" />
    <text class="iso-read iso-read-teal" x="618" y="142">¹²³ · composed</text>
    <circle class="iso-dot-gray" cx="606" cy="178" r="4" />
    <text class="iso-read iso-read-gray" x="618" y="182">¹·³ · shortcut</text>
  </svg>
  <figcaption>
    Coined words as inert tracers — superscripts path-encode hop order. Follow the label, not the internals. <code>¹²³</code> = composed through every hop; <code>¹·³</code> = shortcut at hop two.
  </figcaption>
</figure>

<style>
  .essay-fig.isotrace-fig svg { max-height: 330px; }

  /* on-page elements (theme-aware) */
  .iso-tracer { fill: none; stroke: var(--accent-teal); stroke-width: 1.4; }
  .iso-token-teal { font-family: var(--font-mono); font-size: 14px; fill: var(--accent-teal); font-weight: 500; }
  .iso-sup-teal { font-family: var(--font-mono); font-size: 9px; fill: var(--accent-teal); }
  .iso-inject { stroke: var(--accent-teal); stroke-width: 1.4; fill: none; stroke-linecap: round; }
  .iso-out { stroke: var(--accent-teal); stroke-width: 1.4; fill: none; stroke-linecap: round; }
  .iso-head-teal { fill: none; stroke: var(--accent-teal); stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; }
  .iso-head-gray { fill: none; stroke: var(--color-text-dim); stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; }
  .iso-lbl { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.02em; }
  .iso-lbl-teal { fill: var(--accent-teal); }
  .iso-lbl-dim { fill: var(--color-text-muted); }
  .iso-mini { font-family: var(--font-mono); font-size: 9.5px; fill: var(--color-text-dim); }
  .iso-detface { stroke: var(--color-border-strong); stroke-width: 1; }
  .iso-dot-teal { fill: var(--accent-teal); }
  .iso-dot-gray { fill: none; stroke: var(--color-text-dim); stroke-width: 1.2; }
  .iso-read { font-family: var(--font-mono); font-size: 11px; }
  .iso-read-teal { fill: var(--color-text); }
  .iso-read-gray { fill: var(--color-text-dim); }

  /* inside the black box — always light-on-dark, both themes */
  .iso-box { fill: #15151b; stroke: rgba(255, 255, 255, 0.16); stroke-width: 1; }
  .iso-box-lbl { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.04em; fill: rgba(255, 255, 255, 0.4); }
  .iso-ghost { fill: rgba(255, 255, 255, 0.02); stroke: rgba(255, 255, 255, 0.28); stroke-width: 1; stroke-dasharray: 3 3; }
  .iso-token-in { font-family: var(--font-mono); font-size: 12.5px; fill: rgba(255, 255, 255, 0.7); }
  .iso-sup-in { font-family: var(--font-mono); font-size: 9px; fill: #6fd2ad; }
  .iso-trace { stroke: #54c39b; stroke-width: 2; fill: none; stroke-linecap: round; }
  .iso-shortcut { stroke: rgba(255, 255, 255, 0.38); stroke-width: 1.3; fill: none; stroke-dasharray: 4 3; stroke-linecap: round; }
  .iso-drop { font-family: var(--font-mono); font-size: 9.5px; fill: rgba(255, 255, 255, 0.45); }
  .iso-head-tealb { fill: none; stroke: #54c39b; stroke-width: 1.6; stroke-linecap: round; stroke-linejoin: round; }
</style>
