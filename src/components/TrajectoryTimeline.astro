---
// ResearchSpine — "Option A": the research arc as a layered argument.
// Reading top to bottom: one question (a brace over the three) → the main line
// 01·Certify → 02·Localize → 03·Quantify (Whether / Where / How much) → the
// workbench all three run on → and, off the spine, two collaborative group
// projects. The origin (Leibniz) and the language frontier are faint bookends on
// the beam. Weight, size and position carry the hierarchy: the beam is heaviest,
// the workbench sits beneath as a foundation, the group projects are lightest.
interface Origin {
  label: string;
  href: string;
}
interface Station {
  n: string;
  method: string;
  qword: string;
  title: string;
  color: string;
  href: string;
  capstone?: boolean;
}
interface Frontier {
  label: string;
  title: string;
  href: string;
}
interface Workbench {
  title: string;
  href: string;
  desc: string;
}
interface Group {
  title: string;
  kind: string;
  href: string;
}
interface Props {
  question: string;
  origin: Origin;
  stations: Station[];
  frontier: Frontier;
  workbench: Workbench;
  groups: Group[];
}

const { question, origin, stations, frontier, workbench, groups } = Astro.props;
---

<div class="spine">
  <div class="spine-scroll">
    <div class="spine-grid">
      <p class="sp-question">{question}</p>
      <span class="sp-brace" aria-hidden="true"></span>

      {stations.map((s, i) => (
        <span class={`sp-qword sp-col-${i + 1}`}>{s.qword}</span>
      ))}

      {stations.map((s, i) => (
        <a class={`sp-title sp-col-${i + 1}`} href={s.href} style={`--c: ${s.color};`}>
          <span class="sp-meta">{s.n} · {s.method}</span>
          <span class="sp-name">{s.title}</span>
        </a>
      ))}

      <span class="sp-beam" aria-hidden="true"></span>

      <a class="sp-cap sp-cap-origin" href={origin.href} aria-label={origin.label}>
        <span class="sp-dot sp-dot-origin"></span>
      </a>
      {stations.map((s, i) => (
        <a
          class={`sp-node sp-col-${i + 1}`}
          href={s.href}
          aria-label={s.title}
          style={`--c: ${s.color};`}
        >
          <span class={`sp-dot sp-dot-station${s.capstone ? " sp-dot-capstone" : ""}`}></span>
        </a>
      ))}
      <a class="sp-cap sp-cap-frontier" href={frontier.href} aria-label={frontier.title}>
        <span class="sp-dot sp-dot-frontier"></span>
      </a>

      <span class="sp-caplabel sp-caplabel-origin">{origin.label}</span>
      {stations.map((s, i) => (
        <span class={`sp-tick sp-col-${i + 1}`} aria-hidden="true"></span>
      ))}
      <span class="sp-caplabel sp-caplabel-frontier">{frontier.label}</span>

      <a class="sp-workbench" href={workbench.href}>
        <span class="sp-wb-kicker">Workbench · foundation</span>
        <span class="sp-wb-title">{workbench.title}</span>
        <span class="sp-wb-desc">{workbench.desc}</span>
      </a>

      <p class="sp-offspine">
        <span class="sp-offspine-label">Off the spine · collaborative, in progress</span>
        {groups.map((g, i) => (
          <>
            <span class="sp-offspine-sep">{i === 0 ? "—" : "·"}</span>
            <a href={g.href}>{g.title}</a>
          </>
        ))}
      </p>
    </div>
  </div>
</div>

<style>
  .spine {
    margin-top: 3rem;
  }
  .spine-scroll {
    margin: 0 -1.5rem;
    padding: 0 1.5rem 0.5rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: var(--color-border-strong) transparent;
  }
  .spine-scroll::-webkit-scrollbar { height: 6px; }
  .spine-scroll::-webkit-scrollbar-thumb {
    background: var(--color-border-strong);
    border-radius: 3px;
  }
  .spine-scroll::-webkit-scrollbar-track { background: transparent; }

  /* origin | 01 | 02 | 03 | frontier */
  .spine-grid {
    position: relative;
    min-width: 820px;
    display: grid;
    grid-template-columns: 0.85fr 1fr 1fr 1fr 0.85fr;
    grid-template-rows: auto auto auto auto 30px 34px auto auto;
    align-items: center;
    justify-items: center;
    column-gap: 0.5rem;
  }

  /* column placement — shared by q-words, titles, nodes and ticks */
  .sp-col-1 { grid-column: 2; }
  .sp-col-2 { grid-column: 3; }
  .sp-col-3 { grid-column: 4; }

  /* ---- one question + brace ---- */
  .sp-question {
    grid-column: 2 / 5;
    grid-row: 1;
    margin: 0 0 0.1rem;
    text-align: center;
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--color-text);
  }
  .sp-brace {
    grid-column: 2 / 5;
    grid-row: 2;
    align-self: start;
    width: 78%;
    height: 9px;
    margin-top: 0.15rem;
    border: 1px solid var(--color-border-strong);
    border-bottom: none;
    border-radius: 4px 4px 0 0;
    opacity: 0.8;
  }

  /* ---- progression words ---- */
  .sp-qword {
    grid-row: 3;
    margin-top: 0.9rem;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }

  /* ---- station label (meta + title), above the beam ---- */
  .sp-title {
    grid-row: 4;
    margin-top: 0.4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.18rem;
    text-align: center;
    text-decoration: none;
    padding: 0 0.3rem;
  }
  .sp-meta {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--c, var(--color-text-dim));
  }
  .sp-name {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.25;
    color: var(--color-text);
    transition: color 0.2s ease;
  }
  .sp-title:hover .sp-name { color: var(--c, var(--color-accent)); }

  /* ---- the beam + nodes ---- */
  .sp-beam {
    grid-row: 5;
    grid-column: 1 / 6;
    align-self: center;
    justify-self: stretch;
    height: 2px;
    border-radius: 2px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--color-border-strong) 8%,
      var(--color-border-strong) 60%,
      color-mix(in srgb, var(--accent-deep-purple) 65%, var(--color-border-strong)) 92%,
      transparent
    );
    z-index: 0;
  }
  .sp-node,
  .sp-cap {
    grid-row: 5;
    z-index: 2;
    display: grid;
    place-items: center;
    padding: 6px;
    margin: -6px;
  }
  .sp-cap-origin { grid-column: 1; }
  .sp-cap-frontier { grid-column: 5; }

  .sp-dot {
    display: block;
    border-radius: 50%;
    box-shadow: 0 0 0 4px var(--color-bg);
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }
  .sp-dot-origin {
    width: 12px;
    height: 12px;
    background: var(--color-bg);
    border: 1.5px solid var(--accent-deep-purple);
  }
  .sp-dot-station {
    width: 16px;
    height: 16px;
    background: var(--c, var(--color-accent));
    box-shadow: 0 0 0 4px var(--color-bg), 0 0 0 1px color-mix(in srgb, var(--c) 40%, transparent);
  }
  .sp-dot-capstone {
    width: 18px;
    height: 18px;
    box-shadow:
      0 0 0 4px var(--color-bg),
      0 0 0 7px color-mix(in srgb, var(--c) 20%, transparent),
      0 0 0 8px color-mix(in srgb, var(--c) 42%, transparent);
  }
  .sp-dot-frontier {
    width: 16px;
    height: 16px;
    background: var(--color-bg);
    border: 1.6px dashed var(--accent-deep-purple);
  }
  .sp-node:hover .sp-dot-station { transform: scale(1.16); }
  .sp-cap:hover .sp-dot { transform: scale(1.14); }

  /* ---- bookend labels + up-ticks to the workbench ---- */
  .sp-caplabel {
    grid-row: 6;
    align-self: start;
    margin-top: 0.4rem;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 11.5px;
    line-height: 1.3;
    text-align: center;
    color: var(--color-text-muted);
    max-width: 110px;
  }
  .sp-caplabel-origin { grid-column: 1; }
  .sp-caplabel-frontier { grid-column: 5; }

  .sp-tick {
    grid-row: 6;
    width: 1px;
    height: 100%;
    justify-self: center;
    align-self: stretch;
    background: var(--color-border-strong);
    opacity: 0.45;
  }

  /* ---- the workbench: a quiet foundation note beneath the three (no card) ---- */
  .sp-workbench {
    grid-column: 2 / 5;
    grid-row: 7;
    align-self: start;
    width: 100%;
    max-width: 30rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.12rem;
    padding: 0.1rem 0.5rem 0;
    text-decoration: none;
  }
  .sp-wb-kicker {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }
  .sp-wb-title {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-muted);
    transition: color 0.2s ease;
  }
  .sp-workbench:hover .sp-wb-title { color: var(--color-text); }
  .sp-wb-desc {
    font-size: 11px;
    line-height: 1.45;
    color: var(--color-text-dim);
    max-width: 26rem;
    text-wrap: balance;
  }

  /* ---- off-spine, collaborative work: a quiet one-line note, not boxes ---- */
  .sp-offspine {
    grid-column: 2 / 5;
    grid-row: 8;
    align-self: start;
    margin: 1rem 0 0;
    text-align: center;
    font-size: 11.5px;
    line-height: 1.7;
    color: var(--color-text-dim);
    text-wrap: balance;
  }
  .sp-offspine-label {
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .sp-offspine-sep {
    margin: 0 0.4rem;
    color: var(--color-text-ghost);
  }
  .sp-offspine a {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .sp-offspine a:hover { color: var(--color-text); text-decoration: underline; }
</style>
