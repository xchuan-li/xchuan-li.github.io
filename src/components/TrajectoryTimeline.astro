---
// ResearchSpine — the research arc as ONE vertical line, read top to bottom:
//   ( Leibniz ) the philosophy question
//        |  01 Certify   · is the model using the right structure?   → Stable Is Not Grounded
//        |  02 Localize  · where is the structure used?              → Isotrace
//        |  03 Quantify  · how much inference does the structure support? → Causal Inferential Yield
//        |  Application  · cross-lingual / typological grounding
// MiniCausalLang is the workbench the three run on; the two collaborative projects
// sit OFF the line, in a parallel "side branches" column — beside the spine, never
// on the same axis.
import LeibnizGlyph from "./LeibnizGlyph.astro";

interface Origin {
  label: string;
  href: string;
  hook?: string;
}
interface Station {
  n: string;
  method: string;
  qword: string;
  q?: string;
  title: string;
  color: string;
  href: string;
  capstone?: boolean;
}
interface Frontier {
  label: string;
  title: string;
  href: string;
}
interface Workbench {
  title: string;
  href: string;
  desc: string;
}
interface Group {
  title: string;
  kind: string;
  href: string;
  desc?: string;
}
interface Props {
  question: string;
  origin: Origin;
  stations: Station[];
  frontier: Frontier;
  frontierPilot?: Group;
  workbench: Workbench;
  groups: Group[];
}

const { question, origin, stations, frontier, frontierPilot, workbench, groups } = Astro.props;
---

<div class="vspine">
  <div class="vs-main">
    <ol class="vs-line">
      <!-- origin: the philosophy question -->
      <li class="vs-row vs-origin">
        <a class="vs-node vs-node-origin" href={origin.href} aria-label={origin.label}>
          <LeibnizGlyph size={34} class="vs-leibniz" />
        </a>
        <a class="vs-body vs-origin-body" href={origin.href}>
          <span class="vs-kicker vs-kicker-origin">{origin.label}</span>
          <p class="vs-origin-hook">{origin.hook ?? question}</p>
          {origin.hook && <p class="vs-origin-sub">{question}</p>}
        </a>
      </li>

      <!-- the three method contributions -->
      {stations.map((s) => (
        <li class="vs-row vs-station" style={`--c: ${s.color};`}>
          <a class={`vs-node vs-node-station${s.capstone ? " vs-node-capstone" : ""}`} href={s.href} aria-label={s.title}>
            <span class="vs-dot"></span>
          </a>
          <a class="vs-body vs-station-body" href={s.href}>
            <span class="vs-kicker vs-kicker-station">{s.n} · {s.method}</span>
            {s.q && (
              <span class="vs-q"><span class="vs-qword">{s.qword}</span> — {s.q}</span>
            )}
            <span class="vs-title">{s.title}</span>
          </a>
        </li>
      ))}

      <!-- application frontier -->
      <li class="vs-row vs-frontier">
        <a class="vs-node vs-node-frontier" href={frontier.href} aria-label={frontier.title}>
          <span class="vs-dot vs-dot-frontier"></span>
        </a>
        <div class="vs-body">
          <a class="vs-frontier-link" href={frontier.href}>
            <span class="vs-kicker vs-kicker-frontier">{frontier.label}</span>
            <span class="vs-title vs-title-frontier">{frontier.title}</span>
          </a>
          <p class="vs-frontier-sub">Cross-lingual / typological grounding — the same meaning re-encoded by each language's grammar.</p>
          {frontierPilot && (
            <a class="vs-pilot" href={frontierPilot.href}>
              <span class="vs-pilot-kicker">{frontierPilot.kind}</span>
              <span class="vs-pilot-title">{frontierPilot.title}</span>
              {frontierPilot.desc && <span class="vs-pilot-desc">{frontierPilot.desc}</span>}
            </a>
          )}
        </div>
      </li>
    </ol>

    <!-- the workbench beneath the three -->
    <a class="vs-foundation" href={workbench.href}>
      <span class="vs-foundation-kicker">Workbench · foundation</span>
      <span class="vs-foundation-row">
        <span class="vs-foundation-title">{workbench.title}</span>
        <span class="vs-foundation-desc">{workbench.desc}</span>
      </span>
    </a>
  </div>

  <!-- OFF the spine: collaborative projects, in a parallel column -->
  <aside class="vs-side" aria-label="Side branches and collaborations">
    <p class="vs-side-head">Side branches · collaborations</p>
    <p class="vs-side-note">In-progress group projects that feed the main line — not claimed as my own.</p>
    {groups.map((g) => (
      <a class="vs-branch" href={g.href}>
        <span class="vs-branch-dot" aria-hidden="true"></span>
        <span class="vs-branch-kicker">{g.kind}</span>
        <span class="vs-branch-title">{g.title}</span>
        {g.desc && <span class="vs-branch-desc">{g.desc}</span>}
      </a>
    ))}
  </aside>
</div>

<style>
  .vspine {
    margin-top: 2.5rem;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 16.5rem;
    gap: 2.5rem;
    align-items: start;
  }

  /* ---------- the main vertical line ---------- */
  .vs-line {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .vs-row {
    position: relative;
    display: grid;
    grid-template-columns: 38px 1fr;
    column-gap: 1.1rem;
    padding-bottom: 1.6rem;
  }
  .vs-row:last-child { padding-bottom: 0; }
  /* the beam: a line running dot-to-dot down the rail column */
  .vs-row::before {
    content: "";
    position: absolute;
    left: 18px;
    top: 8px;
    bottom: -8px;
    width: 2px;
    background: var(--color-border-strong);
    border-radius: 2px;
  }
  .vs-row:last-child::before { display: none; }
  .vs-origin::before {
    background: linear-gradient(180deg, color-mix(in srgb, var(--accent-deep-purple) 55%, var(--color-border-strong)), var(--color-border-strong));
  }

  .vs-node {
    grid-column: 1;
    grid-row: 1;
    z-index: 2;
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    align-self: start;
    text-decoration: none;
  }
  .vs-dot {
    display: block;
    width: 15px;
    height: 15px;
    border-radius: 50%;
    background: var(--c, var(--color-accent));
    box-shadow: 0 0 0 4px var(--color-bg), 0 0 0 5px color-mix(in srgb, var(--c) 38%, transparent);
    transition: transform 0.2s ease;
  }
  .vs-node-capstone .vs-dot {
    width: 17px;
    height: 17px;
    box-shadow:
      0 0 0 4px var(--color-bg),
      0 0 0 7px color-mix(in srgb, var(--c) 20%, transparent),
      0 0 0 8px color-mix(in srgb, var(--c) 42%, transparent);
  }
  .vs-dot-frontier {
    background: var(--color-bg);
    border: 1.7px dashed var(--accent-deep-purple);
    box-shadow: 0 0 0 4px var(--color-bg);
  }
  .vs-node:hover .vs-dot { transform: scale(1.16); }

  .vs-node-origin {
    color: var(--accent-deep-purple);
    align-self: start;
  }
  .vs-leibniz {
    background: var(--color-bg);
    border-radius: 50%;
    box-shadow: 0 0 0 4px var(--color-bg);
    transition: transform 0.2s ease;
  }
  .vs-node-origin:hover .vs-leibniz { transform: scale(1.08); }

  /* ---------- row bodies ---------- */
  .vs-body {
    grid-column: 2;
    grid-row: 1;
    display: flex;
    flex-direction: column;
    gap: 0.22rem;
    text-decoration: none;
    min-width: 0;
  }
  .vs-kicker {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  /* origin */
  .vs-origin-body {
    margin: -0.45rem -0.7rem;
    padding: 0.45rem 0.7rem;
    border-radius: 8px;
    transition: background 0.2s ease;
  }
  .vs-origin-body:hover {
    background: color-mix(in srgb, var(--color-bg) 88%, var(--accent-deep-purple) 12%);
  }
  .vs-kicker-origin {
    color: var(--accent-deep-purple);
    font-style: normal;
  }
  .vs-origin-hook {
    margin: 0.15rem 0 0;
    font-family: var(--font-display);
    font-size: 1.18rem;
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--color-text);
    transition: color 0.2s ease;
  }
  .vs-origin-body:hover .vs-origin-hook { color: var(--accent-deep-purple); }
  .vs-origin-sub {
    margin: 0.3rem 0 0;
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--color-text-muted);
    max-width: 46ch;
  }

  /* stations */
  .vs-station-body {
    margin: -0.4rem -0.6rem;
    padding: 0.4rem 0.6rem;
    border-radius: 8px;
    transition: background 0.2s ease;
  }
  .vs-station-body:hover {
    background: color-mix(in srgb, var(--color-bg) 88%, var(--c) 12%);
  }
  .vs-kicker-station { color: var(--c, var(--color-text-dim)); }
  .vs-q {
    font-size: 0.8125rem;
    line-height: 1.4;
    color: var(--color-text-muted);
  }
  .vs-qword {
    font-family: var(--font-mono);
    font-size: 9.5px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }
  .vs-title {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 500;
    line-height: 1.25;
    color: var(--color-text);
    transition: color 0.2s ease;
  }
  .vs-station-body:hover .vs-title { color: var(--c); }

  /* frontier */
  .vs-frontier-link { text-decoration: none; display: flex; flex-direction: column; gap: 0.18rem; }
  .vs-kicker-frontier { color: var(--accent-deep-purple); }
  .vs-title-frontier { color: var(--color-text-muted); }
  .vs-frontier-link:hover .vs-title-frontier { color: var(--color-text); }
  .vs-frontier-sub {
    margin: 0.15rem 0 0;
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--color-text-dim);
    max-width: 44ch;
  }
  .vs-pilot {
    margin-top: 0.7rem;
    display: inline-flex;
    flex-direction: column;
    gap: 0.1rem;
    padding: 0.5rem 0.8rem;
    border: 1px solid color-mix(in srgb, var(--accent-teal-deep) 40%, var(--color-border));
    border-left-width: 2.5px;
    border-left-color: var(--accent-teal-deep);
    border-radius: 0 6px 6px 0;
    background: color-mix(in srgb, var(--color-bg) 84%, var(--accent-teal-deep) 16%);
    text-decoration: none;
    align-self: start;
    transition: transform 0.2s ease, background 0.2s ease;
  }
  .vs-pilot:hover { transform: translateX(2px); }
  .vs-pilot-kicker {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-teal-deep);
  }
  .vs-pilot-title {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
  }
  .vs-pilot-desc {
    font-size: 11px;
    line-height: 1.45;
    color: var(--color-text-dim);
    max-width: 30ch;
  }

  /* ---------- foundation note ---------- */
  .vs-foundation {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    margin-top: 1.5rem;
    margin-left: calc(38px + 1.1rem);
    padding: 0.7rem 0.9rem;
    border: 0.5px dashed var(--color-border-strong);
    border-radius: 8px;
    background: var(--color-surface);
    text-decoration: none;
    transition: border-color 0.2s ease;
  }
  .vs-foundation:hover { border-color: color-mix(in srgb, var(--color-text-muted) 40%, var(--color-border-strong)); }
  .vs-foundation-kicker {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }
  .vs-foundation-row { display: flex; align-items: baseline; gap: 0.55rem; flex-wrap: wrap; }
  .vs-foundation-title {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text);
  }
  .vs-foundation-desc {
    font-size: 0.8125rem;
    line-height: 1.45;
    color: var(--color-text-muted);
  }

  /* ---------- side column: collaborations, off the axis ---------- */
  .vs-side {
    position: relative;
    padding-left: 1.4rem;
    border-left: 1px dashed var(--color-border-strong);
    align-self: stretch;
  }
  .vs-side-head {
    margin: 0.3rem 0 0.15rem;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }
  .vs-side-note {
    margin: 0 0 1rem;
    font-size: 11.5px;
    line-height: 1.5;
    color: var(--color-text-dim);
    font-style: italic;
    max-width: 22ch;
  }
  .vs-branch {
    position: relative;
    display: grid;
    gap: 0.16rem;
    margin-bottom: 0.9rem;
    padding: 0.65rem 0.8rem;
    border: 1px solid var(--color-border);
    border-radius: 7px;
    background: var(--color-surface);
    text-decoration: none;
    transition: border-color 0.2s ease, transform 0.2s ease, background 0.2s ease;
  }
  .vs-branch:last-child { margin-bottom: 0; }
  .vs-branch::after {
    content: "";
    position: absolute;
    left: -1.4rem;
    top: 1.1rem;
    width: 1.4rem;
    height: 1px;
    background: var(--color-border-strong);
  }
  .vs-branch-dot {
    position: absolute;
    left: calc(-1.4rem - 4px);
    top: calc(1.1rem - 4px);
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-bg);
    border: 1.4px solid var(--color-text-dim);
  }
  .vs-branch:hover {
    transform: translateY(-2px);
    border-color: var(--color-border-strong);
    background: color-mix(in srgb, var(--color-surface) 80%, var(--color-text) 5%);
  }
  .vs-branch-kicker {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }
  .vs-branch-title {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.22;
    color: var(--color-text);
  }
  .vs-branch-desc {
    font-size: 11px;
    line-height: 1.45;
    color: var(--color-text-dim);
  }

  /* ---------- responsive: side column drops below the spine ---------- */
  @media (max-width: 820px) {
    .vspine {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }
    .vs-side {
      padding-left: 0;
      border-left: none;
      border-top: 1px dashed var(--color-border-strong);
      padding-top: 1.4rem;
    }
    .vs-side-note { max-width: none; }
    .vs-branch::after, .vs-branch-dot { display: none; }
  }
</style>
