---
// ResearchSpine — a structured roadmap for the homepage.
// The main lane carries ideas and the three-paper sequence; lighter branches
// show the supporting sandbox and the two extensions.
interface SpineItem {
  kind: "idea" | "paper";
  label?: string;
  title?: string;
  n?: string;
  color?: string;
  href: string;
}

interface BranchItem {
  title: string;
  kicker: string;
  desc: string;
  href: string;
  color: string;
  anchor?: number;
}

interface Props {
  spine: SpineItem[];
  sandbox: BranchItem;
  extensions: BranchItem[];
}

const { spine, sandbox, extensions } = Astro.props;
const cols = spine.length;
const sandboxAnchor = sandbox.anchor ?? Math.max(1, cols - 1);
const extensionAnchor = extensions[0]?.anchor ?? Math.max(1, cols - 2);
const sandboxLeft = `${((sandboxAnchor - 0.5) / cols) * 100}%`;
const extensionLeft = `${((extensionAnchor - 0.5) / cols) * 100}%`;
---

<div class="spine-scroll">
  <div class="spine-map" style={`--cols: ${cols}; --sandbox-anchor: ${sandboxAnchor}; --extension-anchor: ${extensionAnchor};`}>
    <div class="spine-track-label">Main research spine</div>

    <ol class="spine-main">
      {
        spine.map((it) => (
          <li
            class={`spine-item spine-${it.kind}`}
            style={it.kind === "paper" && it.color ? `--c: ${it.color};` : undefined}
          >
            {it.kind === "idea" && (
              <a class="spine-tag spine-tag-above" href={it.href}>
                <span class="spine-kicker">Idea</span>
                <span class="spine-label spine-label-idea">{it.label}</span>
              </a>
            )}

            <span class="spine-node" aria-hidden="true"></span>

            {it.kind === "paper" && (
              <a class="spine-tag spine-tag-below" href={it.href}>
                <span class="spine-num">{it.n}</span>
                <span class="spine-label spine-label-paper">{it.title}</span>
              </a>
            )}
          </li>
        ))
      }
    </ol>

    <div class="spine-branches">
      <a
        class="branch-card branch-sandbox"
        href={sandbox.href}
        style={`--c: ${sandbox.color}; --branch-left: ${sandboxLeft};`}
      >
        <span class="branch-kicker">{sandbox.kicker}</span>
        <span class="branch-title">{sandbox.title}</span>
        <span class="branch-desc">{sandbox.desc}</span>
      </a>

      <div class="extension-group" style={`--branch-left: ${extensionLeft};`}>
        <div class="extension-heading">
          <span class="branch-kicker">Extensions</span>
          <span>Mechanistic and applied side lines</span>
        </div>
        <div class="extension-cards">
          {
            extensions.map((it) => (
              <a class="branch-card branch-extension" href={it.href} style={`--c: ${it.color};`}>
                <span class="branch-dot" aria-hidden="true"></span>
                <span class="branch-kicker">{it.kicker}</span>
                <span class="branch-title">{it.title}</span>
                <span class="branch-desc">{it.desc}</span>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
  <div class="spine-hint" aria-hidden="true">scroll</div>
</div>

<style>
  .spine-scroll {
    margin: 3rem -1.5rem 0;
    padding: 0 1.5rem 0.5rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: var(--color-border-strong) transparent;
  }
  .spine-scroll::-webkit-scrollbar { height: 6px; }
  .spine-scroll::-webkit-scrollbar-thumb {
    background: var(--color-border-strong);
    border-radius: 3px;
  }
  .spine-scroll::-webkit-scrollbar-track { background: transparent; }

  .spine-map {
    position: relative;
    min-width: 1120px;
    padding-top: 1.75rem;
  }

  .spine-track-label {
    position: absolute;
    top: 0;
    left: 0;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }

  .spine-main {
    list-style: none;
    margin: 0;
    padding: 0;
    position: relative;
    display: grid;
    grid-template-columns: repeat(var(--cols), minmax(136px, 1fr));
    align-items: stretch;
    height: 260px;
  }
  .spine-main::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--color-border-strong) 5%,
      var(--color-border-strong) 84%,
      color-mix(in srgb, var(--color-border-strong) 40%, transparent),
      transparent
    );
    transform: translateY(-0.5px);
    z-index: 0;
  }

  .spine-item {
    position: relative;
    display: grid;
    grid-template-rows: 1fr auto 1fr;
    align-items: center;
    justify-items: center;
    padding: 0 0.45rem;
  }

  .spine-node {
    position: relative;
    z-index: 2;
    grid-row: 2;
    display: block;
    border-radius: 50%;
    transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease;
  }
  .spine-idea .spine-node {
    width: 14px;
    height: 14px;
    background: var(--color-bg);
    border: 1.5px solid var(--accent-deep-purple);
    box-shadow: 0 0 0 4px var(--color-bg);
  }
  .spine-paper .spine-node {
    width: 17px;
    height: 17px;
    background: var(--c, var(--color-accent));
    box-shadow: 0 0 0 4px var(--color-bg), 0 0 0 1px color-mix(in srgb, var(--c) 40%, transparent);
  }
  .spine-item:hover .spine-node { transform: scale(1.16); }
  .spine-paper:hover .spine-node {
    box-shadow: 0 0 0 4px var(--color-bg), 0 0 0 7px color-mix(in srgb, var(--c) 28%, transparent);
  }

  .spine-tag {
    text-decoration: none;
    color: inherit;
    text-align: center;
    width: 100%;
    max-width: 148px;
    display: block;
    padding: 0 0.25rem;
    transition: color 0.2s ease, transform 0.25s ease;
  }
  .spine-tag-above {
    grid-row: 1;
    align-self: end;
    padding-bottom: 1.1rem;
  }
  .spine-tag-below {
    grid-row: 3;
    align-self: start;
    padding-top: 1.1rem;
  }
  .spine-tag-above::after,
  .spine-tag-below::before {
    content: "";
    display: block;
    width: 1px;
    height: 14px;
    margin: 0 auto;
    background: var(--color-border-strong);
  }
  .spine-tag-above::after { margin-top: 0.5rem; }
  .spine-tag-below::before { margin-bottom: 0.5rem; }

  .spine-kicker,
  .spine-num,
  .branch-kicker {
    font-family: var(--font-mono);
    font-size: 9.5px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    display: block;
  }
  .spine-kicker {
    color: var(--accent-deep-purple);
    margin-bottom: 0.35rem;
    opacity: 0.85;
  }
  .spine-num {
    color: var(--c, var(--color-text-dim));
    margin-bottom: 0.35rem;
  }
  .spine-label {
    display: block;
    line-height: 1.3;
  }
  .spine-label-idea {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 14px;
    color: var(--color-text);
  }
  .spine-label-paper {
    font-family: var(--font-display);
    font-size: 12.5px;
    font-weight: 500;
    color: var(--color-text);
    letter-spacing: 0;
  }
  .spine-idea:hover .spine-label-idea { color: var(--accent-deep-purple); }
  .spine-paper:hover .spine-label-paper { color: var(--c, var(--color-accent)); }

  .spine-branches {
    position: relative;
    height: 285px;
    margin-top: -2.1rem;
  }

  .branch-card,
  .extension-group {
    position: absolute;
    left: var(--branch-left);
    transform: translateX(-50%);
  }

  .branch-card {
    display: block;
    width: 258px;
    padding: 1rem 1rem 1.05rem;
    border: 1px solid color-mix(in srgb, var(--c) 32%, var(--card-border));
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--c) 9%, transparent), transparent 70%),
      var(--card-bg);
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.25s ease;
  }
  .branch-card:hover {
    border-color: color-mix(in srgb, var(--c) 58%, var(--card-hover-border));
    transform: translateX(-50%) translateY(-2px);
  }
  .branch-card::before {
    content: "";
    position: absolute;
    left: 50%;
    top: -34px;
    width: 1px;
    height: 34px;
    background: linear-gradient(180deg, var(--color-border-strong), color-mix(in srgb, var(--c) 48%, transparent));
  }
  .branch-card::after {
    content: "";
    position: absolute;
    left: calc(50% - 4px);
    top: -4px;
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--c);
    box-shadow: 0 0 0 4px var(--color-bg);
  }
  .branch-sandbox {
    top: 0;
    --c: var(--accent-slate);
  }
  .branch-sandbox:hover { transform: translateX(-50%) translateY(-2px); }
  .branch-kicker {
    color: var(--c);
    margin-bottom: 0.45rem;
  }
  .branch-title {
    display: block;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.25;
    color: var(--color-text);
    margin-bottom: 0.45rem;
  }
  .branch-desc {
    display: block;
    font-size: 12px;
    line-height: 1.55;
    color: var(--color-text-muted);
  }

  .extension-group {
    top: 124px;
    width: 560px;
    padding-top: 1.6rem;
  }
  .extension-group::before {
    content: "";
    position: absolute;
    left: 50%;
    top: -28px;
    width: 1px;
    height: 42px;
    background: linear-gradient(180deg, var(--color-border-strong), color-mix(in srgb, var(--accent-amber) 28%, transparent));
  }
  .extension-group::after {
    content: "";
    position: absolute;
    left: 12%;
    right: 12%;
    top: 13px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-border), var(--color-border), transparent);
  }
  .extension-heading {
    position: relative;
    z-index: 1;
    width: max-content;
    margin: 0 auto 0.85rem;
    padding: 0 0.8rem;
    background: var(--color-bg);
    text-align: center;
    color: var(--color-text-muted);
    font-size: 12px;
    line-height: 1.3;
  }
  .extension-heading .branch-kicker {
    color: var(--color-text-dim);
    margin-bottom: 0.2rem;
  }
  .extension-cards {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
  }
  .branch-extension {
    position: relative;
    left: auto;
    transform: none;
    width: auto;
    min-height: 128px;
    padding-left: 2.1rem;
  }
  .branch-extension:hover { transform: translateY(-2px); }
  .branch-extension::before,
  .branch-extension::after {
    display: none;
  }
  .branch-dot {
    position: absolute;
    left: 1rem;
    top: 1.13rem;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--c);
  }

  .spine-hint {
    display: none;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    margin-top: 0.75rem;
  }

  @media (max-width: 880px) {
    .spine-map { min-width: 1060px; }
    .spine-main { height: 250px; }
    .spine-hint { display: block; }
  }
</style>
