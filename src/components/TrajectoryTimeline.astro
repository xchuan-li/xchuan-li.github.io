---
// ResearchSpine — a structured roadmap for the homepage.
// One thick main axis runs left to right and converges on the thesis result (CIY).
// Each project is a single node on the axis; the idea(s) that motivate it sit
// stacked directly above it, chained by short lines (one idea = one tick; two
// ideas = stacked, one above the other). Two side studies branch off the axis as
// thin linear forks before the capstone, feeding into it.
interface Idea {
  label: string;
  href: string;
}

interface SpineItem {
  kind: "idea" | "paper" | "sandbox";
  href: string;
  // origin idea node
  label?: string;
  // project node
  n?: string;
  title?: string;
  color?: string;
  capstone?: boolean;
  // ideas stacked above a project
  ideas?: Idea[];
  // ideas stacked below a project (between node and label)
  ideasBelow?: Idea[];
}

interface BranchItem {
  title: string;
  kicker: string;
  desc: string;
  href: string;
  color: string;
  anchor: number;
}

interface Props {
  spine: SpineItem[];
  extensions: BranchItem[];
}

const { spine, extensions } = Astro.props;
const cols = spine.length;
// Each extension branches from its own anchor on the main axis.
// Card is offset horizontally so two cards don't overlap.
const extMeta = extensions.map((ext, i) => {
  const anchorPct = ((ext.anchor - 0.5) / cols) * 100;
  const cardPct = anchorPct + (i === 0 ? -8 : 8); // first left, second right
  return { ...ext, anchorPct, cardPct };
});
---

<div class="spine-scroll">
  <div class="spine-map" style={`--cols: ${cols};`}>
    <div class="spine-track-label">Main research spine</div>

    <ol class="spine-main">
      {
        spine.map((it) => (
          <li
            class={`spine-item spine-${it.kind}${it.capstone ? " spine-capstone" : ""}`}
            style={it.color ? `--c: ${it.color};` : undefined}
          >
            {it.kind === "idea" && (
              <a class="spine-ideas spine-ideas-origin" href={it.href}>
                <span class="spine-idea-tag">
                  <span class="spine-kicker">Idea</span>
                  <span class="spine-label spine-label-idea">{it.label}</span>
                </span>
                <span class="spine-idea-stem" aria-hidden="true" />
              </a>
            )}

            {it.ideas && (
              <div class="spine-ideas">
                {it.ideas.map((idea, i) => (
                  <>
                    {i > 0 && <span class="spine-idea-stem spine-idea-stem-mid" aria-hidden="true" />}
                    <a class="spine-idea-tag" href={idea.href}>
                      <span class="spine-kicker">Idea</span>
                      <span class="spine-label spine-label-idea">{idea.label}</span>
                    </a>
                  </>
                ))}
                <span class="spine-idea-stem" aria-hidden="true" />
              </div>
            )}

            <span class={`spine-node spine-node-${it.kind}`} aria-hidden="true" />

            {(it.kind === "paper" || it.kind === "sandbox") && (
              <div class="spine-below">
                {it.ideasBelow?.map((idea) => (
                  <>
                    <a class="spine-below-idea" href={idea.href}>
                      <span class="spine-kicker">Idea</span>
                      <span class="spine-label spine-label-idea">{idea.label}</span>
                    </a>
                    <span class="spine-idea-stem" aria-hidden="true" />
                  </>
                ))}
                <a class="spine-tag" href={it.href}>
                  <span class="spine-num">{it.n}</span>
                  <span class="spine-label spine-label-paper">{it.title}</span>
                </a>
              </div>
            )}
          </li>
        ))
      }
    </ol>

    <div class="spine-branches">
      <svg class="branch-fork" viewBox="0 0 100 64" preserveAspectRatio="none" aria-hidden="true">
        {extMeta.map((ext) => (
          <path d={`M ${ext.anchorPct} -77 L ${ext.anchorPct} 16 L ${ext.cardPct} 56`} />
        ))}
      </svg>
      {
        extMeta.map((ext) => (
          <a class="side-study" href={ext.href} style={`--c: ${ext.color}; --x: ${ext.cardPct}%;`}>
            <span class="side-study-dot" aria-hidden="true" />
            <span class="branch-kicker">{ext.kicker}</span>
            <span class="branch-title">{ext.title}</span>
            <span class="branch-desc">{ext.desc}</span>
          </a>
        ))
      }
    </div>
  </div>
  <div class="spine-hint" aria-hidden="true">scroll</div>
</div>

<style>
  .spine-scroll {
    margin: 3rem -1.5rem 0;
    padding: 0 1.5rem 0.5rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: var(--color-border-strong) transparent;
  }
  .spine-scroll::-webkit-scrollbar { height: 6px; }
  .spine-scroll::-webkit-scrollbar-thumb {
    background: var(--color-border-strong);
    border-radius: 3px;
  }
  .spine-scroll::-webkit-scrollbar-track { background: transparent; }

  .spine-map {
    position: relative;
    min-width: 1080px;
    padding-top: 1.75rem;
  }

  .spine-track-label {
    position: absolute;
    top: 0;
    left: 0;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }

  .spine-main {
    list-style: none;
    margin: 0;
    padding: 0;
    position: relative;
    display: grid;
    grid-template-columns: repeat(var(--cols), minmax(150px, 1fr));
    align-items: stretch;
    height: 236px;
  }
  /* main axis — thicker line, strengthening toward the capstone on the right */
  .spine-main::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 137px;
    height: 2px;
    border-radius: 2px;
    background: linear-gradient(
      90deg,
      transparent,
      color-mix(in srgb, var(--color-border-strong) 60%, transparent) 6%,
      var(--color-border-strong) 55%,
      color-mix(in srgb, var(--accent-purple) 70%, var(--color-border-strong)) 93%,
      transparent
    );
    transform: translateY(-1px);
    z-index: 0;
  }

  .spine-item {
    position: relative;
    display: grid;
    grid-template-rows: 130px auto minmax(66px, auto);
    align-items: center;
    justify-items: center;
    padding: 0 0.45rem;
  }

  /* ---- nodes ---- */
  .spine-node {
    position: relative;
    z-index: 2;
    grid-row: 2;
    display: block;
    border-radius: 50%;
    transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease;
  }
  .spine-node-idea {
    width: 14px;
    height: 14px;
    background: var(--color-bg);
    border: 1.5px solid var(--accent-deep-purple);
    box-shadow: 0 0 0 4px var(--color-bg);
  }
  .spine-node-paper {
    width: 17px;
    height: 17px;
    background: var(--c, var(--color-accent));
    box-shadow: 0 0 0 4px var(--color-bg), 0 0 0 1px color-mix(in srgb, var(--c) 40%, transparent);
  }
  /* sandbox node — a rounded square marks tooling, not a paper */
  .spine-node-sandbox {
    width: 16px;
    height: 16px;
    border-radius: 4px;
    background: var(--c, var(--accent-slate));
    box-shadow: 0 0 0 4px var(--color-bg), 0 0 0 1px color-mix(in srgb, var(--c) 40%, transparent);
  }

  /* capstone (CIY) — emphasized convergence target */
  .spine-capstone .spine-node-paper {
    width: 19px;
    height: 19px;
    box-shadow:
      0 0 0 4px var(--color-bg),
      0 0 0 7px color-mix(in srgb, var(--c) 22%, transparent),
      0 0 0 8px color-mix(in srgb, var(--c) 45%, transparent);
  }

  .spine-idea:hover .spine-node-idea,
  .spine-sandbox:hover .spine-node-sandbox,
  .spine-paper:hover .spine-node { transform: scale(1.16); }
  .spine-paper:hover .spine-node-paper {
    box-shadow: 0 0 0 4px var(--color-bg), 0 0 0 7px color-mix(in srgb, var(--c) 28%, transparent);
  }

  /* ---- stacked ideas above a project ---- */
  .spine-ideas {
    grid-row: 1;
    align-self: stretch;
    width: 100%;
    max-width: 178px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    gap: 0.32rem;
    text-decoration: none;
    color: inherit;
  }
  .spine-idea-tag {
    text-decoration: none;
    color: inherit;
    text-align: center;
    display: block;
    transition: color 0.2s ease;
  }
  a.spine-idea-tag:hover .spine-label-idea,
  .spine-ideas-origin:hover .spine-label-idea,
  .spine-below-idea:hover .spine-label-idea { color: var(--accent-deep-purple); }
  .spine-idea-stem {
    width: 1px;
    height: 13px;
    flex: none;
    background: var(--color-border-strong);
  }
  .spine-idea-stem-mid { height: 12px; }

  /* ---- text tags below the node ---- */
  .spine-below {
    grid-row: 3;
    align-self: start;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 156px;
    margin: 0 auto;
    padding-top: 1.1rem;
    text-align: center;
  }
  .spine-below::before {
    content: "";
    display: block;
    width: 1px;
    height: 14px;
    margin-bottom: 0.5rem;
    background: var(--color-border-strong);
  }
  .spine-below .spine-tag {
    text-decoration: none;
    color: inherit;
    text-align: center;
    width: 100%;
    display: block;
    padding: 0 0.25rem;
    transition: color 0.2s ease;
  }
  .spine-below .spine-below-idea {
    text-decoration: none;
    color: inherit;
    text-align: center;
    display: block;
    transition: color 0.2s ease;
  }
  .spine-below .spine-idea-stem {
    width: 1px;
    height: 13px;
    flex: none;
    background: var(--color-border-strong);
    margin: 0.28rem 0;
  }

  .spine-kicker,
  .spine-num,
  .branch-kicker {
    font-family: var(--font-mono);
    font-size: 9.5px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    display: block;
  }
  .spine-kicker {
    color: var(--accent-deep-purple);
    margin-bottom: 0.3rem;
    opacity: 0.85;
  }
  .spine-num {
    color: var(--c, var(--color-text-dim));
    margin-bottom: 0.35rem;
  }
  .spine-label {
    display: block;
    line-height: 1.3;
  }
  .spine-label-idea {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 13.5px;
    color: var(--color-text);
  }
  .spine-label-paper {
    font-family: var(--font-display);
    font-size: 12.5px;
    font-weight: 500;
    color: var(--color-text);
    letter-spacing: 0;
  }
  .spine-paper:hover .spine-label-paper,
  .spine-sandbox:hover .spine-label-paper { color: var(--c, var(--color-accent)); }

  /* ---- side studies: thin linear branches off the axis, before the capstone ---- */
  .spine-branches {
    position: relative;
    height: 184px;
    margin-top: 0;
  }
  .branch-fork {
    position: absolute;
    inset: 0 0 auto 0;
    width: 100%;
    height: 64px;
    overflow: visible;
  }
  .branch-fork path {
    fill: none;
    stroke: color-mix(in srgb, var(--accent-amber) 36%, var(--color-border-strong));
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
  }

  .side-study {
    position: absolute;
    left: var(--x);
    top: 60px;
    transform: translateX(-50%);
    width: 218px;
    padding-top: 0.9rem;
    text-align: center;
    text-decoration: none;
    color: inherit;
  }
  .side-study-dot {
    position: absolute;
    top: -4px;
    left: 50%;
    transform: translateX(-50%);
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--c);
    box-shadow: 0 0 0 4px var(--color-bg);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .side-study:hover .side-study-dot {
    transform: translateX(-50%) scale(1.18);
    box-shadow: 0 0 0 4px var(--color-bg), 0 0 0 7px color-mix(in srgb, var(--c) 26%, transparent);
  }
  .branch-kicker {
    color: var(--c);
    margin-bottom: 0.4rem;
  }
  .branch-title {
    display: block;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.25;
    color: var(--color-text);
    margin-bottom: 0.4rem;
    transition: color 0.2s ease;
  }
  .side-study:hover .branch-title { color: var(--c); }
  .branch-desc {
    display: block;
    font-size: 12px;
    line-height: 1.55;
    color: var(--color-text-muted);
    max-width: 16rem;
    margin: 0 auto;
  }

  .spine-hint {
    display: none;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    margin-top: 0.75rem;
  }

  @media (max-width: 880px) {
    .spine-map { min-width: 1040px; }
    .spine-hint { display: block; }
  }
</style>
