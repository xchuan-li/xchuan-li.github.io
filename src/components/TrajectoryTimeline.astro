---
// ResearchSpine - Apple-style scroll narrative for the homepage research section.
// The page now starts from a historical portrait and philosophical question, then
// lets the causal-interpretability program assemble step by step.

interface Origin {
  label: string;
  href: string;
  hook?: string;
}
interface Station {
  n: string;
  method: string;
  qword: string;
  q?: string;
  title: string;
  color: string;
  href: string;
  capstone?: boolean;
}
interface Frontier {
  label: string;
  title: string;
  href: string;
}
interface Workbench {
  title: string;
  href: string;
  desc: string;
}
interface Group {
  title: string;
  kind: string;
  href: string;
  desc?: string;
}
interface Props {
  question: string;
  origin: Origin;
  stations: Station[];
  frontier: Frontier;
  workbench: Workbench;
  groups: Group[];
}

const { question, origin, stations, frontier, workbench, groups } = Astro.props;

const portraitSrc = "/images/leibniz-portrait.jpg";
const mainNodes = [
  {
    key: "origin",
    label: "Leibniz",
    title: origin.hook ?? question,
    color: "var(--accent-deep-purple)",
    href: origin.href,
  },
  ...stations.map((s, i) => ({
    key: `station-${i}`,
    label: `${s.n} · ${s.method}`,
    title: s.title,
    color: s.color,
    href: s.href,
  })),
  {
    key: "foundation",
    label: "Workbench",
    title: workbench.title,
    color: "var(--accent-slate)",
    href: workbench.href,
  },
];
---

<div class="scroll-spine" data-active="origin">
  <div class="ss-visual" aria-hidden="false">
    <a class="ss-portrait" href={origin.href} aria-label={origin.label}>
      <img src={portraitSrc} alt="Artistic portrait of Gottfried Wilhelm Leibniz" loading="lazy" decoding="async" />
    </a>

    <div class="ss-map" aria-label="Research mainline">
      <div class="ss-rail" aria-hidden="true"></div>
      {mainNodes.map((node, i) => (
        <a
          class={`ss-node${i === 0 ? " is-active" : ""}`}
          data-node={node.key}
          href={node.href}
          style={`--y: ${2 + i * 7.2}rem; --c: ${node.color};`}
        >
          <span class="ss-node-dot" aria-hidden="true"></span>
          <span class="ss-node-label">{node.label}</span>
          <span class="ss-node-title">{node.title}</span>
        </a>
      ))}
    </div>

    <aside class="ss-branches" aria-label="Collaborations and side branches">
      <p class="ss-branches-kicker">Collaborations</p>
      {groups.map((g) => (
        <a class="ss-branch" href={g.href}>
          <span class="ss-branch-kind">{g.kind}</span>
          <span class="ss-branch-title">{g.title}</span>
          {g.desc && <span class="ss-branch-desc">{g.desc}</span>}
        </a>
      ))}
    </aside>
  </div>

  <div class="ss-story">
    <section class="ss-stage ss-stage-origin" data-stage="origin">
      <p class="ss-kicker">{origin.label}</p>
      <h3>{origin.hook ?? "What is a right reason?"}</h3>
      <p>
        The program starts before machine learning: what makes an answer licensed by the
        structure that ought to support it?
      </p>
      <a class="ss-inline-link" href={origin.href}>Read the philosophical bridge</a>
    </section>

    <section class="ss-stage" data-stage="question">
      <p class="ss-kicker">Translated into ML</p>
      <h3>{question}</h3>
      <p>
        In language, the right reason is often visible: the governing head, the dependency, the
        morphology, the word order, or the context that actually licenses the conclusion.
      </p>
    </section>

    {stations.map((s, i) => (
      <section class="ss-stage" data-stage={`station-${i}`}>
        <p class="ss-kicker" style={`--c: ${s.color};`}>{s.n} · {s.method}</p>
        <h3>{s.title}</h3>
        {s.q && (
          <p class="ss-question">
            <span>{s.qword}</span> — {s.q}
          </p>
        )}
        <p>
          {i === 0 && "First, certify whether stable-correct behavior is licensed by genuine structure at all."}
          {i === 1 && "Then localize where that structure is being used, rather than merely observing that the final answer is right."}
          {i === 2 && "Finally, quantify how much inferential work the grounded structure actually supports."}
        </p>
        <a class="ss-inline-link" href={s.href}>Open project</a>
      </section>
    ))}

    <section class="ss-stage" data-stage="foundation">
      <p class="ss-kicker">Foundation</p>
      <h3>{workbench.title}</h3>
      <p>{workbench.desc}</p>
      <p>
        The methods need an answer key for structure. The workbench supplies known graphs so
        certification, localization, and yield can be tested against something observable.
      </p>
      <a class="ss-inline-link" href={workbench.href}>Open workbench</a>
    </section>

    <section class="ss-stage ss-stage-collabs" data-stage="collabs">
      <p class="ss-kicker">Right-side branches</p>
      <h3>Collaborations feed the spine without becoming the spine.</h3>
      <p>
        These projects sit to the right of the main line: they extend, stress-test, or apply the
        structure-versus-surface question, but they are not presented as the three core method
        contributions.
      </p>
      <a class="ss-inline-link" href={frontier.href}>{frontier.title} remains the application horizon</a>
    </section>
  </div>
</div>

<style>
  .scroll-spine {
    --ss-pin-top: 86px;
    margin-top: 2.75rem;
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(18rem, 0.65fr);
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: start;
  }

  .ss-visual {
    position: sticky;
    top: var(--ss-pin-top);
    min-height: calc(100vh - var(--ss-pin-top) - 2rem);
    display: grid;
    grid-template-columns: minmax(0, 1fr) 15.5rem;
    gap: 2rem;
    align-items: center;
  }

  .ss-portrait {
    position: absolute;
    top: 0;
    left: clamp(0rem, 4vw, 3rem);
    z-index: 3;
    display: block;
    width: min(28rem, 72%);
    aspect-ratio: 4 / 5;
    border-radius: 10px;
    overflow: hidden;
    background: var(--color-surface);
    border: 1px solid color-mix(in srgb, var(--accent-deep-purple) 28%, var(--color-border));
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-bg) 80%, transparent);
    transition:
      width 0.7s cubic-bezier(.2,.8,.2,1),
      opacity 0.35s ease,
      transform 0.7s cubic-bezier(.2,.8,.2,1),
      filter 0.45s ease;
  }
  .ss-portrait img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: 50% 34%;
    filter: saturate(0.82) contrast(1.05);
  }
  .scroll-spine:not([data-active="origin"]) .ss-portrait {
    width: 8.5rem;
    opacity: 0.72;
    transform: translateY(-0.6rem);
    filter: grayscale(0.1);
  }

  .ss-map {
    grid-column: 1;
    position: relative;
    min-height: 35rem;
    margin: 8rem 0 0 clamp(4rem, 12vw, 10rem);
    transition: opacity 0.35s ease, transform 0.45s ease;
  }
  .scroll-spine[data-active="origin"] .ss-map {
    opacity: 0.18;
    transform: translateY(1.25rem);
  }
  .ss-rail {
    position: absolute;
    left: 0;
    top: 1.2rem;
    bottom: 1.2rem;
    width: 2px;
    border-radius: 999px;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--accent-deep-purple) 68%, var(--color-border-strong)),
      var(--color-border-strong) 48%,
      color-mix(in srgb, var(--accent-slate) 62%, var(--color-border-strong))
    );
  }
  .ss-node {
    position: absolute;
    left: 0;
    top: var(--y);
    display: grid;
    grid-template-columns: 1.2rem minmax(0, 1fr);
    gap: 0.85rem;
    width: min(28rem, 88%);
    text-decoration: none;
    color: inherit;
    opacity: 0.38;
    transform: translateX(0);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }
  .ss-node.is-active {
    opacity: 1;
    transform: translateX(0.35rem);
  }
  .ss-node-dot {
    width: 13px;
    height: 13px;
    margin-top: 0.25rem;
    border-radius: 50%;
    background: var(--c);
    box-shadow:
      0 0 0 5px var(--color-bg),
      0 0 0 6px color-mix(in srgb, var(--c) 34%, transparent);
  }
  .ss-node.is-active .ss-node-dot {
    box-shadow:
      0 0 0 5px var(--color-bg),
      0 0 0 8px color-mix(in srgb, var(--c) 18%, transparent),
      0 0 0 9px color-mix(in srgb, var(--c) 44%, transparent);
  }
  .ss-node-label {
    grid-column: 2;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--c);
  }
  .ss-node-title {
    grid-column: 2;
    margin-top: 0.12rem;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.25;
    color: var(--color-text);
  }

  .ss-branches {
    grid-column: 2;
    justify-self: stretch;
    align-self: center;
    padding-left: 1.1rem;
    border-left: 1px dashed var(--color-border-strong);
    opacity: 0.18;
    transform: translateX(0.75rem);
    transition: opacity 0.35s ease, transform 0.35s ease;
  }
  .scroll-spine[data-active="collabs"] .ss-branches,
  .scroll-spine[data-active="foundation"] .ss-branches {
    opacity: 1;
    transform: translateX(0);
  }
  .ss-branches-kicker {
    margin: 0 0 0.8rem;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }
  .ss-branch {
    position: relative;
    display: grid;
    gap: 0.2rem;
    margin: 0 0 0.85rem;
    padding: 0.72rem 0.82rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: color-mix(in srgb, var(--color-surface) 86%, transparent);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
  }
  .ss-branch::before {
    content: "";
    position: absolute;
    left: -1.1rem;
    top: 1.25rem;
    width: 1.1rem;
    height: 1px;
    background: var(--color-border-strong);
  }
  .ss-branch:hover {
    transform: translateY(-2px);
    border-color: var(--color-border-strong);
    background: var(--color-surface);
  }
  .ss-branch-kind {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }
  .ss-branch-title {
    font-family: var(--font-display);
    font-size: 0.92rem;
    font-weight: 500;
    line-height: 1.25;
    color: var(--color-text);
  }
  .ss-branch-desc {
    font-size: 11.5px;
    line-height: 1.45;
    color: var(--color-text-dim);
  }

  .ss-story {
    position: relative;
    z-index: 4;
  }
  .ss-stage {
    min-height: 72vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 5rem 0;
  }
  .ss-stage-origin { min-height: 82vh; }
  .ss-stage-collabs { min-height: 68vh; }
  .ss-kicker {
    margin: 0 0 0.85rem;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--c, var(--accent-deep-purple));
  }
  .ss-stage h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.8vw, 4.8rem);
    font-weight: 700;
    line-height: 1.02;
    color: var(--color-text);
  }
  .ss-stage p {
    margin: 1.1rem 0 0;
    max-width: 34rem;
    font-size: 1.02rem;
    line-height: 1.65;
    color: var(--color-text-muted);
  }
  .ss-question span {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }
  .ss-inline-link {
    display: inline-flex;
    align-self: flex-start;
    margin-top: 1.35rem;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--color-accent);
    text-decoration: none;
    background-image: linear-gradient(var(--color-accent), var(--color-accent));
    background-size: 100% 1px;
    background-repeat: no-repeat;
    background-position: 0 100%;
    padding-bottom: 2px;
  }
  .ss-inline-link:hover { opacity: 0.75; }

  @media (max-width: 980px) {
    .scroll-spine {
      display: block;
      margin-top: 2rem;
    }
    .ss-visual {
      position: relative;
      top: auto;
      min-height: auto;
      display: block;
      margin-bottom: 2.5rem;
    }
    .ss-portrait {
      position: relative;
      left: auto;
      width: min(24rem, 100%);
      margin: 0 auto 2rem;
    }
    .scroll-spine:not([data-active="origin"]) .ss-portrait {
      width: min(24rem, 100%);
      opacity: 1;
      transform: none;
    }
    .ss-map {
      min-height: auto;
      margin: 0;
      padding-left: 1rem;
    }
    .scroll-spine[data-active="origin"] .ss-map {
      opacity: 1;
      transform: none;
    }
    .ss-rail { left: 0; top: 0.45rem; bottom: 0.45rem; }
    .ss-node {
      position: relative;
      top: auto;
      left: auto;
      width: auto;
      margin-bottom: 1rem;
      opacity: 0.78;
    }
    .ss-node.is-active { transform: none; }
    .ss-branches {
      margin-top: 2rem;
      opacity: 1;
      transform: none;
    }
    .ss-stage,
    .ss-stage-origin,
    .ss-stage-collabs {
      min-height: auto;
      padding: 3rem 0;
    }
    .ss-stage h3 {
      font-size: clamp(1.8rem, 9vw, 3rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ss-portrait,
    .ss-map,
    .ss-node,
    .ss-branches,
    .ss-branch {
      transition: none;
    }
  }
</style>

<script>
  document.querySelectorAll(".scroll-spine").forEach((root) => {
    const stages = Array.from(root.querySelectorAll("[data-stage]"));
    const nodes = Array.from(root.querySelectorAll("[data-node]"));
    if (!stages.length) return;

    const setActive = (key) => {
      root.setAttribute("data-active", key);
      nodes.forEach((node) => {
        node.classList.toggle("is-active", node.getAttribute("data-node") === key);
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
        if (visible?.target) setActive(visible.target.getAttribute("data-stage"));
      },
      { threshold: [0.25, 0.45, 0.65], rootMargin: "-18% 0px -24% 0px" }
    );

    stages.forEach((stage) => observer.observe(stage));
  });
</script>
