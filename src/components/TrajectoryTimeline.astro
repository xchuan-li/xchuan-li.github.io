---
// ResearchSpine — "Option A": the research arc as a layered argument.
// Reading top to bottom: one question (a brace over the three) → the main line
// 01·Certify → 02·Localize → 03·Quantify (Whether / Where / How much), with a
// language frontier at the right edge. MiniCausalLang remains the foundation
// beneath the method line; the two collaborative projects are explicit satellite
// branches, not extra main-line nodes.
interface Origin {
  label: string;
  href: string;
}
interface Station {
  n: string;
  method: string;
  qword: string;
  title: string;
  color: string;
  href: string;
  capstone?: boolean;
}
interface Frontier {
  label: string;
  title: string;
  href: string;
}
interface Workbench {
  title: string;
  href: string;
  desc: string;
}
interface Group {
  title: string;
  kind: string;
  href: string;
  desc?: string;
}
interface Props {
  question: string;
  origin: Origin;
  stations: Station[];
  frontier: Frontier;
  workbench: Workbench;
  groups: Group[];
}

const { question, origin, stations, frontier, workbench, groups } = Astro.props;
const [latentBranch, protoBranch] = groups;
---

<div class="spine">
  <div class="spine-scroll">
    <div class="spine-grid">
      <p class="sp-question">{question}</p>
      <span class="sp-brace" aria-hidden="true"></span>

      {stations.map((s, i) => (
        <span class={`sp-qword sp-col-${i + 1}`}>{s.qword}</span>
      ))}

      {stations.map((s, i) => (
        <a class={`sp-title sp-col-${i + 1}`} href={s.href} style={`--c: ${s.color};`}>
          <span class="sp-meta">{s.n} · {s.method}</span>
          <span class="sp-name">{s.title}</span>
        </a>
      ))}

      <span class="sp-beam" aria-hidden="true"></span>

      <a class="sp-cap sp-cap-origin" href={origin.href} aria-label={origin.label}>
        <span class="sp-glyph sp-glyph-origin">?</span>
      </a>
      {stations.map((s, i) => (
        <a
          class={`sp-node sp-col-${i + 1}`}
          href={s.href}
          aria-label={s.title}
          style={`--c: ${s.color};`}
        >
          <span class={`sp-dot sp-dot-station${s.capstone ? " sp-dot-capstone" : ""}`}></span>
        </a>
      ))}
      <a class="sp-cap sp-cap-frontier" href={frontier.href} aria-label={frontier.title}>
        <span class="sp-dot sp-dot-frontier"></span>
      </a>

      <span class="sp-caplabel sp-caplabel-origin">{origin.label}</span>
      {stations.map((s, i) => (
        <span class={`sp-tick sp-col-${i + 1}`} aria-hidden="true"></span>
      ))}
      <span class="sp-caplabel sp-caplabel-frontier">{frontier.label}</span>

      {latentBranch && (
        <>
          <a class="sp-branch sp-branch-latent" href={latentBranch.href}>
            <span class="sp-branch-dot" aria-hidden="true"></span>
            <span class="sp-branch-kicker">Mechanistic branch</span>
            <span class="sp-branch-title">{latentBranch.title}</span>
            {latentBranch.desc && <span class="sp-branch-desc">{latentBranch.desc}</span>}
          </a>
        </>
      )}

      {protoBranch && (
        <>
          <a class="sp-branch sp-branch-proto" href={protoBranch.href}>
            <span class="sp-branch-dot" aria-hidden="true"></span>
            <span class="sp-branch-kicker">Cross-lingual branch</span>
            <span class="sp-branch-title">{protoBranch.title}</span>
            {protoBranch.desc && <span class="sp-branch-desc">{protoBranch.desc}</span>}
          </a>
        </>
      )}

      <a class="sp-workbench" href={workbench.href}>
        <span class="sp-wb-kicker">Workbench · foundation</span>
        <span class="sp-wb-title">{workbench.title}</span>
        <span class="sp-wb-desc">{workbench.desc}</span>
      </a>
    </div>
  </div>
</div>

<style>
  .spine {
    margin-top: 3rem;
  }
  .spine-scroll {
    margin: 0 -1.5rem;
    padding: 0 1.5rem 0.5rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: var(--color-border-strong) transparent;
  }
  .spine-scroll::-webkit-scrollbar { height: 6px; }
  .spine-scroll::-webkit-scrollbar-thumb {
    background: var(--color-border-strong);
    border-radius: 3px;
  }
  .spine-scroll::-webkit-scrollbar-track { background: transparent; }

  /* origin | 01 | 02 | 03 | frontier */
  .spine-grid {
    position: relative;
    min-width: 900px;
    display: grid;
    grid-template-columns: 0.85fr 1fr 1fr 1fr 0.85fr;
    grid-template-rows: auto auto auto auto 30px 34px auto minmax(68px, auto);
    align-items: center;
    justify-items: center;
    column-gap: 0.5rem;
  }

  /* column placement — shared by q-words, titles, nodes and ticks */
  .sp-col-1 { grid-column: 2; }
  .sp-col-2 { grid-column: 3; }
  .sp-col-3 { grid-column: 4; }

  /* ---- one question + brace ---- */
  .sp-question {
    grid-column: 2 / 5;
    grid-row: 1;
    margin: 0 0 0.1rem;
    text-align: center;
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--color-text);
  }
  .sp-brace {
    grid-column: 2 / 5;
    grid-row: 2;
    align-self: start;
    width: 78%;
    height: 9px;
    margin-top: 0.15rem;
    border: 1px solid var(--color-border-strong);
    border-bottom: none;
    border-radius: 4px 4px 0 0;
    opacity: 0.8;
  }

  /* ---- progression words ---- */
  .sp-qword {
    grid-row: 3;
    margin-top: 0.9rem;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }

  /* ---- station label (meta + title), above the beam ---- */
  .sp-title {
    grid-row: 4;
    margin-top: 0.4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.18rem;
    text-align: center;
    text-decoration: none;
    padding: 0 0.3rem;
  }
  .sp-meta {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--c, var(--color-text-dim));
  }
  .sp-name {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.25;
    color: var(--color-text);
    transition: color 0.2s ease;
  }
  .sp-title:hover .sp-name { color: var(--c, var(--color-accent)); }

  /* ---- the beam + nodes ---- */
  .sp-beam {
    grid-row: 5;
    grid-column: 1 / 6;
    align-self: center;
    justify-self: stretch;
    height: 2px;
    border-radius: 2px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--color-border-strong) 8%,
      var(--color-border-strong) 60%,
      color-mix(in srgb, var(--accent-deep-purple) 65%, var(--color-border-strong)) 92%,
      transparent
    );
    z-index: 0;
  }
  .sp-node,
  .sp-cap {
    grid-row: 5;
    z-index: 2;
    display: grid;
    place-items: center;
    padding: 6px;
    margin: -6px;
  }
  .sp-cap-origin { grid-column: 1; }
  .sp-cap-frontier { grid-column: 5; }

  .sp-dot {
    display: block;
    border-radius: 50%;
    box-shadow: 0 0 0 4px var(--color-bg);
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }
  .sp-dot-station {
    width: 16px;
    height: 16px;
    background: var(--c, var(--color-accent));
    box-shadow: 0 0 0 4px var(--color-bg), 0 0 0 1px color-mix(in srgb, var(--c) 40%, transparent);
  }
  .sp-dot-capstone {
    width: 18px;
    height: 18px;
    box-shadow:
      0 0 0 4px var(--color-bg),
      0 0 0 7px color-mix(in srgb, var(--c) 20%, transparent),
      0 0 0 8px color-mix(in srgb, var(--c) 42%, transparent);
  }
  .sp-dot-frontier {
    width: 16px;
    height: 16px;
    background: var(--color-bg);
    border: 1.6px dashed var(--accent-deep-purple);
  }
  .sp-node:hover .sp-dot-station { transform: scale(1.16); }
  .sp-cap:hover .sp-dot { transform: scale(1.14); }

  /* ---- origin as a question mark — "Leibniz's question" ---- */
  .sp-glyph {
    display: grid;
    place-items: center;
    border-radius: 50%;
    box-shadow: 0 0 0 4px var(--color-bg);
    transition: transform 0.22s ease;
  }
  .sp-glyph-origin {
    width: 18px;
    height: 18px;
    background: var(--color-bg);
    border: 1.5px solid var(--accent-deep-purple);
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 600;
    font-size: 12px;
    line-height: 1;
    color: var(--accent-deep-purple);
  }
  .sp-cap:hover .sp-glyph { transform: scale(1.14); }

  /* ---- bookend labels + down-ticks ---- */
  .sp-caplabel {
    grid-row: 6;
    align-self: start;
    margin-top: 0.4rem;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 11.5px;
    line-height: 1.3;
    text-align: center;
    color: var(--color-text-muted);
    max-width: 110px;
  }
  .sp-caplabel-origin { grid-column: 1; }
  .sp-caplabel-frontier { grid-column: 5; }

  .sp-tick {
    grid-row: 6;
    width: 1px;
    height: 100%;
    justify-self: center;
    align-self: stretch;
    background: var(--color-border-strong);
    opacity: 0.45;
  }

  /* ---- collaborative branches: visible, but not promoted to the main line ---- */
  .sp-branch {
    grid-row: 8;
    align-self: start;
    position: relative;
    display: grid;
    justify-items: center;
    gap: 0.18rem;
    min-width: 12rem;
    margin-top: 1.1rem;
    padding: 0.65rem 0.9rem 0.72rem;
    border: 1px solid color-mix(in srgb, var(--branch-c) 48%, var(--color-border));
    border-radius: 6px;
    background: color-mix(in srgb, var(--color-bg) 82%, var(--branch-c) 18%);
    text-align: center;
    text-decoration: none;
    box-shadow: 0 0 0 3px var(--color-bg), 0 2px 8px color-mix(in srgb, var(--branch-c) 10%, transparent);
    transition: border-color 0.2s ease, transform 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
    z-index: 2;
  }
  .sp-branch:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--branch-c) 68%, var(--color-border));
    background: color-mix(in srgb, var(--color-bg) 76%, var(--branch-c) 24%);
    box-shadow: 0 0 0 3px var(--color-bg), 0 4px 14px color-mix(in srgb, var(--branch-c) 18%, transparent);
  }
  .sp-branch-latent {
    grid-column: 2;
    --branch-c: var(--accent-teal);
    justify-self: center;
  }
  .sp-branch-proto {
    grid-column: 4;
    --branch-c: var(--accent-deep-purple);
    justify-self: center;
  }
  .sp-branch-dot {
    position: absolute;
    top: -5px;
    left: calc(50% - 5px);
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--branch-c);
    box-shadow: 0 0 0 4px var(--color-bg);
  }
  /* a single straight dashed line dropping from the beam to each card */
  .sp-branch-dot::before {
    content: "";
    position: absolute;
    left: 50%;
    bottom: 100%;
    transform: translateX(-50%);
    width: 0;
    height: 8.9rem;
    border-left: 1.4px dashed var(--branch-c);
    opacity: 0.62;
  }
  .sp-branch-kicker {
    font-family: var(--font-mono);
    font-size: 8.5px;
    font-weight: 500;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--branch-c) 72%, var(--color-text-muted));
  }
  .sp-branch-title {
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 500;
    line-height: 1.22;
    color: var(--color-text);
    transition: color 0.2s ease;
  }
  .sp-branch-desc {
    margin-top: 0.1rem;
    font-size: 10.5px;
    line-height: 1.45;
    color: var(--color-text-dim);
    max-width: 14rem;
    text-wrap: balance;
  }
  .sp-branch:hover .sp-branch-title { color: var(--color-text); }

  /* ---- the workbench: a quiet foundation note beneath the three (no card) ---- */
  .sp-workbench {
    grid-column: 2 / 5;
    grid-row: 7;
    align-self: start;
    width: 100%;
    max-width: 30rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.12rem;
    padding: 0.25rem 0.7rem 0.15rem;
    text-decoration: none;
    position: relative;
    z-index: 2;
    border-radius: 6px;
    background: var(--color-bg);
  }
  .sp-wb-kicker {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }
  .sp-wb-title {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-muted);
    transition: color 0.2s ease;
  }
  .sp-workbench:hover .sp-wb-title { color: var(--color-text); }
  .sp-wb-desc {
    font-size: 11px;
    line-height: 1.45;
    color: var(--color-text-dim);
    max-width: 26rem;
    text-wrap: balance;
  }
</style>
