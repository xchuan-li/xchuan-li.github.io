---
// ResearchSpine — the Leibniz origin (kept) feeding a HORIZONTAL mainline of three
// nodes: Certify (behaviour · sandbox) · Mechanism (inside real models) ·
// Across languages (cross-lingual). Most projects hang from one node as a small
// card; a "bridge" project (spanTo set) is a double-width card straddling two
// adjacent nodes — e.g. HanGL across Mechanism + Across-languages. The dot encodes
// maturity (near-complete / in progress / concept). Driven by data/research.ts.
interface Origin { label: string; href: string; hook?: string; }
interface Project {
  title: string;
  href: string;
  color?: string;
  category?: string;
  node?: string;
  spanTo?: string;
  maturity?: string;
  progress?: string;
  blurb?: string;
}
interface Props {
  question: string;
  origin: Origin;
  projects: Project[];
}
const { question, origin, projects } = Astro.props;
const portraitSrc = "/images/leibniz-portrait.png";

const NODES = [
  { key: "certify", label: "Certify", sub: "behaviour · sandbox", color: "var(--accent-coral)" },
  { key: "mechanism", label: "Mechanism", sub: "inside real models", color: "var(--accent-amber)" },
  { key: "crosslingual", label: "Across languages", sub: "cross-lingual", color: "var(--accent-teal)" },
];
const COL: Record<string, number> = { certify: 1, mechanism: 2, crosslingual: 3 };
const nodeColor: Record<string, string> = Object.fromEntries(NODES.map((n) => [n.key, n.color]));
const nodeLabel: Record<string, string> = Object.fromEntries(NODES.map((n) => [n.key, n.label]));

const matOrder: Record<string, number> = { near: 0, active: 1, concept: 2 };
// within a column: more mature first; on a tie, personal before collaborative
const sortItems = (a: Project, b: Project) => {
  const m = (matOrder[a.maturity ?? "active"] ?? 1) - (matOrder[b.maturity ?? "active"] ?? 1);
  if (m !== 0) return m;
  return (a.category === "collaborative" ? 1 : 0) - (b.category === "collaborative" ? 1 : 0);
};

const singles = projects.filter((p) => p.node && !p.spanTo);
const bridges = projects.filter((p) => p.node && p.spanTo);

// Bridges take the top card rows (1st bridge → row 2, 2nd → row 3); each bridge
// occupies its two columns at that row. Singles then fill the remaining cells in
// their own column from the top down, so every column is contiguous — empty space
// only ever trails at the bottom of a shorter column, never punched into a middle.
const bridgePlaced = bridges.map((p, bi) => ({ p, row: 2 + bi }));
const occupied: Record<number, Set<number>> = { 1: new Set(), 2: new Set(), 3: new Set() };
bridgePlaced.forEach(({ p, row }) => {
  const c = COL[p.node];
  occupied[c].add(row);
  occupied[c + 1].add(row);
});

// One flat, node-grouped list of grid items. DOM order is grouped by node so the
// mobile (single-column) fallback reads sensibly; desktop placement is by the
// explicit grid-column / grid-row on each item, independent of DOM order.
const items: any[] = [];
NODES.forEach((n, i) => {
  const col = i + 1;
  items.push({ kind: "head", node: n, col, row: 1 });
  let r = 2;
  singles
    .filter((p) => p.node === n.key)
    .sort(sortItems)
    .forEach((p) => {
      while (occupied[col].has(r)) r++;
      items.push({ kind: "card", p, col, row: r });
      r++;
    });
});
bridgePlaced.forEach(({ p, row }) => items.push({ kind: "bridge", p, col: COL[p.node], row }));
---

<div class="rm">
  <div class="rm-origin">
    <a class="rm-portrait-link" href={origin.href} aria-label={origin.label}>
      <span class="tl-portrait"><img src={portraitSrc} alt="Portrait of Gottfried Wilhelm Leibniz" loading="lazy" decoding="async" /></span>
    </a>
    <a class="tl-obtn" href={origin.href}>
      <span class="tl-kicker tl-kicker-origin">{origin.label}</span>
      <span class="tl-latin">{origin.hook ?? "Nihil est sine ratione."}</span>
      <span class="tl-obtn-text">{question}</span>
      <span class="tl-cta">Read the philosophical bridge <span aria-hidden="true">→</span></span>
    </a>
  </div>

  <div class="rm-cols">
    {items.map((it) =>
      it.kind === "head" ? (
        <div class="rm-head" style={`--c: ${it.node.color}; grid-column: ${it.col}; grid-row: ${it.row};`}>
          <span class="rm-dot" aria-hidden="true"></span>
          <span class="rm-node-title">{it.node.label}</span>
          <span class="rm-node-sub">{it.node.sub}</span>
        </div>
      ) : it.kind === "bridge" ? (
        <a
          class="rm-card rm-card-bridge"
          href={it.p.href}
          style={`--c: ${it.p.color ?? nodeColor[it.p.node]}; --ca: ${nodeColor[it.p.node]}; --cb: ${nodeColor[it.p.spanTo]}; grid-column: ${it.col} / span 2; grid-row: ${it.row};`}
        >
          <span class="rm-card-span">
            <span style={`color: ${nodeColor[it.p.node]}`}>{nodeLabel[it.p.node]}</span>
            <span class="rm-span-arrow" aria-hidden="true">↔</span>
            <span style={`color: ${nodeColor[it.p.spanTo]}`}>{nodeLabel[it.p.spanTo]}</span>
          </span>
          <span class="rm-card-title">{it.p.title}</span>
          {it.p.blurb && <span class="rm-card-blurb">{it.p.blurb}</span>}
          <span class="rm-card-meta">
            <span class={`rm-mat rm-mat-${it.p.maturity ?? "active"}`} aria-hidden="true"></span>
            <span class="rm-card-prog">{it.p.progress}</span>
            <span class="rm-card-cat">{it.p.category === "collaborative" ? "group" : "personal"}</span>
          </span>
        </a>
      ) : (
        <a
          class="rm-card"
          href={it.p.href}
          style={`--c: ${it.p.color ?? nodeColor[it.p.node]}; grid-column: ${it.col}; grid-row: ${it.row};`}
        >
          <span class="rm-card-title">{it.p.title}</span>
          {it.p.blurb && <span class="rm-card-blurb">{it.p.blurb}</span>}
          <span class="rm-card-meta">
            <span class={`rm-mat rm-mat-${it.p.maturity ?? "active"}`} aria-hidden="true"></span>
            <span class="rm-card-prog">{it.p.progress}</span>
            <span class="rm-card-cat">{it.p.category === "collaborative" ? "group" : "personal"}</span>
          </span>
        </a>
      )
    )}
  </div>
</div>

<style>
  .rm { margin: 2.5rem 0 0; }

  /* origin (Leibniz) — kept as-is */
  .rm-origin {
    display: grid;
    grid-template-columns: 46px 1fr;
    column-gap: 1.1rem;
    align-items: start;
    max-width: 44rem;
    margin-bottom: 2.6rem;
  }
  .rm-portrait-link { display: flex; justify-content: center; text-decoration: none; }
  .tl-portrait {
    width: 46px; height: 56px; overflow: hidden; margin-top: 2px;
    -webkit-mask-image: radial-gradient(120% 100% at 50% 34%, #000 60%, transparent 96%);
            mask-image: radial-gradient(120% 100% at 50% 34%, #000 60%, transparent 96%);
  }
  .tl-portrait img { width: 100%; height: 100%; display: block; object-fit: cover; object-position: 50% 14%; filter: contrast(1.04); }
  .tl-obtn {
    display: flex; flex-direction: column; text-decoration: none;
    border: 1px solid color-mix(in srgb, var(--accent-deep-purple) 22%, var(--color-border));
    border-radius: 12px; background: var(--color-surface);
    padding: 0.9rem 1.05rem 1rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .tl-obtn:hover {
    border-color: color-mix(in srgb, var(--accent-deep-purple) 55%, var(--color-border));
    box-shadow: 0 3px 18px color-mix(in srgb, var(--accent-deep-purple) 10%, transparent);
  }
  .tl-kicker { font-family: var(--font-mono); font-size: 10px; font-weight: 500; letter-spacing: 0.13em; text-transform: uppercase; }
  .tl-kicker-origin { color: var(--accent-deep-purple); }
  .tl-latin { margin: 0.25rem 0 0; font-family: var(--font-display); font-style: italic; font-size: 1.5rem; font-weight: 500; line-height: 1.15; letter-spacing: -0.005em; color: var(--color-text); }
  .tl-obtn-text { margin: 0.4rem 0 0; font-size: 0.86rem; line-height: 1.55; color: var(--color-text-muted); max-width: 46ch; }
  .tl-cta {
    align-self: flex-start; display: inline-flex; align-items: center; gap: 0.4rem; margin-top: 0.8rem;
    font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.02em;
    color: var(--btn-primary-text); background: var(--accent-deep-purple);
    padding: 5px 12px; border-radius: 999px;
  }

  /* horizontal mainline — explicit 3-column grid; bridges span two columns */
  .rm-cols {
    position: relative;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    column-gap: 1.25rem;
    row-gap: 0.6rem;
    padding-top: 1.4rem;
    align-items: stretch;
  }
  .rm-cols::before {
    content: "";
    position: absolute;
    top: calc(1.4rem + 7px); left: 12%; right: 12%;
    height: 2px;
    background: var(--color-border-strong);
    z-index: 0;
  }

  .rm-head { position: relative; z-index: 1; display: flex; flex-direction: column; align-items: center; text-align: center; margin-bottom: 0.5rem; }
  .rm-dot {
    width: 14px; height: 14px; border-radius: 50%;
    background: var(--c);
    box-shadow: 0 0 0 4px var(--color-bg), 0 0 0 5px color-mix(in srgb, var(--c) 36%, transparent);
  }
  .rm-node-title { margin-top: 0.55rem; font-family: var(--font-display); font-size: 1.05rem; font-weight: 600; color: var(--color-text); }
  .rm-node-sub { margin-top: 0.15rem; font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-text-dim); }

  .rm-card {
    position: relative; z-index: 1;
    display: flex; flex-direction: column; gap: 0.35rem;
    padding: 0.7rem 0.85rem;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-left: 2.5px solid var(--c);
    border-radius: 8px;
    min-height: 8.5rem;
    text-decoration: none;
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
  }
  .rm-card:hover { border-color: var(--card-hover-border); background: var(--card-hover-bg); transform: translateY(-2px); }
  .rm-card-title { font-family: var(--font-display); font-size: 0.94rem; font-weight: 500; line-height: 1.25; color: var(--color-text); transition: color 0.2s ease; }
  .rm-card:hover .rm-card-title { color: var(--c); }
  .rm-card-blurb {
    font-size: 0.8rem; line-height: 1.5; color: var(--color-text-muted);
    display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
  }
  .rm-card-meta { display: flex; align-items: center; gap: 0.45rem; margin-top: auto; padding-top: 0.3rem; }
  .rm-card-prog { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.02em; color: var(--color-text-muted); }
  .rm-card-cat {
    margin-left: auto;
    font-family: var(--font-mono); font-size: 8.5px; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--color-text-dim);
    border: 1px solid var(--color-border); border-radius: 999px; padding: 1px 6px;
  }
  .rm-mat { width: 8px; height: 8px; border-radius: 50%; flex: 0 0 auto; }
  .rm-mat-near { background: var(--c); box-shadow: 0 0 0 2px color-mix(in srgb, var(--c) 30%, transparent); }
  .rm-mat-active { background: var(--c); }
  .rm-mat-concept { background: transparent; border: 1.5px solid var(--color-text-dim); }

  /* bridge: double-width card straddling two nodes, an edge in each node's color */
  .rm-card-bridge { border-left: 2.5px solid var(--ca); border-right: 2.5px solid var(--cb); }
  .rm-card-span {
    display: inline-flex; align-items: center; gap: 0.35rem;
    font-family: var(--font-mono); font-size: 8.5px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase;
  }
  .rm-span-arrow { color: var(--color-text-dim); }

  @media (max-width: 720px) {
    .rm-cols { grid-template-columns: 1fr; row-gap: 0.6rem; padding-top: 0.4rem; }
    .rm-cols::before { display: none; }
    .rm-cols > * { grid-column: 1 / -1 !important; grid-row: auto !important; }
    .rm-head { align-items: flex-start; text-align: left; margin-top: 1.2rem; }
    .rm-head:first-child { margin-top: 0; }
  }
</style>
