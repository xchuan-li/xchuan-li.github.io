---
// CausalResidueFigure — visualizing causal structure learning as elimination.
// Three panels showing a hypothesis space being cut by successive falsifiers:
//   H₀  — the full candidate space (many dots, all live)
//   Hₜ  — partway through training (some dots crossed out, slashes show cuts)
//   Hₙ  — the residue (one accent dot survives, the rest are ghosts)
// Boxless, theme-aware. Sits inside .essay-fig like the other long-form figures.
---

<figure class="essay-fig residue-fig">
  <svg viewBox="0 0 640 240" role="img" aria-label="A hypothesis space of candidate causal structures progressively narrowed by training examples acting as falsifiers; what survives is the residue.">
    <defs>
      <marker id="cr-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto">
        <path d="M 0 1 L 9 5 L 0 9" class="cr-arrhead" />
      </marker>
    </defs>

    <!-- =========== Panel 1: H₀ — the full hypothesis space =========== -->
    <g transform="translate(20, 30)">
      <text class="cr-tag" x="0" y="-6">H₀</text>
      <text class="cr-tag-sub" x="0" y="172">candidate structures</text>
      <rect class="cr-panel" x="0" y="0" width="160" height="158" rx="10" />
      <g class="cr-dot-live">
        <circle cx="20" cy="22" r="2.5" />
        <circle cx="46" cy="14" r="2.5" />
        <circle cx="78" cy="26" r="2.5" />
        <circle cx="108" cy="18" r="2.5" />
        <circle cx="138" cy="28" r="2.5" />
        <circle cx="16" cy="50" r="2.5" />
        <circle cx="44" cy="58" r="2.5" />
        <circle cx="72" cy="48" r="2.5" />
        <circle cx="102" cy="56" r="2.5" />
        <circle cx="132" cy="50" r="2.5" />
        <circle cx="20" cy="84" r="2.5" />
        <circle cx="48" cy="92" r="2.5" />
        <circle cx="80" cy="82" r="2.5" />
        <circle cx="110" cy="88" r="2.5" />
        <circle cx="142" cy="86" r="2.5" />
        <circle cx="22" cy="118" r="2.5" />
        <circle cx="50" cy="126" r="2.5" />
        <circle cx="76" cy="116" r="2.5" />
        <circle cx="106" cy="124" r="2.5" />
        <circle cx="138" cy="120" r="2.5" />
        <circle cx="34" cy="146" r="2.5" />
        <circle cx="68" cy="142" r="2.5" />
        <circle cx="98" cy="148" r="2.5" />
        <circle cx="124" cy="144" r="2.5" />
      </g>
    </g>

    <!-- arrow 1 → 2, with cumulative-falsifier label -->
    <g transform="translate(186, 105)">
      <line class="cr-arrow" x1="0" y1="0" x2="40" y2="0" marker-end="url(#cr-arrow)" />
      <text class="cr-edge-tag" x="20" y="-8" text-anchor="middle">e₁ e₂ e₃</text>
      <text class="cr-edge-sub" x="20" y="16" text-anchor="middle">falsify</text>
    </g>

    <!-- =========== Panel 2: Hₜ — partway through =========== -->
    <g transform="translate(236, 30)">
      <text class="cr-tag" x="0" y="-6">Hₜ</text>
      <text class="cr-tag-sub" x="0" y="172">after a few cuts</text>
      <rect class="cr-panel" x="0" y="0" width="160" height="158" rx="10" />

      <!-- The cuts: diagonal hairlines crossing the panel -->
      <g class="cr-cuts">
        <line x1="-4" y1="46" x2="166" y2="120" />
        <line x1="-4" y1="116" x2="166" y2="40" />
        <line x1="42" y1="-4" x2="124" y2="162" />
      </g>

      <!-- Eliminated (faded) -->
      <g class="cr-dot-ghost">
        <circle cx="20" cy="22" r="2.5" />
        <circle cx="46" cy="14" r="2.5" />
        <circle cx="108" cy="18" r="2.5" />
        <circle cx="16" cy="50" r="2.5" />
        <circle cx="44" cy="58" r="2.5" />
        <circle cx="132" cy="50" r="2.5" />
        <circle cx="22" cy="118" r="2.5" />
        <circle cx="138" cy="120" r="2.5" />
        <circle cx="34" cy="146" r="2.5" />
        <circle cx="68" cy="142" r="2.5" />
        <circle cx="124" cy="144" r="2.5" />
        <circle cx="138" cy="28" r="2.5" />
        <circle cx="78" cy="26" r="2.5" />
        <circle cx="50" cy="126" r="2.5" />
        <circle cx="98" cy="148" r="2.5" />
      </g>

      <!-- Survivors (still live) -->
      <g class="cr-dot-live">
        <circle cx="72" cy="48" r="2.6" />
        <circle cx="102" cy="56" r="2.6" />
        <circle cx="80" cy="82" r="2.6" />
        <circle cx="110" cy="88" r="2.6" />
        <circle cx="142" cy="86" r="2.6" />
        <circle cx="48" cy="92" r="2.6" />
        <circle cx="76" cy="116" r="2.6" />
        <circle cx="106" cy="124" r="2.6" />
        <circle cx="20" cy="84" r="2.6" />
      </g>
    </g>

    <!-- arrow 2 → 3 -->
    <g transform="translate(402, 105)">
      <line class="cr-arrow" x1="0" y1="0" x2="40" y2="0" marker-end="url(#cr-arrow)" />
      <text class="cr-edge-tag" x="20" y="-8" text-anchor="middle">e₄ … e_n</text>
      <text class="cr-edge-sub" x="20" y="16" text-anchor="middle">narrow</text>
    </g>

    <!-- =========== Panel 3: Hₙ — the residue =========== -->
    <g transform="translate(452, 30)">
      <text class="cr-tag cr-tag-accent" x="0" y="-6">Hₙ</text>
      <text class="cr-tag-sub" x="0" y="172">residue · the structure</text>
      <rect class="cr-panel cr-panel-residue" x="0" y="0" width="160" height="158" rx="10" />

      <!-- Inner residue region (small rounded panel inside) -->
      <rect class="cr-inner" x="50" y="56" width="60" height="46" rx="6" />

      <!-- All the ghosts that didn't make it -->
      <g class="cr-dot-ghost">
        <circle cx="20" cy="22" r="2.5" />
        <circle cx="46" cy="14" r="2.5" />
        <circle cx="108" cy="18" r="2.5" />
        <circle cx="138" cy="28" r="2.5" />
        <circle cx="78" cy="26" r="2.5" />
        <circle cx="16" cy="50" r="2.5" />
        <circle cx="44" cy="58" r="2.5" />
        <circle cx="132" cy="50" r="2.5" />
        <circle cx="142" cy="86" r="2.5" />
        <circle cx="22" cy="118" r="2.5" />
        <circle cx="138" cy="120" r="2.5" />
        <circle cx="50" cy="126" r="2.5" />
        <circle cx="34" cy="146" r="2.5" />
        <circle cx="68" cy="142" r="2.5" />
        <circle cx="98" cy="148" r="2.5" />
        <circle cx="124" cy="144" r="2.5" />
        <circle cx="20" cy="84" r="2.5" />
      </g>

      <!-- Survivors inside the residue region -->
      <circle class="cr-dot-keep" cx="72" cy="74" r="3.2" />
      <circle class="cr-dot-keep" cx="92" cy="86" r="3.6" />
      <circle class="cr-dot-keep cr-dot-pick" cx="80" cy="84" r="4" />
    </g>
  </svg>
  <figcaption>
    Each training example is a falsifier — it eliminates the candidate structures incompatible with it.
    What persists across the cumulative cuts is not produced by training; it <em>survives</em> it.
  </figcaption>
</figure>

<style>
  .essay-fig.residue-fig svg { color: var(--color-text-muted); max-height: 240px; }

  .cr-panel {
    fill: none;
    stroke: var(--color-border-strong);
    stroke-width: 0.9;
    opacity: 0.85;
  }
  .cr-panel-residue { stroke: var(--color-text-dim); }
  .cr-inner {
    fill: none;
    stroke: var(--color-accent);
    stroke-width: 1;
    opacity: 0.85;
  }

  .cr-tag {
    font-family: var(--font-mono);
    font-size: 10.5px;
    fill: var(--color-text-muted);
    letter-spacing: 0.06em;
  }
  .cr-tag-accent { fill: var(--color-accent); }
  .cr-tag-sub {
    font-family: var(--font-mono);
    font-size: 9.5px;
    fill: var(--color-text-dim);
    font-style: italic;
    letter-spacing: 0.04em;
  }
  .cr-edge-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    fill: var(--color-text-muted);
    letter-spacing: 0.04em;
  }
  .cr-edge-sub {
    font-family: var(--font-mono);
    font-size: 9px;
    fill: var(--color-text-dim);
    font-style: italic;
    letter-spacing: 0.06em;
  }

  .cr-dot-live circle { fill: var(--color-text-muted); opacity: 0.92; }
  .cr-dot-ghost circle { fill: var(--color-text-dim); opacity: 0.28; }
  .cr-dot-keep { fill: var(--color-accent); opacity: 0.9; }
  .cr-dot-pick { fill: var(--color-accent); stroke: var(--color-bg); stroke-width: 1.5; opacity: 1; }

  .cr-cuts line {
    stroke: var(--color-accent);
    stroke-width: 0.9;
    stroke-dasharray: 3 2.5;
    opacity: 0.6;
    stroke-linecap: round;
  }

  .cr-arrow {
    stroke: var(--color-text-dim);
    stroke-width: 1;
    fill: none;
    stroke-linecap: round;
  }
  .cr-arrhead {
    fill: none;
    stroke: var(--color-text-dim);
    stroke-width: 1.2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .residue-fig svg path { fill: none; }
</style>
