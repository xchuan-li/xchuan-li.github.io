---
// MarginNote - a Tufte-style sidenote authored inline in the prose. On wide
// reading pages it floats into the right gutter beside the paragraph it follows;
// on narrow screens it collapses to an inline indented aside.
//   <MarginNote>a quiet aside</MarginNote>
//   <MarginNote kind="question">an open question to sit in the margin</MarginNote>
interface Props {
  kind?: "note" | "question";
  label?: string;
}
const { kind = "note", label } = Astro.props;
const defaultLabel = kind === "question" ? "Open question" : "Note";
---

<aside class={`margin-note margin-note-${kind}`}>
  <span class="margin-note-label">{label ?? defaultLabel}</span>
  <span class="margin-note-body"><slot /></span>
</aside>
