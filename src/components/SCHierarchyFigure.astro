---
// SCHierarchyFigure — concept illustration for the homepage About section.
// Shows the SC framework's strict containment:
//   accuracy ⊋ stable-correct ⊋ grounded
// As three concentric rounded panels with populations of small nodes in each band:
//   • outer band  → accurate-but-unstable (the stability check eliminates these)
//   • middle band → stable-correct-but-spurious (the do-intervention catches these)
//   • inner area  → grounded (the certified set)
// Boxless, theme-aware, no card chrome.
---

<figure class="sc-hierarchy-fig" aria-label="Three concentric panels labeled accuracy, stable-correct, and grounded — illustrating the strict hierarchy of the SC certification framework.">
  <svg viewBox="0 0 400 540" width="400" height="540" preserveAspectRatio="xMidYMid meet">
    <defs>
      <pattern id="sc-cross" x="0" y="0" width="6" height="6" patternUnits="userSpaceOnUse" />
      <marker id="sc-arrow" viewBox="0 0 10 10" refX="8.5" refY="5" markerWidth="5" markerHeight="5" orient="auto">
        <path d="M 0 1 L 9 5 L 0 9" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
      </marker>
    </defs>

    <!-- Outer panel: ACCURACY -->
    <rect class="sc-panel sc-p1" x="20" y="60" width="360" height="440" rx="22" />
    <text class="sc-cap-tag" x="20" y="46">ACCURACY</text>
    <text class="sc-cap-sub" x="20" y="514">headline numbers — not yet certified</text>

    <!-- Middle panel: STABLE-CORRECT (SC) -->
    <rect class="sc-panel sc-p2" x="58" y="108" width="284" height="340" rx="18" />
    <text class="sc-cap-tag sc-cap-coral" x="58" y="98">STABLE-CORRECT</text>

    <!-- Inner panel: GROUNDED -->
    <rect class="sc-panel sc-p3" x="100" y="170" width="200" height="220" rx="14" />
    <text class="sc-cap-tag sc-cap-amber" x="100" y="160">GROUNDED</text>

    <!-- Outer band dots: accurate but unstable -->
    <g class="sc-dot-dim">
      <circle cx="40" cy="84" r="2.4" />
      <circle cx="78" cy="78" r="2.4" />
      <circle cx="148" cy="82" r="2.4" />
      <circle cx="232" cy="80" r="2.4" />
      <circle cx="316" cy="82" r="2.4" />
      <circle cx="358" cy="86" r="2.4" />
      <circle cx="36" cy="142" r="2.4" />
      <circle cx="362" cy="138" r="2.4" />
      <circle cx="34" cy="232" r="2.4" />
      <circle cx="364" cy="228" r="2.4" />
      <circle cx="36" cy="332" r="2.4" />
      <circle cx="364" cy="326" r="2.4" />
      <circle cx="34" cy="412" r="2.4" />
      <circle cx="362" cy="416" r="2.4" />
      <circle cx="42" cy="468" r="2.4" />
      <circle cx="98" cy="476" r="2.4" />
      <circle cx="180" cy="476" r="2.4" />
      <circle cx="262" cy="478" r="2.4" />
      <circle cx="324" cy="474" r="2.4" />
    </g>

    <!-- Middle band: stable-correct but spurious (the band between middle and inner rects).
         These look identical to the certified ones by every observable behavior,
         until the do-intervention severs the shortcut. -->
    <g class="sc-dot-spurious">
      <g>
        <circle cx="78" cy="132" r="3.2" />
        <g class="sc-x" transform="translate(78,132)">
          <line x1="-3.2" y1="-3.2" x2="3.2" y2="3.2" />
          <line x1="3.2" y1="-3.2" x2="-3.2" y2="3.2" />
        </g>
      </g>
      <g>
        <circle cx="170" cy="138" r="3.2" />
        <g class="sc-x" transform="translate(170,138)">
          <line x1="-3.2" y1="-3.2" x2="3.2" y2="3.2" />
          <line x1="3.2" y1="-3.2" x2="-3.2" y2="3.2" />
        </g>
      </g>
      <g>
        <circle cx="248" cy="128" r="3.2" />
        <g class="sc-x" transform="translate(248,128)">
          <line x1="-3.2" y1="-3.2" x2="3.2" y2="3.2" />
          <line x1="3.2" y1="-3.2" x2="-3.2" y2="3.2" />
        </g>
      </g>
      <g>
        <circle cx="318" cy="140" r="3.2" />
        <g class="sc-x" transform="translate(318,140)">
          <line x1="-3.2" y1="-3.2" x2="3.2" y2="3.2" />
          <line x1="3.2" y1="-3.2" x2="-3.2" y2="3.2" />
        </g>
      </g>
      <g>
        <circle cx="76" cy="232" r="3.2" />
        <g class="sc-x" transform="translate(76,232)">
          <line x1="-3.2" y1="-3.2" x2="3.2" y2="3.2" />
          <line x1="3.2" y1="-3.2" x2="-3.2" y2="3.2" />
        </g>
      </g>
      <g>
        <circle cx="324" cy="232" r="3.2" />
        <g class="sc-x" transform="translate(324,232)">
          <line x1="-3.2" y1="-3.2" x2="3.2" y2="3.2" />
          <line x1="3.2" y1="-3.2" x2="-3.2" y2="3.2" />
        </g>
      </g>
      <g>
        <circle cx="80" cy="332" r="3.2" />
        <g class="sc-x" transform="translate(80,332)">
          <line x1="-3.2" y1="-3.2" x2="3.2" y2="3.2" />
          <line x1="3.2" y1="-3.2" x2="-3.2" y2="3.2" />
        </g>
      </g>
      <g>
        <circle cx="320" cy="330" r="3.2" />
        <g class="sc-x" transform="translate(320,330)">
          <line x1="-3.2" y1="-3.2" x2="3.2" y2="3.2" />
          <line x1="3.2" y1="-3.2" x2="-3.2" y2="3.2" />
        </g>
      </g>
      <g>
        <circle cx="86" cy="416" r="3.2" />
        <g class="sc-x" transform="translate(86,416)">
          <line x1="-3.2" y1="-3.2" x2="3.2" y2="3.2" />
          <line x1="3.2" y1="-3.2" x2="-3.2" y2="3.2" />
        </g>
      </g>
      <g>
        <circle cx="172" cy="424" r="3.2" />
        <g class="sc-x" transform="translate(172,424)">
          <line x1="-3.2" y1="-3.2" x2="3.2" y2="3.2" />
          <line x1="3.2" y1="-3.2" x2="-3.2" y2="3.2" />
        </g>
      </g>
      <g>
        <circle cx="244" cy="420" r="3.2" />
        <g class="sc-x" transform="translate(244,420)">
          <line x1="-3.2" y1="-3.2" x2="3.2" y2="3.2" />
          <line x1="3.2" y1="-3.2" x2="-3.2" y2="3.2" />
        </g>
      </g>
      <g>
        <circle cx="318" cy="418" r="3.2" />
        <g class="sc-x" transform="translate(318,418)">
          <line x1="-3.2" y1="-3.2" x2="3.2" y2="3.2" />
          <line x1="3.2" y1="-3.2" x2="-3.2" y2="3.2" />
        </g>
      </g>
    </g>

    <!-- Inner area dots: grounded (certified) -->
    <g class="sc-dot-grounded">
      <circle cx="132" cy="208" r="4.2" />
      <circle cx="200" cy="200" r="4.2" />
      <circle cx="266" cy="216" r="4.2" />
      <circle cx="158" cy="262" r="4.2" />
      <circle cx="232" cy="270" r="4.2" />
      <circle cx="186" cy="318" r="4.2" />
      <circle cx="252" cy="328" r="4.2" />
      <circle cx="138" cy="350" r="4.2" />
    </g>

    <!-- do() intervention callout — an arrow from a spurious dot to the inner area
         to suggest the test that severs it. -->
    <g class="sc-callout">
      <line x1="244" y1="416" x2="232" y2="370" marker-end="url(#sc-arrow)" />
      <text class="sc-callout-text" x="252" y="396">do(C)</text>
    </g>

    <!-- Strict-containment caption -->
    <text class="sc-formula" x="200" y="540" text-anchor="middle">accuracy ⊋ stable-correct ⊋ grounded</text>
  </svg>
</figure>

<style>
  .sc-hierarchy-fig { margin: 0; padding: 0; }
  .sc-hierarchy-fig svg { width: 100%; max-width: 460px; height: auto; display: block; margin: 0 auto; }

  .sc-panel { fill: none; stroke-width: 1; }
  .sc-p1 { stroke: var(--color-border-strong); }
  .sc-p2 { stroke: var(--accent-coral); stroke-opacity: 0.55; }
  .sc-p3 { stroke: var(--accent-amber); stroke-opacity: 0.75; }

  .sc-cap-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    fill: var(--color-text-muted);
  }
  .sc-cap-coral { fill: var(--accent-coral); }
  .sc-cap-amber { fill: var(--accent-amber); }
  .sc-cap-sub {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    fill: var(--color-text-dim);
    font-style: italic;
  }

  .sc-dot-dim circle { fill: var(--color-text-ghost); opacity: 0.55; }
  .sc-dot-spurious circle { fill: var(--accent-coral); opacity: 0.85; }
  .sc-dot-spurious .sc-x line {
    stroke: var(--color-bg);
    stroke-width: 1.2;
    stroke-linecap: round;
  }
  .sc-dot-grounded circle { fill: var(--accent-amber); }

  .sc-callout line {
    stroke: var(--color-text-muted);
    stroke-width: 1;
    stroke-dasharray: 3 2;
    fill: none;
  }
  .sc-callout-text {
    font-family: var(--font-mono);
    font-size: 10.5px;
    fill: var(--color-text-muted);
    font-style: italic;
    letter-spacing: 0.04em;
  }
  .sc-callout { color: var(--color-text-muted); }

  .sc-formula {
    font-family: var(--font-mono);
    font-size: 11px;
    fill: var(--color-text-dim);
    letter-spacing: 0.05em;
  }
</style>
