---
// HeroCausalMatrix — the homepage hero emblem: a grounding circuit.
//
// Five word-wheels spin independently (each its own speed and direction), drawing
// from a rich vocabulary. Most instants are an ungrammatical jumble. A tiny check
// reads whatever is currently centred and asks: does the verb agree with the
// subject (and the article with the subject) across the intervening noun? When it
// does — rarely — the channel on the right CONNECTS (green, a path to the model's
// behaviour). When it doesn't, an ✕ blocks it (red). Structure grounded ⇒ the
// circuit closes; surface jumble ⇒ blocked.
//
// Motion is one coherent thing (each wheel turns vertically); the verdict is a
// STATE (connected / blocked), checked live in the browser — not a perpendicular
// flow.
const PITCH = 46;
const Y_CENTER = 225;
const Y0 = Y_CENTER + 5; // baseline of cell 0 at translateY(0)
const N = 10;

// n: "s" singular · "p" plural · "x" irrelevant. Skewed so the article, subject
// and verb only rarely share number — the connected (grounded) combo is uncommon
// (~1 in 6). Cell 0 of every column is grounded (the reduced-motion still frame).
const cols = [
  { x: 58,  role: null,              key: false, speed: 15, dir: 1,
    words: [["A","s"],["This","s"],["Each","s"],["These","p"],["Many","p"],["Most","p"],["Several","p"],["Few","p"],["Both","p"],["All","p"]] },
  { x: 168, role: "SUBJECT · head",  key: true,  speed: 18, dir: -1,
    words: [["signal","s"],["key","s"],["river","s"],["bridge","s"],["root","s"],["claim","s"],["gate","s"],["sign","s"],["keys","p"],["roots","p"]] },
  { x: 288, role: null,              key: false, speed: 13, dir: 1,
    words: [["through","x"],["near","x"],["beyond","x"],["under","x"],["across","x"],["along","x"],["past","x"],["behind","x"],["within","x"],["beside","x"]] },
  { x: 392, role: "NEAREST NOUN",    key: false, speed: 20, dir: -1,
    words: [["trees","p"],["walls","p"],["gates","p"],["fields","p"],["rivers","p"],["doors","p"],["hills","p"],["panels","p"],["layers","p"],["tokens","p"]] },
  { x: 486, role: "VERB · do(form)", key: true,  speed: 16, dir: 1,
    words: [["is","s"],["was","s"],["has","s"],["are","p"],["were","p"],["have","p"],["hold","p"],["stay","p"],["remain","p"],["persist","p"]] },
];
const cells = (words: string[][]) =>
  Array.from({ length: 2 * N }, (_, i) => ({ y: Y0 + i * PITCH, w: words[i % N][0] }));

const reelData = cols.map((c, i) => ({ i, speed: c.speed, dir: c.dir, nums: c.words.map((w) => w[1]) }));
const cfg = { N, PITCH, YC: Y_CENTER, Y0, idx: { det: 0, subj: 1, verb: 4 } };
---

<figure
  class="hero-matrix is-open"
  aria-label="A grounding circuit. Five word-wheels spin independently through a rich vocabulary; a check reads the centred words and connects a green channel to the model's behaviour only when the verb agrees with the subject across the intervening noun — otherwise an ✕ blocks it."
>
  <svg viewBox="0 0 640 360" shape-rendering="geometricPrecision" preserveAspectRatio="xMidYMid meet" role="img">
    <defs>
      <filter id="hm-soft" x="-80%" y="-80%" width="260%" height="260%">
        <feGaussianBlur stdDeviation="3.2" />
      </filter>
      <clipPath id="hm-band"><rect x="24" y="156" width="496" height="138" /></clipPath>
      <linearGradient id="hm-fade-top" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="var(--color-bg)" stop-opacity="1" />
        <stop offset="1" stop-color="var(--color-bg)" stop-opacity="0" />
      </linearGradient>
      <linearGradient id="hm-fade-bot" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="var(--color-bg)" stop-opacity="0" />
        <stop offset="1" stop-color="var(--color-bg)" stop-opacity="1" />
      </linearGradient>
    </defs>

    <!-- dial separators -->
    <g class="hm-guide">
      {cols.map((c) => <line x1={c.x} y1="150" x2={c.x} y2="300" />)}
    </g>

    <!-- neutral slots behind the load-bearing dials -->
    <rect class="hm-slot" x="128" y="207" width="80" height="36" rx="4" />
    <rect class="hm-slot" x="446" y="207" width="80" height="36" rx="4" />
    <!-- green when the structure is grounded -->
    <rect class="hm-box-ok" x="128" y="207" width="80" height="36" rx="4" />
    <rect class="hm-box-ok" x="446" y="207" width="80" height="36" rx="4" />

    <!-- the spinning wheels (driven independently in the browser) -->
    <g clip-path="url(#hm-band)">
      {
        cols.map((c, i) => (
          <g class="hm-reel" data-reel={i} transform="translate(0 0)">
            {cells(c.words).map((cell) => (
              <text class={`hm-cell ${c.key ? "hm-cell-key" : "hm-cell-mute"}`} x={c.x} y={cell.y} text-anchor="middle">
                {cell.w}
              </text>
            ))}
          </g>
        ))
      }
    </g>

    <!-- dial peek -->
    <rect class="hm-fade" x="24" y="156" width="496" height="44" fill="url(#hm-fade-top)" />
    <rect class="hm-fade" x="24" y="250" width="496" height="44" fill="url(#hm-fade-bot)" />

    <!-- role labels -->
    <g class="hm-role">
      {cols.filter((c) => c.role).map((c) => <text x={c.x} y="142" text-anchor="middle">{c.role}</text>)}
      <text x="592" y="196" text-anchor="middle">BEHAVIOR</text>
    </g>

    <!-- the relation under test: subject -> verb, across the nearest noun -->
    <path class="hm-agree" d="M 168 241 V 252 H 486 V 241" />

    <!-- output node = the model's behaviour Y -->
    <rect class="hm-out" x="584" y="217" width="16" height="16" rx="2" />

    <!-- CONNECTED (green): the grounded path closes through to the behaviour -->
    <g class="hm-gate-open">
      <path class="hm-go-line" d="M 168 241 V 252 H 486 V 241" />
      <line class="hm-go-link" x1="526" y1="225" x2="584" y2="225" />
      <circle class="hm-go-halo" cx="592" cy="225" r="15" filter="url(#hm-soft)" />
      <rect class="hm-go-node" x="584" y="217" width="16" height="16" rx="2" />
      <text class="hm-go-label" x="555" y="258" text-anchor="middle">grounded</text>
    </g>

    <!-- BLOCKED (red): ✕ across the channel, behaviour not licensed -->
    <g class="hm-gate-block">
      <line class="hm-x" x1="544" y1="219" x2="556" y2="231" />
      <line class="hm-x" x1="556" y1="219" x2="544" y2="231" />
      <text class="hm-block-label" x="550" y="258" text-anchor="middle">blocked</text>
    </g>
  </svg>

  <figcaption class="hero-matrix-cap">
    Five dials spin through real words. Almost every combination is a jumble — the
    channel stays <span class="cap-bad">✕ blocked</span>. Only when the verb agrees
    with the subject across the surface noun does it
    <span class="cap-ok">connect</span>: structure grounded, behaviour licensed.
  </figcaption>
</figure>

<script define:vars={{ reelData, cfg }}>
  (function () {
    const fig = document.querySelector(".hero-matrix");
    if (!fig) return;
    const { N, PITCH, YC, Y0, idx } = cfg;
    const L = N * PITCH;
    const reels = reelData.map((r) => ({
      el: fig.querySelector(`[data-reel="${r.i}"]`),
      i: r.i,
      speed: r.speed,
      dir: r.dir,
      nums: r.nums,
      // stagger the starting positions so the wheels are out of phase
      phase: (r.i * 137.5) % L,
    }));
    const wrap = (v) => ((v % L) + L) % L;
    const centred = (ph) => Math.round(wrap(ph) / PITCH) % N;
    const numOf = (k) => {
      const r = reels.find((x) => x.i === k);
      return r.nums[centred(r.phase)];
    };
    const grounded = () => {
      const s = numOf(idx.subj), v = numOf(idx.verb), d = numOf(idx.det);
      return (d === "n" || d === s) && s === v;
    };
    const draw = () => {
      for (const r of reels) r.el.setAttribute("transform", `translate(0 ${-r.phase})`);
    };
    let open = null;
    const apply = () => {
      const g = grounded();
      if (g !== open) { open = g; fig.classList.toggle("is-open", g); }
    };

    if (matchMedia("(prefers-reduced-motion: reduce)").matches) {
      reels.forEach((r) => (r.phase = 0)); // cell 0 of each column is a grounded sentence
      draw();
      apply();
      return;
    }

    // Spin → (on a grounded combo) decelerate into alignment → dwell → spin back up.
    const SETTLE = 420, HOLD = 560, SPINUP = 460; // ms
    const easeOut = (t) => 1 - Math.pow(1 - t, 3);
    let last = performance.now(), raf = 0, armed = true;
    let mode = "spin", tMark = 0, from = [], to = [];
    const frame = (now) => {
      const dt = Math.min(0.05, (now - last) / 1000);
      last = now;
      if (mode === "spin") {
        for (const r of reels) r.phase = wrap(r.phase + r.speed * r.dir * dt);
        const g = grounded();
        if (g && armed) {
          from = reels.map((r) => r.phase);
          to = reels.map((r) => Math.round(r.phase / PITCH) * PITCH);
          mode = "settle"; tMark = now; armed = false;
        } else if (!g) {
          armed = true;
        }
      } else if (mode === "settle") {
        const e = easeOut(Math.min(1, (now - tMark) / SETTLE));
        reels.forEach((r, i) => (r.phase = from[i] + (to[i] - from[i]) * e));
        if (now - tMark >= SETTLE) { reels.forEach((r, i) => (r.phase = wrap(to[i]))); mode = "hold"; tMark = now; }
      } else if (mode === "hold") {
        if (now - tMark >= HOLD) { mode = "spinup"; tMark = now; }
      } else {
        const t = Math.min(1, (now - tMark) / SPINUP);
        for (const r of reels) r.phase = wrap(r.phase + r.speed * r.dir * dt * t * t);
        if (t >= 1) mode = "spin";
      }
      draw();
      apply();
      fig.classList.toggle("clicking", mode === "hold");
      raf = requestAnimationFrame(frame);
    };
    raf = requestAnimationFrame(frame);

    new IntersectionObserver((es) => {
      for (const e of es) {
        if (e.isIntersecting && !raf) { last = performance.now(); raf = requestAnimationFrame(frame); }
        else if (!e.isIntersecting && raf) { cancelAnimationFrame(raf); raf = 0; }
      }
    }).observe(fig);
  })();
</script>

<style>
  .hero-matrix { margin: 0; padding: 0; }
  .hero-matrix svg {
    width: 100%;
    max-width: 600px;
    height: auto;
    display: block;
    font-family: var(--font-mono);
    overflow: visible;
    --hm-ok: var(--accent-teal);
    --hm-bad: #db5048;
  }

  .hm-guide line { stroke: var(--color-border); stroke-width: 1; }
  .hm-slot { fill: none; stroke: var(--color-border-strong); stroke-width: 1; opacity: 0.5; }

  .hm-role text { font-size: 8px; letter-spacing: 0.13em; fill: var(--color-text-ghost); }

  .hm-cell { font-size: 15px; letter-spacing: 0.01em; }
  .hm-cell-mute { fill: var(--color-text-muted); }
  .hm-cell-key  { fill: var(--color-text); font-weight: 600; }

  /* the relation under test — quiet structural connector */
  .hm-agree { fill: none; stroke: var(--color-text-dim); stroke-width: 1.2; opacity: 0.45; }

  /* output node (model behaviour) */
  .hm-out { fill: none; stroke: var(--color-text-dim); stroke-width: 1.2; opacity: 0.6; }

  /* ---- grounded path (green), shown only when .is-open ---- */
  .hm-box-ok { fill: var(--hm-ok); fill-opacity: 0.13; stroke: var(--hm-ok); stroke-opacity: 0.85; stroke-width: 1.4; opacity: 0; transition: opacity 0.25s ease; }
  .hm-gate-open { opacity: 0; transition: opacity 0.25s ease; }
  .hm-go-line { fill: none; stroke: var(--hm-ok); stroke-width: 1.6; opacity: 0.9; }
  .hm-go-link { stroke: var(--hm-ok); stroke-width: 1.8; stroke-linecap: round; }
  .hm-go-halo { fill: var(--hm-ok); opacity: 0.26; }
  .hm-go-node { fill: var(--hm-ok); fill-opacity: 0.2; stroke: var(--hm-ok); stroke-width: 1.6; }
  .hm-go-label { font-size: 8.5px; letter-spacing: 0.16em; text-transform: uppercase; fill: var(--hm-ok); }

  /* ---- blocked (red ✕), shown by default ---- */
  .hm-gate-block { opacity: 1; transition: opacity 0.25s ease; }
  .hm-x { stroke: var(--hm-bad); stroke-width: 2.2; stroke-linecap: round; }
  .hm-block-label { font-size: 8.5px; letter-spacing: 0.16em; text-transform: uppercase; fill: var(--hm-bad); opacity: 0.85; }

  .hero-matrix.is-open .hm-box-ok { opacity: 1; }
  .hero-matrix.is-open .hm-gate-open { opacity: 1; }
  .hero-matrix.is-open .hm-gate-block { opacity: 0; }

  /* the "click": a quick pop on the behaviour node as the dials lock into place */
  @keyframes hm-pop {
    0%   { transform: scale(0.66); }
    55%  { transform: scale(1.22); }
    100% { transform: scale(1); }
  }
  .hero-matrix.clicking .hm-go-node,
  .hero-matrix.clicking .hm-go-halo {
    transform-box: fill-box;
    transform-origin: center;
    animation: hm-pop 0.34s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .hero-matrix-cap {
    margin-top: 1.1rem;
    font-size: 11.5px;
    line-height: 1.6;
    font-style: italic;
    color: var(--color-text-dim);
    max-width: 32rem;
  }
  .hero-matrix-cap .cap-ok  { font-style: normal; color: var(--accent-teal); }
  .hero-matrix-cap .cap-bad { font-style: normal; color: #db5048; }
</style>
