---
// ProjectCover — 16:10 cover illustrations for the homepage research-grid cards.
// Each kind shows the project's most identifying experimental visual + a few
// load-bearing labels (deltas, token names, gauge values, framing tags).
// Boxless; the cell background provides the project tint. `color` sets
// `currentColor` for the project accent.
interface Props {
  kind: "sc" | "isotrace" | "mcm" | "ciy" | "latent" | "protobias" | "xling" | "hangl";
  color?: string;
}
const { kind, color = "var(--color-accent)" } = Astro.props;
const labels: Record<Props["kind"], string> = {
  sc: "DAG with do-intervention cut and an accuracy bar chart showing Δ +.408 collapse versus Δ +.021 control",
  isotrace: "A three-hop chain with concept-name tokens (Zorb, Veln, Quasp) and a bypass arc dropping hop 2",
  mcm: "Planted ground-truth DAG on the left, recovered minimal structure on the right, recovery arrow between",
  ciy: "A yield gauge beside two models matched on accuracy but opposed on CIY — the falsifiability test",
  latent: "An activation manifold with two control states linked by a steer arrow under different prompt framings",
  protobias: "A central input fans to three languages; one path lands on meaning, another drifts to a cultural prototype",
  xling: "One meaning fans to three languages, encoded at different granularity — a single morpheme, subwords, a fragmented compound",
  hangl: "The Hangul word 학교 and the Hanja form 學校 share no surface overlap but bind to one latent meaning node; strong models bridge them without the explicit Hanja cue",
};
---

<svg
  class="proj-cover"
  viewBox="0 0 320 200"
  role="img"
  aria-label={labels[kind]}
  style={`color:${color}`}
  preserveAspectRatio="xMidYMid meet"
>
  <defs>
    <marker id={`pc-${kind}-a`} viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto">
      <path d="M 0 1 L 9 5 L 0 9" class="pc-arrhead" />
    </marker>
    <marker id={`pc-${kind}-d`} viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto">
      <path d="M 0 1 L 9 5 L 0 9" class="pc-arrhead-dim" />
    </marker>
  </defs>

  {kind === "sc" && (
    <g>
      <!-- Left: the DAG -->
      <text class="pc-cap" x="22" y="28">do-intervention test</text>

      <!-- M node (top) -->
      <circle class="pc-acc-f" cx="44" cy="68" r="6" />
      <text class="pc-node-label" x="44" y="52" text-anchor="middle">M</text>
      <!-- c node (bottom) -->
      <circle class="pc-dim" cx="44" cy="142" r="5.5" />
      <text class="pc-node-label pc-node-dim" x="44" y="160" text-anchor="middle">c</text>
      <!-- Y target -->
      <circle class="pc-acc-soft" cx="146" cy="105" r="14" />
      <circle class="pc-acc-f" cx="146" cy="105" r="8.5" />
      <text class="pc-node-label" x="146" y="135" text-anchor="middle">Y</text>

      <!-- M → Y solid -->
      <line class="pc-acc pc-w" x1="50" y1="69.5" x2="135" y2="97" marker-end={`url(#pc-${kind}-a)`} />
      <!-- c → Y dashed (severed) -->
      <line class="pc-dim pc-dash" x1="50" y1="139" x2="135" y2="115" marker-end={`url(#pc-${kind}-d)`} />
      <!-- Cut mark on c → Y -->
      <g class="pc-cut" transform="translate(88,124) rotate(-15)">
        <line x1="-4.5" y1="-4.5" x2="4.5" y2="4.5" />
        <line x1="4.5" y1="-4.5" x2="-4.5" y2="4.5" />
      </g>

      <!-- Right: outcome bars -->
      <g transform="translate(186,30)">
        <text class="pc-cap" x="0" y="-4">accuracy under do( )</text>

        <!-- Baseline -->
        <text class="pc-row-label" x="0" y="22">baseline</text>
        <rect class="pc-bar-track" x="0" y="28" width="76" height="4.5" rx="2.25" />
        <rect class="pc-bar-fill" x="0" y="28" width="69.3" height="4.5" rx="2.25" />
        <text class="pc-row-value" x="124" y="33" text-anchor="end">.912</text>

        <!-- do(c=3) — the big drop -->
        <text class="pc-row-label" x="0" y="58">do(c=3)</text>
        <rect class="pc-bar-track" x="0" y="64" width="76" height="4.5" rx="2.25" />
        <rect class="pc-bar-fill" x="0" y="64" width="38.3" height="4.5" rx="2.25" />
        <text class="pc-row-value" x="124" y="69" text-anchor="end">.504</text>
        <text class="pc-row-delta" x="124" y="80" text-anchor="end">Δ −.408</text>

        <!-- do(c=2) — control -->
        <text class="pc-row-label" x="0" y="106">do(c=2)</text>
        <rect class="pc-bar-track" x="0" y="112" width="76" height="4.5" rx="2.25" />
        <rect class="pc-bar-fill pc-bar-dim" x="0" y="112" width="67.7" height="4.5" rx="2.25" />
        <text class="pc-row-value pc-row-value-dim" x="124" y="117" text-anchor="end">.891</text>
        <text class="pc-row-delta pc-row-delta-dim" x="124" y="128" text-anchor="end">Δ −.021</text>
      </g>
    </g>
  )}

  {kind === "isotrace" && (
    <g>
      <text class="pc-cap" x="160" y="26" text-anchor="middle">multi-hop trace · shortcut at hop 2</text>

      <!-- Concept-name tokens above each hop -->
      <text class="pc-token" x="60" y="68" text-anchor="middle">Zorb</text>
      <text class="pc-token pc-token-dim" x="160" y="68" text-anchor="middle">Veln</text>
      <text class="pc-token" x="260" y="68" text-anchor="middle">Quasp</text>

      <!-- Bypass arc 1 → 3 (the surface pattern that skips the middle hop) -->
      <path class="pc-dim pc-dash" d="M 64 92 C 100 38, 220 38, 256 92" marker-end={`url(#pc-${kind}-d)`} />
      <text class="pc-tick" x="160" y="48" text-anchor="middle">bypass</text>

      <!-- Hop chain: solid arrows 1 → 2 and 2 → 3 -->
      <line class="pc-acc pc-w" x1="68" y1="116" x2="146" y2="116" marker-end={`url(#pc-${kind}-a)`} />
      <line class="pc-acc pc-w" x1="174" y1="116" x2="246" y2="116" marker-end={`url(#pc-${kind}-a)`} />

      <!-- Hop nodes -->
      <circle class="pc-acc" cx="60" cy="116" r="8" />
      <circle class="pc-dim pc-dash-r" cx="160" cy="116" r="7" />
      <circle class="pc-acc-f" cx="260" cy="116" r="8" />

      <!-- Hop indices -->
      <text class="pc-hop" x="60" y="156" text-anchor="middle">1</text>
      <text class="pc-hop pc-hop-dim" x="160" y="156" text-anchor="middle">2</text>
      <text class="pc-hop" x="260" y="156" text-anchor="middle">3</text>

      <!-- Branch labels -->
      <text class="pc-cap-tick" x="110" y="180" text-anchor="middle">compositional</text>
      <text class="pc-cap-tick pc-cap-tick-dim" x="210" y="180" text-anchor="middle">surface pattern</text>
    </g>
  )}

  {kind === "mcm" && (
    <g>
      <text class="pc-cap" x="22" y="26">planted</text>
      <text class="pc-cap" x="298" y="26" text-anchor="end">recovered from behavior</text>

      <!-- Left panel: planted ground-truth DAG -->
      <g class="pc-mcm-left">
        <line class="pc-acc pc-w" x1="42" y1="68" x2="86" y2="108" />
        <line class="pc-acc pc-w" x1="42" y1="148" x2="86" y2="116" />
        <line class="pc-acc pc-w" x1="40" y1="108" x2="80" y2="108" />
        <circle class="pc-acc" cx="36" cy="60" r="5" />
        <circle class="pc-acc" cx="32" cy="108" r="5" />
        <circle class="pc-acc" cx="36" cy="156" r="5" />
        <circle class="pc-acc-f" cx="90" cy="112" r="7" />
      </g>
      <text class="pc-axis" x="62" y="186" text-anchor="middle">ground truth</text>

      <!-- Middle: recovery arrow -->
      <g transform="translate(120,90)">
        <line class="pc-tick-line" x1="0" y1="22" x2="80" y2="22" marker-end={`url(#pc-${kind}-a)`} />
        <text class="pc-cap-tick" x="40" y="14" text-anchor="middle">train · recover</text>
        <text class="pc-cap-tick pc-cap-tick-dim" x="40" y="40" text-anchor="middle">behavior alone</text>
      </g>

      <!-- Right panel: recovered minimal structure — some edges solid (kept), some dashed (missed) -->
      <g class="pc-mcm-right">
        <line class="pc-acc pc-w" x1="230" y1="68" x2="274" y2="108" />
        <line class="pc-dim pc-dash" x1="230" y1="148" x2="274" y2="116" />
        <line class="pc-acc pc-w" x1="228" y1="108" x2="268" y2="108" />
        <circle class="pc-acc" cx="224" cy="60" r="5" />
        <circle class="pc-acc" cx="220" cy="108" r="5" />
        <circle class="pc-dim pc-dash-r" cx="224" cy="156" r="5" />
        <circle class="pc-acc-f" cx="278" cy="112" r="7" />
      </g>
      <text class="pc-axis" x="250" y="186" text-anchor="middle">score vs truth</text>
    </g>
  )}

  {kind === "ciy" && (
    <g>
      <text class="pc-cap" x="22" y="26">graded yield · falsifiability test</text>

      <!-- Gauge -->
      <g transform="translate(28,46)">
        <path class="pc-dim pc-w" d="M 4 90 A 60 60 0 0 1 124 90" />
        <line class="pc-tick-line" x1="4" y1="90" x2="14" y2="90" />
        <line class="pc-tick-line" x1="13.5" y1="56.5" x2="22.6" y2="63.6" />
        <line class="pc-tick-line" x1="46" y1="35" x2="50.5" y2="44" />
        <line class="pc-tick-line" x1="64" y1="30" x2="64" y2="40" />
        <line class="pc-tick-line" x1="82" y1="35" x2="77.5" y2="44" />
        <line class="pc-tick-line" x1="114.5" y1="56.5" x2="105.4" y2="63.6" />
        <line class="pc-tick-line" x1="124" y1="90" x2="114" y2="90" />

        <!-- Needle -->
        <line class="pc-acc pc-w" x1="64" y1="90" x2="42" y2="48" />
        <circle class="pc-acc-f" cx="64" cy="90" r="3.2" />

        <text class="pc-axis" x="4" y="106">low</text>
        <text class="pc-axis" x="124" y="106" text-anchor="end">high CIY</text>
      </g>

      <!-- Right: two models matched on accuracy, opposed on CIY -->
      <g transform="translate(190,52)">
        <text class="pc-cap-tick" x="0" y="0">same accuracy</text>
        <text class="pc-cap-tick pc-cap-tick-dim" x="0" y="14">opposite CIY</text>

        <!-- Model A: high CIY (filled, accent) -->
        <g transform="translate(0,32)">
          <circle class="pc-acc-f" cx="8" cy="6" r="5.5" />
          <text class="pc-row-label" x="22" y="9">model A</text>
          <text class="pc-row-value" x="105" y="10" text-anchor="end">.78</text>
        </g>
        <!-- Falsifiability bracket — short vertical hairline with end caps connecting A & B -->
        <g class="pc-bracket">
          <line x1="8" y1="46" x2="8" y2="74" />
          <line x1="5" y1="46" x2="11" y2="46" />
          <line x1="5" y1="74" x2="11" y2="74" />
        </g>
        <text class="pc-axis pc-axis-dim" x="18" y="64">falsifiable</text>

        <!-- Model B: low CIY (dim outlined) -->
        <g transform="translate(0,78)">
          <circle class="pc-dim" cx="8" cy="6" r="5.5" />
          <text class="pc-row-label pc-row-label-dim" x="22" y="9">model B</text>
          <text class="pc-row-value pc-row-value-dim" x="105" y="10" text-anchor="end">.14</text>
        </g>
      </g>
    </g>
  )}

  {kind === "latent" && (
    <g>
      <text class="pc-cap" x="22" y="26">prompt framing · activation states</text>

      <!-- The manifold -->
      <path class="pc-manifold" d="M 14 134 C 56 78, 124 168, 200 96 C 244 52, 290 88, 308 70" />

      <!-- Background activation cloud -->
      <g class="pc-cloud">
        <circle cx="30" cy="122" r="1.7" />
        <circle cx="52" cy="110" r="1.7" />
        <circle cx="68" cy="138" r="1.7" />
        <circle cx="90" cy="148" r="1.7" />
        <circle cx="112" cy="142" r="1.7" />
        <circle cx="134" cy="158" r="1.7" />
        <circle cx="156" cy="138" r="1.7" />
        <circle cx="174" cy="120" r="1.7" />
        <circle cx="196" cy="108" r="1.7" />
        <circle cx="220" cy="86" r="1.7" />
        <circle cx="248" cy="74" r="1.7" />
        <circle cx="276" cy="84" r="1.7" />
        <circle cx="296" cy="78" r="1.7" />
        <circle cx="44" cy="158" r="1.7" />
        <circle cx="208" cy="142" r="1.7" />
        <circle cx="266" cy="106" r="1.7" />
      </g>

      <!-- Two control states -->
      <circle class="pc-acc" cx="76" cy="118" r="7.5" />
      <circle class="pc-acc-f" cx="232" cy="80" r="8.5" />

      <!-- Steer arrow A → B -->
      <line class="pc-acc pc-w" x1="84" y1="116" x2="222" y2="84" marker-end={`url(#pc-${kind}-a)`} />

      <!-- Framing labels -->
      <text class="pc-row-label" x="76" y="100" text-anchor="middle">framing A</text>
      <text class="pc-row-label" x="232" y="62" text-anchor="middle">framing B</text>

      <text class="pc-cap-tick" x="160" y="186" text-anchor="middle">causally relevant state · or surface feature?</text>
    </g>
  )}

  {kind === "protobias" && (
    <g>
      <text class="pc-cap" x="22" y="26">multimodal · cross-lingual prototype drift</text>

      <!-- Central input node (image + text token) -->
      <g transform="translate(38,108)">
        <rect class="pc-acc" x="-10" y="-10" width="20" height="20" rx="3" />
        <line class="pc-acc" x1="-4.5" y1="-3" x2="4.5" y2="-3" />
        <line class="pc-acc" x1="-4.5" y1="2" x2="4.5" y2="2" />
        <line class="pc-acc" x1="-4.5" y1="7" x2="2" y2="7" />
        <text class="pc-axis" x="0" y="28" text-anchor="middle">image · text</text>
      </g>

      <!-- Three language branches -->
      <line class="pc-acc pc-w" x1="56" y1="100" x2="170" y2="68" marker-end={`url(#pc-${kind}-a)`} />
      <line class="pc-acc pc-w" x1="56" y1="108" x2="170" y2="108" marker-end={`url(#pc-${kind}-a)`} />
      <path class="pc-acc pc-w pc-dash" d="M 56 116 C 100 138, 142 148, 168 152" marker-end={`url(#pc-${kind}-d)`} />

      <!-- Language tag tokens -->
      <text class="pc-lang" x="112" y="62" text-anchor="middle">EN</text>
      <text class="pc-lang" x="112" y="102" text-anchor="middle">ZH</text>
      <text class="pc-lang pc-lang-dim" x="118" y="146" text-anchor="middle">AR</text>

      <!-- Meaning target -->
      <circle class="pc-acc-f" cx="186" cy="68" r="7" />
      <circle class="pc-acc-f" cx="186" cy="108" r="7" />
      <text class="pc-axis" x="226" y="72">meaning</text>
      <text class="pc-axis" x="226" y="112">meaning</text>

      <!-- Prototype drift (the cultural shortcut) -->
      <polygon class="pc-dim" points="180,142 192,152 180,162 168,152" />
      <text class="pc-axis pc-axis-dim" x="226" y="156">cultural prototype</text>
      <text class="pc-cap-tick pc-cap-tick-dim" x="220" y="186" text-anchor="end">drift on language switch</text>
    </g>
  )}

  {kind === "xling" && (
    <g>
      <text class="pc-cap" x="22" y="26">cross-lingual encoding · structure vs surface</text>

      <!-- Meaning node -->
      <circle class="pc-acc-soft" cx="44" cy="104" r="13" />
      <circle class="pc-acc-f" cx="44" cy="104" r="7.5" />
      <text class="pc-axis" x="44" y="132" text-anchor="middle">meaning</text>

      <!-- Three language branches -->
      <line class="pc-acc pc-w" x1="56" y1="98" x2="150" y2="62" marker-end={`url(#pc-${kind}-a)`} />
      <line class="pc-acc pc-w" x1="58" y1="104" x2="150" y2="108" marker-end={`url(#pc-${kind}-a)`} />
      <path class="pc-acc pc-w pc-dash" d="M 56 112 C 100 140, 138 150, 150 152" marker-end={`url(#pc-${kind}-d)`} />

      <!-- Language tags -->
      <text class="pc-lang" x="118" y="54" text-anchor="middle">ZH</text>
      <text class="pc-lang" x="118" y="100" text-anchor="middle">EN</text>
      <text class="pc-lang pc-lang-dim" x="122" y="146" text-anchor="middle">DE</text>

      <!-- ZH: a single unit (morpheme = character) -->
      <rect class="pc-acc-f" x="166" y="52" width="20" height="20" rx="3" />
      <text class="pc-axis" x="196" y="66">1 morpheme</text>

      <!-- EN: two subwords -->
      <rect class="pc-acc" x="166" y="99" width="13" height="18" rx="2.5" />
      <rect class="pc-acc" x="183" y="99" width="13" height="18" rx="2.5" />
      <text class="pc-axis" x="206" y="112">subwords</text>

      <!-- DE: fragmented compound (three pieces, dim) -->
      <rect class="pc-dim" x="166" y="143" width="9" height="16" rx="2" />
      <rect class="pc-dim" x="178" y="143" width="9" height="16" rx="2" />
      <rect class="pc-dim" x="190" y="143" width="9" height="16" rx="2" />
      <text class="pc-axis pc-axis-dim" x="206" y="156">fragmented</text>

      <text class="pc-cap-tick" x="160" y="190" text-anchor="middle">same meaning · different granularity — genuine or surface?</text>
    </g>
  )}

  {kind === "hangl" && (
    <g>
      <text class="pc-cap" x="22" y="26">Sino-Korean · surface script vs latent Hanja</text>

      {/* two disjoint surface forms — no edge between them (zero character overlap) */}
      <rect class="pc-dim" x="40" y="56" width="64" height="34" rx="4" />
      <text class="pc-cjk" x="72" y="79" text-anchor="middle">학교</text>
      <text class="pc-axis" x="72" y="104" text-anchor="middle">Hangul surface</text>

      <rect class="pc-dim" x="216" y="56" width="64" height="34" rx="4" />
      <text class="pc-cjk" x="248" y="79" text-anchor="middle">學校</text>
      <text class="pc-axis" x="248" y="104" text-anchor="middle">Hanja structure</text>

      <text class="pc-neq" x="160" y="78" text-anchor="middle">≠</text>

      {/* both bind to one shared latent meaning node beneath */}
      <path class="pc-dim pc-dash" d="M 78 90 C 100 118, 132 128, 150 134" marker-end={`url(#pc-${kind}-d)`} />
      <path class="pc-dim pc-dash" d="M 242 90 C 220 118, 188 128, 170 134" marker-end={`url(#pc-${kind}-d)`} />
      <circle class="pc-acc-soft" cx="160" cy="142" r="15" />
      <circle class="pc-acc-f" cx="160" cy="142" r="8" />
      <text class="pc-axis" x="160" y="170" text-anchor="middle">latent meaning</text>

      <text class="pc-cap-tick" x="160" y="190" text-anchor="middle">strong models bridge them without the explicit Hanja cue</text>
    </g>
  )}
</svg>

<style>
  .proj-cover { display: block; width: 100%; height: 100%; overflow: visible; }

  /* Strokes */
  .pc-acc { stroke: currentColor; fill: none; stroke-width: 1.4; }
  .pc-acc-soft { stroke: currentColor; fill: none; stroke-width: 1; opacity: 0.32; }
  .pc-dim { stroke: var(--color-text-dim); fill: none; stroke-width: 1.1; }
  .pc-w { stroke-width: 1.8; }
  .pc-dash { stroke-dasharray: 3 2.5; }
  .pc-dash-r { stroke-dasharray: 2 2; }

  /* Fills */
  .pc-acc-f { fill: currentColor; stroke: none; }

  /* Cut + arrowheads */
  .pc-cut line { stroke: currentColor; stroke-width: 1.6; stroke-linecap: round; }
  .pc-arrhead { fill: none; stroke: currentColor; stroke-width: 1.4; stroke-linecap: round; stroke-linejoin: round; }
  .pc-arrhead-dim { fill: none; stroke: var(--color-text-dim); stroke-width: 1.4; stroke-linecap: round; stroke-linejoin: round; }
  .pc-manifold { stroke: var(--color-text-dim); fill: none; stroke-width: 1; opacity: 0.55; stroke-dasharray: 2 3; }
  .pc-cloud circle { fill: var(--color-text-dim); opacity: 0.55; }

  /* Text */
  .pc-cap {
    font-family: var(--font-mono);
    font-size: 8.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    fill: var(--color-text-muted);
  }
  .pc-cap-tick {
    font-family: var(--font-mono);
    font-size: 8px;
    letter-spacing: 0.04em;
    fill: var(--color-text-muted);
  }
  .pc-cap-tick-dim { fill: var(--color-text-dim); font-style: italic; }
  .pc-tick {
    font-family: var(--font-mono);
    font-size: 7.5px;
    letter-spacing: 0.06em;
    fill: var(--color-text-dim);
    text-transform: uppercase;
  }
  .pc-node-label {
    font-family: var(--font-mono);
    font-size: 10px;
    fill: var(--color-text);
    font-weight: 500;
  }
  .pc-node-dim { fill: var(--color-text-dim); }
  .pc-token {
    font-family: var(--font-mono);
    font-size: 10px;
    fill: currentColor;
    font-weight: 500;
    letter-spacing: 0.02em;
  }
  .pc-token-dim { fill: var(--color-text-dim); font-style: italic; }
  .pc-hop {
    font-family: var(--font-display);
    font-size: 14px;
    fill: currentColor;
    font-weight: 600;
  }
  .pc-hop-dim { fill: var(--color-text-dim); }
  .pc-lang {
    font-family: var(--font-mono);
    font-size: 9px;
    fill: var(--color-text-muted);
    letter-spacing: 0.1em;
    font-weight: 500;
  }
  .pc-lang-dim { fill: var(--color-text-dim); font-style: italic; }
  .pc-cjk {
    font-family: var(--font-mono);
    font-size: 18px;
    fill: var(--color-text-muted);
    font-weight: 500;
  }
  .pc-neq {
    font-family: var(--font-mono);
    font-size: 15px;
    fill: var(--color-text-dim);
  }
  .pc-row-label {
    font-family: var(--font-mono);
    font-size: 8.5px;
    fill: var(--color-text-muted);
    letter-spacing: 0.04em;
  }
