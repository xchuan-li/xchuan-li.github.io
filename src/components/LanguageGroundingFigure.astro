---
// LanguageGroundingFigure — concept illustration for the homepage About section.
// A small causal DAG over a sentence's constituents. Agreement attraction:
// "The key [to the cabinets] ___" — the verb should agree with the structural
// head ("key"), not the linearly nearest noun ("cabinets"). A do()-intervention
// on the surface cue tests which one the model's answer is actually licensed by.
//   amber  = structural dependency / grounded   (the head -> the verb)
//   coral  = surface correlation / spurious      (the nearest noun -> the verb)
// Right-angle (Manhattan) routing, theme-aware, no card chrome.
---

<figure class="ag-fig" aria-label="A causal diagram over a sentence's constituents. In 'The key to the cabinets ___', a solid structural edge runs from the head 'key' to the verb's agreement, and a dashed surface edge runs from the nearest noun 'cabinets' to the verb; a do-intervention severs the surface edge. Grounded behavior tracks the head; spurious behavior tracks the nearest noun.">
  <svg viewBox="0 0 440 360" shape-rendering="geometricPrecision" preserveAspectRatio="xMidYMid meet">
    <defs>
      <marker id="ag-m-a" viewBox="0 0 10 10" refX="7" refY="5" markerWidth="6" markerHeight="6" orient="auto">
        <path class="ag-mh-a" d="M0 0 L10 5 L0 10 z" />
      </marker>
      <marker id="ag-m-c" viewBox="0 0 10 10" refX="7" refY="5" markerWidth="6" markerHeight="6" orient="auto">
        <path class="ag-mh-c" d="M0 0 L10 5 L0 10 z" />
      </marker>
    </defs>

    <!-- legend -->
    <line class="ag-e-a" x1="30" y1="30" x2="50" y2="30" />
    <text class="ag-leg ag-amber" x="56" y="33.5">structural dependency</text>
    <line class="ag-e-c" x1="30" y1="46" x2="50" y2="46" />
    <text class="ag-leg ag-muted" x="56" y="49.5">surface correlation</text>

    <!-- sentence -->
    <text class="ag-sent" x="220" y="86" text-anchor="middle"><tspan class="ag-muted">The </tspan><tspan class="ag-amber ag-b">key</tspan><tspan class="ag-dim"> [to the </tspan><tspan class="ag-coral ag-b">cabinets</tspan><tspan class="ag-dim">]</tspan><tspan class="ag-muted"> ___</tspan></text>
    <line class="ag-rule" x1="44" y1="100" x2="396" y2="100" />

    <!-- constituent nodes -->
    <text class="ag-word ag-amber" x="95" y="150" text-anchor="middle">key</text>
    <text class="ag-role" x="95" y="164" text-anchor="middle">head · subject</text>
    <circle class="ag-node ag-node-a" cx="95" cy="184" r="4" />

    <text class="ag-word ag-muted" x="220" y="150" text-anchor="middle">to the cabinets</text>
    <text class="ag-role" x="220" y="164" text-anchor="middle">modifier · intervenes</text>
    <circle class="ag-node ag-node-b" cx="220" cy="184" r="4" />

    <text class="ag-word ag-coral" x="355" y="150" text-anchor="middle">cabinets</text>
    <text class="ag-role" x="355" y="164" text-anchor="middle">nearest noun</text>
    <circle class="ag-node ag-node-c" cx="355" cy="184" r="4" />

    <!-- answer node -->
    <circle class="ag-halo" cx="220" cy="300" r="10" />
    <circle class="ag-ans-dot" cx="220" cy="300" r="4.5" />
    <text class="ag-ans" x="220" y="326" text-anchor="middle">VERB AGREEMENT</text>

    <!-- structural edge: head -> verb (solid, long-range dependency) -->
    <path class="ag-e-a" d="M 95 188 V 256 H 214 V 286" marker-end="url(#ag-m-a)" />
    <text class="ag-edgelbl ag-amber" x="100" y="250">syntactic dependency</text>

    <!-- surface edge: nearest noun -> verb (dashed, short/linear), severed by do() -->
    <path class="ag-e-c" d="M 355 188 V 266 H 226 V 286" marker-end="url(#ag-m-c)" />
    <g class="ag-cut" transform="translate(355,222)">
      <line x1="-5" y1="-5" x2="5" y2="5" />
      <line x1="5" y1="-5" x2="-5" y2="5" />
    </g>
    <text class="ag-dolbl" x="366" y="226">do(cue)</text>

    <!-- caption -->
    <text class="ag-cap" x="220" y="348" text-anchor="middle">grounded tracks the head — spurious tracks the nearest noun</text>
  </svg>
</figure>

<style>
  .ag-fig { margin: 0; padding: 0; }
  .ag-fig svg { width: 100%; max-width: 460px; height: auto; display: block; margin: 0 auto; font-family: var(--font-mono); }

  /* color helpers */
  .ag-amber { fill: var(--accent-amber); }
  .ag-coral { fill: var(--accent-coral); }
  .ag-muted { fill: var(--color-text-muted); }
  .ag-dim { fill: var(--color-text-dim); }
  .ag-b { font-weight: 600; }

  .ag-leg { font-size: 9.5px; letter-spacing: 0.02em; }
  .ag-sent { font-size: 13px; }
  .ag-role { font-size: 9px; letter-spacing: 0.05em; fill: var(--color-text-dim); }
  .ag-word { font-size: 11px; font-weight: 600; letter-spacing: 0.02em; }
  .ag-ans { font-size: 9.5px; letter-spacing: 0.14em; fill: var(--color-text-muted); }
  .ag-edgelbl { font-size: 9px; font-style: italic; }
  .ag-dolbl { font-size: 9.5px; font-style: italic; fill: var(--accent-coral); }
  .ag-cap { font-size: 9.5px; font-style: italic; fill: var(--color-text-dim); letter-spacing: 0.02em; }

  .ag-rule { stroke: var(--color-border-strong); stroke-width: 0.5; }

  .ag-node { fill: var(--color-bg); stroke-width: 1.2; }
  .ag-node-a { stroke: var(--accent-amber); }
  .ag-node-b { stroke: var(--color-text-dim); }
  .ag-node-c { stroke: var(--accent-coral); }

  .ag-halo { fill: var(--accent-amber); opacity: 0.14; }
  .ag-ans-dot { fill: var(--accent-amber); }

  .ag-e-a { stroke: var(--accent-amber); stroke-width: 1.3; fill: none; }
  .ag-e-c { stroke: var(--accent-coral); stroke-width: 1.2; fill: none; stroke-dasharray: 4 3; }
  .ag-mh-a { fill: var(--accent-amber); }
  .ag-mh-c { fill: var(--accent-coral); }

  .ag-cut line { stroke: var(--accent-coral); stroke-width: 1.6; stroke-linecap: round; }
</style>
