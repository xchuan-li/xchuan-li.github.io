---
// SectionDivider — a thin line with a tiny geometric mark.
// `mark` prop chooses which symbol appears. Defaults to a small dot triplet.
interface Props {
  mark?: "dots" | "arrow" | "node" | "x";
  ariaLabel?: string;
}
const { mark = "dots", ariaLabel } = Astro.props;
---

<div class="section-divider" role={ariaLabel ? "separator" : "presentation"} aria-label={ariaLabel}>
  <span class="line"></span>
  <span class="mark">
    {mark === "dots" && (
      <svg viewBox="0 0 24 8" aria-hidden="true">
        <circle cx="4" cy="4" r="1.5" />
        <circle cx="12" cy="4" r="1.5" />
        <circle cx="20" cy="4" r="1.5" />
      </svg>
    )}
    {mark === "arrow" && (
      <svg viewBox="0 0 24 8" aria-hidden="true">
        <line x1="2" y1="4" x2="20" y2="4" stroke="currentColor" stroke-width="1" />
        <path d="M 16 1 L 22 4 L 16 7" fill="none" stroke="currentColor" stroke-width="1" />
      </svg>
    )}
    {mark === "node" && (
      <svg viewBox="0 0 24 8" aria-hidden="true">
        <circle cx="6" cy="4" r="2.5" fill="none" stroke="currentColor" stroke-width="1" />
        <line x1="9" y1="4" x2="18" y2="4" stroke="currentColor" stroke-width="1" />
      </svg>
    )}
    {mark === "x" && (
      <svg viewBox="0 0 24 8" aria-hidden="true">
        <line x1="8" y1="0" x2="16" y2="8" stroke="currentColor" stroke-width="1" />
        <line x1="8" y1="8" x2="16" y2="0" stroke="currentColor" stroke-width="1" />
      </svg>
    )}
  </span>
  <span class="line"></span>
</div>

<style>
  .section-divider {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 3rem 0 2rem;
    color: var(--color-text-dim);
  }
  .line {
    flex: 1;
    height: 0.5px;
    background: var(--color-border);
  }
  .mark {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
  }
  .mark svg {
    width: 24px;
    height: 8px;
    fill: currentColor;
  }
</style>
