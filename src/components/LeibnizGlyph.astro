---
// LeibnizGlyph - a minimalist single-stroke line portrait of Leibniz, recognizable
// by the full-bottomed baroque periwig (the big symmetric curl masses framing the
// face). Evocative, not photo-accurate - the honest limit of clean line-art.
// Inherits color from `currentColor`; size via the `size` prop.
interface Props {
  size?: number;
  class?: string;
}
const { size = 24, class: klass = "" } = Astro.props;
---

<svg
  class={klass}
  width={size}
  height={size}
  viewBox="0 0 48 54"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  role="img"
  aria-label="Line portrait of Leibniz"
>
  <title>Leibniz</title>
  <!-- face -->
  <path d="M18.5 19 C18.5 13.5 29.5 13.5 29.5 19 C30.3 25 28 31 24 32 C20 31 17.7 25 18.5 19 Z" />
  <!-- crown of the wig over the brow -->
  <path d="M17 17 C18.5 9.5 29.5 9.5 31 17" />
  <!-- left periwig curls falling to the shoulder -->
  <path d="M17 17 C10.5 16.5 8.5 24.5 11.8 31.5 C8.8 35.5 11 41.5 16.2 42.5 C14 37.5 17 35.5 18.2 31.5" />
  <!-- right periwig curls -->
  <path d="M31 17 C37.5 16.5 39.5 24.5 36.2 31.5 C39.2 35.5 37 41.5 31.8 42.5 C34 37.5 31 35.5 29.8 31.5" />
  <!-- collar / shoulders -->
  <path d="M16.2 42.5 C18.5 47.5 29.5 47.5 31.8 42.5" />
  <!-- eyes + nose, the faintest suggestion of a face -->
  <path d="M20.8 22 H22.6" />
  <path d="M25.4 22 H27.2" />
  <path d="M24 23.5 V26.3" />
</svg>
