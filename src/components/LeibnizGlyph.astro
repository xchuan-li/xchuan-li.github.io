---
// LeibnizGlyph - a minimalist single-stroke line portrait of Leibniz, recognizable
// by the full-bottomed baroque periwig (the big symmetric curl masses framing the
// face). Evocative, not photo-accurate - the honest limit of clean line-art.
// Inherits color from `currentColor`; size via the `size` prop.
interface Props {
  size?: number;
  class?: string;
}
const { size = 24, class: klass = "" } = Astro.props;
---

<svg
  class={klass}
  width={size}
  height={size}
  viewBox="0 0 64 72"
  fill="none"
  stroke="currentColor"
  stroke-width="1.7"
  stroke-linecap="round"
  stroke-linejoin="round"
  role="img"
  aria-label="Line portrait of Leibniz"
>
  <title>Leibniz</title>
  <!-- oval face -->
  <path d="M24 23 C24 15.5 40 15.5 40 23 C41.2 32 38 41 32 42.5 C26 41 22.8 32 24 23 Z" />
  <!-- parted crown and brow line -->
  <path d="M21.5 22 C23.5 10 40.5 10 42.5 22" />
  <path d="M25.2 20 C28.3 17.4 35.7 17.4 38.8 20" />
  <!-- left periwig mass with stacked curls -->
  <path d="M22 20 C14 18.8 10.5 25.5 13.5 32.5 C9.4 36.5 10.2 44.8 16.8 46.8 C12.8 52.6 17.6 61.2 25 58.8" />
  <path d="M18.8 23 C13.2 25.8 16.2 32.2 21.2 29.8" />
  <path d="M17.3 32.5 C11.8 35.6 15.3 42.2 20.5 39.2" />
  <path d="M17.3 43.5 C12.5 47.6 16.7 53.8 22.3 49.4" />
  <!-- right periwig mass with stacked curls -->
  <path d="M42 20 C50 18.8 53.5 25.5 50.5 32.5 C54.6 36.5 53.8 44.8 47.2 46.8 C51.2 52.6 46.4 61.2 39 58.8" />
  <path d="M45.2 23 C50.8 25.8 47.8 32.2 42.8 29.8" />
  <path d="M46.7 32.5 C52.2 35.6 48.7 42.2 43.5 39.2" />
  <path d="M46.7 43.5 C51.5 47.6 47.3 53.8 41.7 49.4" />
  <!-- collar and shoulders -->
  <path d="M24.8 43.8 C26.8 48.2 37.2 48.2 39.2 43.8" />
  <path d="M19.5 59.5 C24 64 40 64 44.5 59.5" />
  <!-- face details -->
  <path d="M27.5 28.5 H29.8" />
  <path d="M34.2 28.5 H36.5" />
  <path d="M32 30.2 V34.2" />
  <path d="M29.4 37.5 C31.2 38.5 32.8 38.5 34.6 37.5" />
</svg>
