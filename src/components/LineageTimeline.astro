---
// A quiet, horizontal lineage timeline for the research-program page: five nodes
// tracing the inherited question from Leibniz to language models. Thin line, small
// dots, small mono labels — understated on purpose. Horizontal on desktop; stacks
// to a vertical rail on narrow screens (following the site's ResearchTimeline).
const nodes = [
  { year: "1686", name: "Leibniz" },
  { year: "1963", name: "Kripke" },
  { year: "1981", name: "Kratzer" },
  { year: "2020", name: "Leahy & Carey" },
  { year: "now", name: "LMs" },
];
---

<div class="lineage-tl" role="list" aria-label="Intellectual lineage, Leibniz to language models">
  <div class="lineage-track">
    {
      nodes.map((n) => (
        <div class="lineage-node" role="listitem">
          <span class="lineage-dot" aria-hidden="true" />
          <span class="lineage-label">
            <span class="lineage-year">{n.year}</span>
            <span class="lineage-name">{n.name}</span>
          </span>
        </div>
      ))
    }
  </div>
</div>

<style>
  .lineage-tl {
    margin: 2.25rem 0 2.75rem;
  }
  .lineage-track {
    position: relative;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.5rem;
  }
  /* the connecting line, drawn behind the dots between the first and last node */
  .lineage-track::before {
    content: "";
    position: absolute;
    top: 4px;
    left: 10%;
    right: 10%;
    height: 1px;
    background: var(--color-border-strong);
    z-index: 0;
  }
  .lineage-node {
    position: relative;
    z-index: 1;
    flex: 1 1 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.55rem;
    min-width: 0;
  }
  .lineage-dot {
    width: 9px;
    height: 9px;
    border-radius: 999px;
    background: var(--color-accent);
    /* ring in the page background so the line reads as passing behind the dot */
    box-shadow: 0 0 0 3px var(--color-bg);
    transition: transform 0.18s ease, background 0.18s ease;
  }
  .lineage-node:hover .lineage-dot {
    transform: scale(1.35);
    background: var(--accent-deep-purple);
  }
  .lineage-label {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.12rem;
    text-align: center;
  }
  .lineage-year {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--color-text);
  }
  .lineage-name {
    font-size: 11px;
    line-height: 1.3;
    color: var(--color-text-muted);
  }

  /* Narrow screens: stack into a vertical rail with the line running down the left. */
  @media (max-width: 560px) {
    .lineage-track {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
    }
    .lineage-track::before {
      top: 0.75rem;
      bottom: 0.75rem;
      left: 4px;
      right: auto;
      width: 1px;
      height: auto;
    }
    .lineage-node {
      flex: none;
      flex-direction: row;
      align-items: center;
      justify-content: flex-start;
      gap: 0.85rem;
      padding: 0.5rem 0;
    }
    .lineage-label {
      flex-direction: row;
      align-items: baseline;
      gap: 0.5rem;
      text-align: left;
    }
  }
</style>
